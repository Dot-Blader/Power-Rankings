@using Umbraco.Cms.Web.Common.PublishedModels;
@inherits Umbraco.Cms.Web.Common.Views.UmbracoViewPage<HomePage>
@using Umbraco.Cms.Core.Models.Blocks;
@{
	Layout = "mainLayout.cshtml";

	IEnumerable<BlockListItem> blocks = Model.List!;

	blocks = blocks.OrderByDescending(b =>
		b.Settings.Value<float?>("energyExponent")).ThenByDescending(b => b.Settings.Value<float?>("energyMultiplicator"));

	var blocksOrderId = blocks.OrderByDescending(b => b.Settings.Value<int>("orderId"));
}

