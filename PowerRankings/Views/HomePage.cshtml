	<div class="container">
		<div class="site-title">POWER RANKINGS</div>

		<div class="options-menu options">
			<div id="All" class="options-btn obtn">All</div>
			<div id="Destiny" class="options-btn obtn btn-destiny">Destiny</div>
			<div id="LittleNightmares" class="options-btn obtn btn-LN">Little Nightmares</div>
			<div id="Sonic" class="options-btn obtn btn-sonic">SONIC</div>
		</div>

		<div class="tier">
			<div class="tier-name">Boundless</div>
			<div class="tier-content open">
				<div class="umb-block-list">
					@{
						foreach (var block in blocksOrderId!.Where(b => b.Settings?.Value<string>("Tiers") == "Boundless"))
						{
							@await Html.PartialAsync($"~/Views/Partials/blocklist/Components/{block.Content.ContentType.Alias}.cshtml", block)
