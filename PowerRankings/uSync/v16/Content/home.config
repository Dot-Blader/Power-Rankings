        {
          "alias": "mainPicture",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": [
            {
              "key": "a890170a-0723-4b11-9753-5ce239da629c",
              "mediaKey": "b81ede95-c02d-46b3-a3af-ef0757499747",
              "mediaTypeAlias": "Image",
              "crops": [],
              "focalPoint": null
            }
          ]
        },
        {
          "alias": "details",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "Interceptors are slow-moving, hovering vehicles used by the Cabal for warfare. They are equipped with a pair of high-yield cannons that can shred apart enemy infantry effectively. The cannons have about a quarter of the firepower of the larger Goliath Tank\u0027s main cannon."
        }
      ]
    },
    {
      "contentTypeKey": "6f386c25-c5f7-4cc6-8761-a63a480078ba",
      "key": "2774212f-2a69-4644-a5b6-d0aae804db93",
      "udi": null,
      "values": [
        {
          "alias": "energyMultiplicator",
          "culture": null,
