                  {
                    "alias": "characterName",
                    "culture": null,
                    "editorAlias": null,
                    "segment": null,
                    "value": "Nixis, Hunger of Oryx"
                  },
                  {
                    "alias": "characterVariant",
                    "culture": null,
                    "editorAlias": null,
                    "segment": null,
                    "value": "Ascendant Plane"
                  },
                  {
                    "alias": "characterSource",
                    "culture": null,
                    "editorAlias": null,
                    "segment": null,
                    "value": "Destiny: The Taken King"
                  },
                  {
                    "alias": "mainPicture",
