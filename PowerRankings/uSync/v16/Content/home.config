        {
          "alias": "characterName",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "Argos, Planetary Core"
        },
        {
          "alias": "characterSource",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "Destiny 2: Curse of Osiris"
        },
        {
          "alias": "details",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "Argos was a massive Hydra initially located at the core of 7066 Nessus. Its purpose was to transform the Centaur into a Machine-World, which it succeeded in doing. When Calus\u0027s Leviathan started sucking up the crust of Nessus, the core with Argos was ripped out and sucked in too. Argos would set up a barrier within the maw of the Leviathan, blocking its systems. Coincidentally a Guardian fireteam happened to infiltrate the ship looking to investigate Calus, and Calus would request that they faced Argos with their Light."
        },
        {
          "alias": "mainPicture",
          "culture": null,
          "editorAlias": null,
          "segment": null,
