                      }
                    ]
                  },
                  {
                    "alias": "mainPicture",
                    "culture": null,
                    "editorAlias": null,
                    "segment": null,
                    "value": [
                      {
                        "key": "fd7976a0-212f-49f7-b016-ba7567262e3e",
                        "mediaKey": "90c47504-c941-45a1-8867-9599fcff945d",
                        "mediaTypeAlias": "Image",
                        "crops": [],
                        "focalPoint": null
                      }
                    ]
                  },
                  {
                    "alias": "characterSource",
                    "culture": null,
                    "editorAlias": null,
                    "segment": null,
                    "value": "Destiny: House of Wolves"
                  },
                  {
                    "alias": "characterName",
                    "culture": null,
                    "editorAlias": null,
                    "segment": null,
                    "value": "Vekis, King Baron"
                  },
                  {
                    "alias": "details",
                    "culture": null,
                    "editorAlias": null,
                    "segment": null,
                    "value": "Vekis was a Baron of the House of Kings who partook in the negotiations between them and the House of Wolves. Vekis was armed with Shock Blades, and with his partner Paskin wielding ranged weaponry they could handle any potential assassination attempts from the Wolves."
                  }
                ]
              },
              {
                "contentTypeKey": "6f386c25-c5f7-4cc6-8761-a63a480078ba",
                "key": "9bad646b-ea53-4c06-af52-03a1bb2c802f",
                "udi": null,
                "values": [
                  {
                    "alias": "profilePicture",
                    "culture": null,
                    "editorAlias": null,
                    "segment": null,
                    "value": [
                      {
                        "key": "e9360737-a76a-4279-9cd7-b42fc783d932",
                        "mediaKey": "31883792-edb4-4dd8-aa26-61e6cb4f52be",
