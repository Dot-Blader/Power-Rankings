          ]
        },
        {
          "alias": "details",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "Parthenios was an incredibly powerful Taken Hydra that Toniq sent into the HyperNet Current Vex domain. Parthenios was assigned to spread the Blight of the Taken throughout the Network, intending to use it to breach Neomuna\u0027s CloudArk. It had control over massive Blights and used its Taken Power to enhance its shields and weapons."
        },
        {
          "alias": "characterVariant",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "Vex Network"
        }
      ]
    },
