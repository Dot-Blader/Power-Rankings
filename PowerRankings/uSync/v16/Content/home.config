        {
          "alias": "characterName",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "Resonant Splinter"
        },
        {
          "alias": "characterSource",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "Destiny 2: The Witch Queen"
        },
        {
          "alias": "details",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "The Witness could calcify massive amounts of defeated foes into a form of resin that it could use to channel its Darkness. Resonant Splinters are spheres of this resin contained within a sort of Pyramid-tech vehicle that the Witness granted to the Scorn serving it within Savath\u00FBn\u0027s Throne World. The amount of power within just this small sphere was sufficient to obliterate the entire Throne World, a 5-Dimensional structure."
        },
        {
          "alias": "energyMultiplicator",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "5-Dimensional"
        },
        {
          "alias": "characterTitle",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "Pyramid Superweapon"
        }
      ]
    },
    {
      "contentTypeKey": "6f386c25-c5f7-4cc6-8761-a63a480078ba",
      "key": "a9d277b3-5ab3-4c2b-985f-be5387a07b14",
      "udi": null,
      "values": [
        {
          "alias": "energyMultiplicator",
