            }
          ]
        },
        {
          "alias": "characterName",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "The Caretaker"
        },
        {
          "alias": "characterSource",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "Destiny 2: The Witch Queen"
        },
        {
          "alias": "details",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "The Caretaker was a Scorn who Rhulk experimented on and successfully fused with a worm larva. Like the Hive, this made the Caretaker more powerful with the Darkness, and Rhulk assigned the abomination to oversee his collection of experiments. As a fireteam of Guardians assaulted the Pyramid Ship, they disturbed the Caretaker who promptly attempted to annihilate them by channeling its Resonance through Pyramid-tech obelisks into a massive explosion."
        },
        {
          "alias": "energyExponent",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "24"
        },
        {
          "alias": "mainPicture",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": [
