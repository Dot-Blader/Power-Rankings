            }
          ]
        },
        {
          "alias": "characterName",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "Egg Wizard"
        },
        {
          "alias": "mainPicture",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": [
            {
              "key": "07208e38-08c7-4adb-9846-0868dc60082d",
              "mediaKey": "da5f790a-cdaf-4cc1-b0fd-730633d9e0db",
              "mediaTypeAlias": "Image",
              "crops": [],
              "focalPoint": null
            }
          ]
        },
        {
          "alias": "characterSource",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "Sonic Rush Adventure"
        },
        {
          "alias": "details",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "The Egg Wizard was a robot built and used by Doctor Eggman and Eggman Nega to harness the \u0022Power of the Stars\u0022 through wielding the Jeweled Scepter. At the time Eggman considered the Power of the Stars to be greater than anything the Chaos Emeralds could accomplish, and this is after having encountered Super Sonic and seen his full power. What the two Eggmen hadn\u0027t realised was that when multiple Chaos Emerald-enhanced beings fight together, their powers combine and increase exponentially. This allowed Sonic and Blaze to defeat the Eggmen, using their Super Sonic and Burning Blaze forms respectively to destroy the robot."
        }
      ]
    },
    {
      "contentTypeKey": "6f386c25-c5f7-4cc6-8761-a63a480078ba",
      "key": "646b4136-a2d1-4f5d-b5bb-00ecc1d5296d",
      "udi": null,
      "values": [
        {
          "alias": "energyMultiplicator",
