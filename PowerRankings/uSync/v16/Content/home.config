    },
    {
      "contentTypeKey": "6f386c25-c5f7-4cc6-8761-a63a480078ba",
      "key": "dd725258-d427-4230-b329-55d0008770f5",
      "udi": null,
      "values": [
        {
          "alias": "energyMultiplicator",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "1,54"
        },
        {
          "alias": "characterName",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "Prohibitive Mind"
        },
        {
          "alias": "characterSource",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "Destiny"
        },
        {
          "alias": "details",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "The Prohibitive Mind was the Axis Mind that led the programming collective Virgo Prohibition. Its primary goal was to transform Mars into a Machine-World, allowing the planet to become a node in the Vex Network. As a subgoal it coordinated assaults on the Cabal of Mars, a purpose its programming wasn\u0027t initially made for. This led to a surprising failure for the Vex against the Cabal, which stunted them long enough that they would end up mostly wiped out by both Cabal and Guardians of the Last City before finishing their goal."
        },
        {
          "alias": "profilePicture",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": [
            {
              "key": "575f78f2-fbc2-496c-bb05-922948441b21",
