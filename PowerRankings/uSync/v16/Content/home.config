                  {
                    "alias": "details",
                    "culture": null,
                    "editorAlias": null,
                    "segment": null,
                    "value": "Ungoloth would have its soul returned to the Ascendant Plane as all Taken would after being defeated in material space. Its ultimate fate remains unknown."
