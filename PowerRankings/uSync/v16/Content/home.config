        {
          "alias": "details",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "SHINOBI was a more durable version of the NINJA. It was able to move swiftly and could detect incoming attacks and block them before countering with its own sharp blades."
        }
      ]
    },
