                  {
                    "alias": "characterVariant",
                    "culture": null,
                    "editorAlias": null,
                    "segment": null,
                    "value": "Material Space"
                  },
                  {
                    "alias": "characterSource",
                    "culture": null,
                    "editorAlias": null,
                    "segment": null,
                    "value": "Destiny: The Taken King"
                  },
                  {
                    "alias": "details",
                    "culture": null,
                    "editorAlias": null,
                    "segment": null,
                    "value": "Nixis was a Fallen Archon Priest trapped in the Prison of Elders. He was rescued by the House of Winter during the Taken War in hopes of rallying the broken House and help them survive Oryx. Before the Fallen could fully restore his soul however, he was Taken by Oryx, and was made to be Ascendant, channeling Taken from the Ascendant Plane onto Venus deep in the House of Winter\u0027s lair."
                  }
                ]
              }
            ],
