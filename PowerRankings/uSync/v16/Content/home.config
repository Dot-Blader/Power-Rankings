        },
        {
          "alias": "characterSource",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "Destiny 2: Beyond Light"
        },
        {
          "alias": "characterName",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "Praksis, the Technocrat"
        },
        {
          "alias": "details",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "Praksis was a member of the Dark Council serving Eramis. He was the genius who figured out how to receive Stasis-abilities from Pyramid Splinters. He assisted the House of Salvation with gifting this Darkness to more Eliksni, and personally wore a massive Splinter on his back which he harnessed immense amounts of Stasis-power from."
        },
        {
          "alias": "profilePicture",
          "culture": null,
