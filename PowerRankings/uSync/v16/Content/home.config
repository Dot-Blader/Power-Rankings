                            {
                              "alias": "characterName",
                              "culture": null,
                              "editorAlias": null,
                              "segment": null,
                              "value": "Mengoor"
                            },
                            {
                              "alias": "characterVariant",
                              "culture": null,
                              "editorAlias": null,
                              "segment": null,
                              "value": "Material Space"
                            },
                            {
                              "alias": "details",
                              "culture": null,
                              "editorAlias": null,
                              "segment": null,
                              "value": "Mengoor was a Hive Knight who was dyad-bound to Cra\u0027adug, another Hive Knight. Together they fought against the Taishibethi for ten years straight without faultering, and were members of Oryx\u0027s Court. When they helped tear down the Gift Mast, they tithed their share of its power to each other instead of Oryx. In response, Oryx would curse them so that their camaraderie would be their death. "
                            },
                            {
                              "alias": "mainPicture",
                              "culture": null,
                              "editorAlias": null,
                              "segment": null,
                              "value": [
                                {
                                  "key": "2e3956fd-c1e3-43a3-a68d-4070c2b3e009",
