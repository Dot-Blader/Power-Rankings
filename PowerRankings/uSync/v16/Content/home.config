                  },
                  {
                    "alias": "details",
                    "culture": null,
                    "editorAlias": null,
                    "segment": null,
                    "value": "Within the Throne World of Oryx, at the rear of the Dreadnaught, the daughters cast the spells that made sure the impossible warship could function within material space."
                  },
                  {
                    "alias": "profilePicture",
                    "culture": null,
                    "editorAlias": null,
                    "segment": null,
                    "value": [
                      {
                        "key": "edb54f01-3b92-479d-8a79-7049dd58d4bb",
