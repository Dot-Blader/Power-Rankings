        {
          "alias": "characterName",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "The Witness"
        },
        {
          "alias": "characterTitle",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "The First Knife"
        },
        {
          "alias": "characterVariant",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "Zenith"
        },
        {
          "alias": "characterSource",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "Destiny 2: The Final Shape"
        },
        {
          "alias": "details",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "The Witness was an entire civilization combined into one incredibly powerful entity. It sought to end all pain and suffering in the universe by finalizing it into a state where nothing could live or die. After combining the powers of the Traveler\u0027s Light and the Darkness of the Veil, the Witness reached the zenith of its power, and attempted to enact the Final Shape."
        },
        {
          "alias": "mainPicture",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": [
            {
              "key": "a6db5f5e-9d1f-4c9b-96cf-341a2a5c159e",
              "mediaKey": "4a306171-06dd-4acb-acc7-25854279bbde",
              "mediaTypeAlias": "Image",
              "crops": [],
              "focalPoint": null
            }
          ]
        }
      ]
    },
    {
