          "segment": null,
          "value": "61"
        },
        {
          "alias": "details",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "Oryx, the Taken King, was the heir to the Osmium Court. Oryx grew more powerful over time than any other Hive, and his Court would tithe an extremely large amount of power to him. He gained the power to Take from communing with the Winnower itself, and would create the Taken by removing his enemies\u0027 weaknesses and enhancing their strengths, binding their will to his own. After billions of years of growth and conquest at the behest of his worm\u0027s hunger, Oryx had grown far more powerful than any other Hive in the universe, receiving tributes from his Court."
        },
        {
          "alias": "mainPicture",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": [
            {
              "key": "373de6a8-37dc-468b-9dba-dededffd6617",
              "mediaKey": "22e72d6f-5869-4348-be93-f3eeb5ad4a04",
              "mediaTypeAlias": "Image",
              "crops": [],
              "focalPoint": null
            }
          ]
        },
        {
          "alias": "characterSource",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "Destiny: The Taken King"
        }
      ]
    },
