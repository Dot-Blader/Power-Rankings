        },
        {
          "alias": "characterSource",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "Destiny"
        },
        {
          "alias": "mainPicture",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": [
            {
              "key": "da821b01-f98a-4e2c-b0ec-f185461905b1",
              "mediaKey": "1c98ded7-779a-4bf3-b2ab-1ed7266a6199",
              "mediaTypeAlias": "Image",
              "crops": [],
              "focalPoint": null
            }
          ]
        },
        {
          "alias": "details",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "A Wizard can perform a ritual on a Hive Thrall that turns them into an Ogre. They\u0027re tortured with Light, making them hate it more than anything in the universe. Once morphed, the Ogre has heightened cunning, but will behave like a mindless killing machine of pure rage at the sight of a Lightbearer."
        }
      ]
    },
    {
      "contentTypeKey": "6f386c25-c5f7-4cc6-8761-a63a480078ba",
      "key": "b772ace2-9dbc-41fd-b36f-65d2120bcc35",
