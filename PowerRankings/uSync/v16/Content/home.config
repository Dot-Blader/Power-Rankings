          "value": "7,47"
        },
        {
          "alias": "energyExponent",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "10"
        },
        {
          "alias": "characterName",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "Cabal Elites"
        },
        {
          "alias": "characterSource",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "Destiny"
        },
        {
          "alias": "details",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "The oldest Cabal grow massive and extremely naturally strong. Due to having survived countless battles they usually prove their worth to the Cabal High Command and ascend to high ranks. They wear ultra-dense armor, so strong that facing them would feel like facing a tank to most of their enemies."
        },
        {
          "alias": "profilePicture",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": [
            {
              "key": "e3f804b2-de9c-4961-ba4a-199d8c3fa5b8",
              "mediaKey": "e2585eed-0a50-45e5-a401-7a3ba4a67617",
              "mediaTypeAlias": "Image",
              "crops": [],
              "focalPoint": null
            }
          ]
        },
        {
          "alias": "groupMembers",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": {
            "contentData": [
              {
                "contentTypeKey": "6f386c25-c5f7-4cc6-8761-a63a480078ba",
                "key": "6e707c53-4f56-41be-84c0-287f6f4d9284",
                "udi": null,
                "values": [
                  {
                    "alias": "profilePicture",
                    "culture": null,
                    "editorAlias": null,
                    "segment": null,
                    "value": [
                      {
                        "key": "8ea0c6ba-c990-46c5-ae52-48360a1d681d",
                        "mediaKey": "4ba10cd4-9a8b-4e72-ab3a-2088c2ee8fb0",
                        "mediaTypeAlias": "Image",
                        "crops": [],
                        "focalPoint": null
                      }
                    ]
                  },
                  {
                    "alias": "characterName",
                    "culture": null,
                    "editorAlias": null,
                    "segment": null,
                    "value": "Valus Tau\u0027ugh"
                  },
                  {
                    "alias": "characterTitle",
                    "culture": null,
                    "editorAlias": null,
                    "segment": null,
                    "value": "Champion of the Skyburners"
                  },
                  {
                    "alias": "characterSource",
                    "culture": null,
                    "editorAlias": null,
                    "segment": null,
                    "value": "Destiny: The Taken King"
                  },
                  {
                    "alias": "mainPicture",
                    "culture": null,
                    "editorAlias": null,
                    "segment": null,
                    "value": [
                      {
                        "key": "dcf118c3-c218-4673-9c61-ed417bfabc95",
                        "mediaKey": "add79a83-5726-485f-b922-15e18e474a31",
                        "mediaTypeAlias": "Image",
                        "crops": [],
                        "focalPoint": null
                      }
                    ]
                  },
                  {
                    "alias": "details",
                    "culture": null,
                    "editorAlias": null,
                    "segment": null,
                    "value": "Tau\u0027ugh held the rank of Valus and was a member of the Skyburners legion. He was on the Dantalion Exodus VI when his Primus crashed it into the Dreadnaught of Oryx. He was selected to act as the legion\u0027s champion if a serious enemy threat attempted to breach the ship. He was summoned as Guardians defeated the Centurion Ve\u0027ength in the Hull Breach, exiting the ship fully armed and accompanied by his strongest lieutenants. "
                  }
                ]
              },
              {
                "contentTypeKey": "6f386c25-c5f7-4cc6-8761-a63a480078ba",
                "key": "ea1d8f13-410b-4707-bed0-d390ab2a584c",
                "udi": null,
                "values": [
                  {
                    "alias": "profilePicture",
                    "culture": null,
                    "editorAlias": null,
                    "segment": null,
                    "value": [
                      {
                        "key": "068e5eb1-da6a-4a09-be31-5c9aa23b6ff6",
                        "mediaKey": "73209d0d-bd33-4da0-a057-5cf4795881a2",
                        "mediaTypeAlias": "Image",
                        "crops": [],
                        "focalPoint": null
                      }
                    ]
                  },
                  {
                    "alias": "characterName",
                    "culture": null,
                    "editorAlias": null,
                    "segment": null,
                    "value": "Valus Mau\u0027ual"
                  },
                  {
                    "alias": "characterTitle",
                    "culture": null,
                    "editorAlias": null,
                    "segment": null,
                    "value": "The Nimble Boulder"
                  },
                  {
                    "alias": "characterSource",
                    "culture": null,
                    "editorAlias": null,
                    "segment": null,
                    "value": "Destiny: The Taken King"
                  },
                  {
                    "alias": "mainPicture",
                    "culture": null,
                    "editorAlias": null,
                    "segment": null,
                    "value": [
                      {
                        "key": "901aa00b-0230-49fa-9247-afd42c9c56b0",
                        "mediaKey": "47f83e2e-6928-4f78-ac9d-7abf72248a5f",
                        "mediaTypeAlias": "Image",
                        "crops": [],
                        "focalPoint": null
                      }
                    ]
                  },
                  {
                    "alias": "details",
                    "culture": null,
                    "editorAlias": null,
                    "segment": null,
                    "value": "Valus Mau\u0027ual was equipped with a back-mounted propulsion system that allowed him to swiftly charge at his enemies. He would enter battles without any weapons, smashing into his enemies with his fist and causing devastation. He was a bond-brother to Valus Tlu\u0027urn and their Primus Ta\u0027aun and a member of the Skyburners legion."
                  }
                ]
              },
              {
                "contentTypeKey": "6f386c25-c5f7-4cc6-8761-a63a480078ba",
                "key": "0418961a-6366-4a4a-baeb-8ab42464232c",
                "udi": null,
                "values": [
                  {
                    "alias": "profilePicture",
                    "culture": null,
                    "editorAlias": null,
                    "segment": null,
                    "value": [
                      {
                        "key": "5fd2c977-afbe-48fe-be78-9ddeebb7073d",
                        "mediaKey": "b1a5ca4a-46fe-4b46-bff0-ad75f7ec6e4a",
                        "mediaTypeAlias": "Image",
                        "crops": [],
                        "focalPoint": null
                      }
                    ]
                  },
                  {
                    "alias": "mainPicture",
                    "culture": null,
                    "editorAlias": null,
                    "segment": null,
                    "value": [
                      {
                        "key": "c514fad3-3363-4995-9e40-f501e8330d6e",
                        "mediaKey": "530e30c5-421c-4680-b250-1f7bb90d2f0c",
                        "mediaTypeAlias": "Image",
                        "crops": [],
                        "focalPoint": null
                      }
                    ]
                  },
                  {
                    "alias": "characterName",
                    "culture": null,
                    "editorAlias": null,
                    "segment": null,
                    "value": "Valus Tlu\u0027urn"
                  },
                  {
                    "alias": "characterSource",
                    "culture": null,
                    "editorAlias": null,
                    "segment": null,
                    "value": "Destiny: The Taken King"
                  },
                  {
                    "alias": "details",
                    "culture": null,
                    "editorAlias": null,
                    "segment": null,
                    "value": "Valus Tlu\u0027urn was a member of the Skyburners legion and a bond-brother to Primus Ta\u0027aun and Valus Mau\u0027ual. Together these three elite warriors slew many Guardians as they battled across Mars. When Mau\u0027ual fell during their fight against a fireteam of Guardians aboard the Dreadnaught, Tlu\u0027urn picked up his brother\u0027s gear and would use it along with his own gear to fight back against the fireteam."
                  }
                ]
              },
              {
                "contentTypeKey": "6f386c25-c5f7-4cc6-8761-a63a480078ba",
                "key": "4479fd0c-3d4d-4a9d-88f6-6f12cf719f48",
                "udi": null,
                "values": [
                  {
                    "alias": "profilePicture",
                    "culture": null,
                    "editorAlias": null,
                    "segment": null,
                    "value": [
                      {
                        "key": "fd9bf992-80e6-4474-8fe0-46ef41acaff8",
                        "mediaKey": "8ed83c85-466d-439a-9072-d70055d3f034",
                        "mediaTypeAlias": "Image",
                        "crops": [],
                        "focalPoint": null
                      }
                    ]
                  },
                  {
                    "alias": "mainPicture",
                    "culture": null,
                    "editorAlias": null,
                    "segment": null,
                    "value": [
                      {
                        "key": "0a96c771-a177-422a-8e51-39ca6df16f79",
                        "mediaKey": "f76a0ea6-5a22-4bc7-881b-9d810f5cd0e0",
                        "mediaTypeAlias": "Image",
                        "crops": [],
                        "focalPoint": null
                      }
                    ]
                  },
                  {
                    "alias": "characterName",
                    "culture": null,
                    "editorAlias": null,
                    "segment": null,
                    "value": "Valus Thuun"
                  },
                  {
                    "alias": "characterSource",
                    "culture": null,
                    "editorAlias": null,
                    "segment": null,
                    "value": "Destiny 2: Curse of Osiris"
                  },
                  {
                    "alias": "details",
                    "culture": null,
                    "editorAlias": null,
                    "segment": null,
                    "value": "Valus Thuun led an expedition into the Infinite Forest on Mercury during the Red War, hoping to secure the Tree of Probabilities for the Red Legion. He and his crew would become trapped in a simulated combat loop by the Vex, forced to fight forever. A version of him from another timeline would be summoned by the Conductor to lead her new Red Legion subjects due to her knowledge of his incredible combat-skills from the simulations of the Vex. "
                  }
                ]
              },
              {
                "contentTypeKey": "6f386c25-c5f7-4cc6-8761-a63a480078ba",
                "key": "1e66ec52-c077-4e33-9b15-1d904e48cdb3",
                "udi": null,
                "values": [
                  {
                    "alias": "profilePicture",
                    "culture": null,
                    "editorAlias": null,
                    "segment": null,
                    "value": [
                      {
                        "key": "a8f6dd01-6fe1-4619-a8ac-c312da11360c",
                        "mediaKey": "4d4eae1f-b1d2-472c-aede-5b8b9aa49139",
                        "mediaTypeAlias": "Image",
                        "crops": [],
                        "focalPoint": null
                      }
                    ]
                  },
                  {
                    "alias": "mainPicture",
                    "culture": null,
                    "editorAlias": null,
                    "segment": null,
                    "value": [
                      {
                        "key": "5b43aa9e-ea8f-44ea-9192-acd5f77aa82c",
                        "mediaKey": "42fd455e-a9ab-48a6-b858-910b34b16b06",
                        "mediaTypeAlias": "Image",
                        "crops": [],
                        "focalPoint": null
                      }
                    ]
                  },
                  {
                    "alias": "characterName",
                    "culture": null,
                    "editorAlias": null,
                    "segment": null,
                    "value": "Valus Ta\u0027aurc"
                  },
                  {
                    "alias": "characterSource",
                    "culture": null,
                    "editorAlias": null,
                    "segment": null,
                    "value": "Destiny"
                  },
                  {
                    "alias": "details",
                    "culture": null,
                    "editorAlias": null,
                    "segment": null,
                    "value": "Valus Ta\u0027aurc was a member of the Dust Giants legion, and acted as the Fleet Commander for the Siege Dancers legion. He became renowned for conquering more land across Mars than any other Cabal commander, either fighting with his troops on the frontline or stationed within his Imperial Land Tank Cerberus Vae III. As one of the highest ranking Cabal in the system, he had armor like that of a tank, and was seen as indestructible by many."
                  }
                ]
              },
              {
                "contentTypeKey": "6f386c25-c5f7-4cc6-8761-a63a480078ba",
                "key": "a60d7e12-b206-40fc-b31e-6239b1bef349",
                "udi": null,
                "values": [
                  {
                    "alias": "profilePicture",
                    "culture": null,
                    "editorAlias": null,
                    "segment": null,
                    "value": [
                      {
                        "key": "b15dffb7-63b6-46d9-a290-666b1b7836b0",
                        "mediaKey": "ccf5e8cf-c3e8-457b-9046-4c865177832e",
                        "mediaTypeAlias": "Image",
                        "crops": [],
                        "focalPoint": null
                      }
                    ]
                  },
                  {
                    "alias": "mainPicture",
                    "culture": null,
                    "editorAlias": null,
                    "segment": null,
                    "value": [
                      {
                        "key": "98932d6e-2bce-47a8-8b66-74014c6296dd",
                        "mediaKey": "33d2b323-ea52-4bed-8228-230220d81737",
                        "mediaTypeAlias": "Image",
                        "crops": [],
                        "focalPoint": null
                      }
                    ]
                  },
                  {
                    "alias": "characterName",
                    "culture": null,
                    "editorAlias": null,
                    "segment": null,
                    "value": "Primus Sha\u0027aull"
                  },
                  {
                    "alias": "characterSource",
                    "culture": null,
                    "editorAlias": null,
                    "segment": null,
                    "value": "Destiny"
                  },
                  {
                    "alias": "details",
                    "culture": null,
                    "editorAlias": null,
                    "segment": null,
                    "value": "Primus Sha\u0027aull led the Blind Legion on Mars, and as a Primus he would be in direct contact with the leader of the entire Cabal Empire. He and his legion was tasked with studying the Vex on Mars, and would capture Vex artifacts and territories. "
                  }
                ]
              },
              {
                "contentTypeKey": "6f386c25-c5f7-4cc6-8761-a63a480078ba",
                "key": "d14656ed-01f3-4807-af91-06636e69aee7",
                "udi": null,
                "values": [
                  {
                    "alias": "profilePicture",
                    "culture": null,
                    "editorAlias": null,
                    "segment": null,
                    "value": [
                      {
                        "key": "dace4db5-4493-4566-a77a-b5bbf432e8ee",
                        "mediaKey": "0662eb4a-9acf-41ae-9388-ca21dcdb9867",
                        "mediaTypeAlias": "Image",
                        "crops": [],
                        "focalPoint": null
                      }
                    ]
                  },
                  {
                    "alias": "mainPicture",
                    "culture": null,
                    "editorAlias": null,
                    "segment": null,
                    "value": [
                      {
                        "key": "fdc65ce5-edff-4fc4-8e4c-25ac2bdf297f",
                        "mediaKey": "8cec25c7-7ba1-4932-8850-2b327ece8a49",
                        "mediaTypeAlias": "Image",
                        "crops": [],
                        "focalPoint": null
                      }
                    ]
                  },
                  {
                    "alias": "characterName",
                    "culture": null,
                    "editorAlias": null,
                    "segment": null,
                    "value": "Primus Ta\u0027aun"
                  },
                  {
                    "alias": "characterSource",
                    "culture": null,
                    "editorAlias": null,
                    "segment": null,
                    "value": "Destiny: The Taken King"
                  },
                  {
                    "alias": "details",
                    "culture": null,
                    "editorAlias": null,
                    "segment": null,
                    "value": "Primus Ta\u0027aun was the leader of the Skyburners legion and a bond-brother to Valus Mau\u0027ual and Valus Tlu\u0027urn. He was tasked by the leader of the Cabal Empire himself to crash a ship into the Dreadnaught of Oryx in order to use it as a beachhead for the Empire to assault the vessel. During the assault Oryx Took Ta\u0027aun, and told him that he had been the mightiest Cabal in the system."
                  }
                ]
              },
              {
                "contentTypeKey": "6f386c25-c5f7-4cc6-8761-a63a480078ba",
                "key": "948d18ed-c0ba-4f3a-8f10-b2ed0d855d04",
                "udi": null,
                "values": [
                  {
                    "alias": "profilePicture",
                    "culture": null,
                    "editorAlias": null,
                    "segment": null,
                    "value": [
                      {
