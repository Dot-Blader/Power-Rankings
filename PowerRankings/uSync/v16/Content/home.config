        {
          "alias": "characterName",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "Monster Baby"
        },
        {
          "alias": "characterSource",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "Little Nightmares 3"
        },
        {
          "alias": "details",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "Roaming an ancient city is this massive creature. It appears to be some kind of doll or baby, or a mix of both, and it behaves as immaturely as one might imagine. It recklessly breaks apart buildings as it searches for something to play with, and with its gaze can turn residents and visitors alike into stone. Where this being came from, and what it\u0027s doing in the Necropolis is unclear, but the effects of its presence are obvious. The entire city has been turned into a tomb, with pretty much every single resident having been turned to stone, or crushed to death."
        },
        {
          "alias": "mainPicture",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": [
            {
              "key": "4a32c33c-40fe-4ebf-81c3-291dbd91d555",
              "mediaKey": "30351c28-196b-4694-ae15-94ede2da9713",
              "mediaTypeAlias": "Image",
              "crops": [],
              "focalPoint": null
            }
          ]
        },
        {
          "alias": "characterTitle",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "Lost Dolly"
        }
      ]
    },
    {
      "contentTypeKey": "6f386c25-c5f7-4cc6-8761-a63a480078ba",
      "key": "4df48978-08cf-4a2f-b3b5-80780d1df019",
