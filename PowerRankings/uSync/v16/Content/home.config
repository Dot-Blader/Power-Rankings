                            {
                              "alias": "characterName",
                              "culture": null,
                              "editorAlias": null,
                              "segment": null,
                              "value": "Gulrot, Unclean"
                            },
                            {
                              "alias": "details",
                              "culture": null,
                              "editorAlias": null,
                              "segment": null,
                              "value": "Gulrot was an Ogre Summoned by the Worm Keepers in the Prison of Elders. They were a group of Wizards who sought a leader for the Cult of the Worm. Gulrot\u0027s ritual succeeded, but due to the hap-hazard nature of conducting such a ritual in the Prison of Elders, Gulrot would come out vile and warped by it."
                            }
                          ]
                        },
                        {
                          "contentTypeKey": "6f386c25-c5f7-4cc6-8761-a63a480078ba",
