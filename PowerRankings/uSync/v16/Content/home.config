        {
          "alias": "details",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "Vendraxis was a Taken servant of Oryx who survived the Taken War and hid in the EDZ. He commanded a group of Taken from within the Hallowed Grove, and wielded some control over Blights."
        }
      ]
    },
    {
      "contentTypeKey": "6f386c25-c5f7-4cc6-8761-a63a480078ba",
