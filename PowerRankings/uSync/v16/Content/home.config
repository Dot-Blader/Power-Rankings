          "alias": "characterName",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "Egg Flapper"
        },
        {
          "alias": "characterSource",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "Sonic Heroes"
        },
        {
          "alias": "details",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "Egg Flappers were an airborne variant of the Egg Pawn. They were often armed with guns that allowed them to strike at Sonic and his friends from above, and had the same durability as regular Egg Pawns."
        }
      ]
    },
    {
      "contentTypeKey": "6f386c25-c5f7-4cc6-8761-a63a480078ba",
      "key": "fe577785-d174-4f2b-a90d-a25c3150a0ff",
