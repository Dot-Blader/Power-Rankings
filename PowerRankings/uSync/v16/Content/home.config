                    "culture": null,
                    "editorAlias": null,
                    "segment": null,
                    "value": [
                      {
                        "key": "cab27b14-e9d9-436b-a928-25793b412558",
                        "mediaKey": "5a42ffef-02bb-4285-9a47-6a0ecfb3b7ce",
                        "mediaTypeAlias": "Image",
                        "crops": [],
                        "focalPoint": null
                      }
                    ]
                  },
                  {
                    "alias": "characterSource",
                    "culture": null,
                    "editorAlias": null,
                    "segment": null,
                    "value": "Destiny 2: Shadowkeep"
                  },
                  {
                    "alias": "details",
                    "culture": null,
                    "editorAlias": null,
                    "segment": null,
                    "value": "Zeteon was a Minotaur summoned to protect the Black Garden gate on Luna. It was presumably a Gate Lord. After summoning and defeating this Minotaur a fireteam of Guardians were able to successfully breach the Black Garden and bypass its defenses in order to uncover the truth about a previous fireteam that went missing in the Garden."
                  }
                ]
              },
              {
                "contentTypeKey": "6f386c25-c5f7-4cc6-8761-a63a480078ba",
                "key": "9783243e-2341-4cb9-be6e-77bdd3cd6a41",
