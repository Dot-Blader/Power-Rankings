        {
          "alias": "details",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "Eshkin\u0027tuk was a Taken Knight blessed with power by the Witness and sent to hinder the Young Wolf on their journey to destroy the Witness. He commanded a group of Ascendant Darkblades and conjured a large Blight to block the way for the Guardian as he and his troops assaulted them. After being defeated his essence was returned to the Ascendant Plane like all Taken."
        },
        {
          "alias": "characterVariant",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "Pale Heart"
        }
      ]
    },
