        },
        {
          "alias": "characterName",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "Ascendant Hive"
        },
        {
          "alias": "profilePicture",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": ""
        },
        {
          "alias": "characterSource",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "Destiny"
        },
        {
          "alias": "details",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "After attaining sufficient power with the Darkness a Hive will become Ascendant. At this level they can cut their way into the Ascendant Plane, where they will have access to a Throne World of their own making. Ascendant Hive are placed in charge of Hive Broods, overseeing their tasks and making sure the Hive keeps growing stronger."
        },
        {
          "alias": "characterVariant",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "Ascendant Plane"
        },
        {
          "alias": "groupMembers",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": {
            "contentData": [
              {
                "contentTypeKey": "6f386c25-c5f7-4cc6-8761-a63a480078ba",
                "key": "fd7b654d-c5bd-406a-981a-0256d10e0c95",
                "udi": null,
