        },
        {
          "alias": "characterName",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "Arcadia Class Jumpship"
        },
        {
          "alias": "characterSource",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "Destiny"
        },
        {
          "alias": "details",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "Developed during humanity\u0027s Golden Age, various models of Jumpships would allow people to travel efficiently between different planets and moons. The Guardians of the Last City would restore and utilize old Jumpships after the Collapse, and the Young Wolf would find themselves with an old Arcadia Class Jumpship that they found rusting away in the Cosmodrome. These ships had both weapons and armor strong enough to rival those of the enemies of the Last City."
        },
        {
          "alias": "mainPicture",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": [
            {
              "key": "11b5daea-9cc6-4aec-8dc1-bff79e5f870f",
              "mediaKey": "e8a86021-0cb0-4244-bb9d-bf6ba83e8c51",
              "mediaTypeAlias": "Image",
              "crops": [],
              "focalPoint": null
            }
          ]
        }
      ]
    },
    {
      "contentTypeKey": "6f386c25-c5f7-4cc6-8761-a63a480078ba",
      "key": "41ac6cf8-66a2-46ef-a8b3-61ca49a7f38d",
      "udi": null,
      "values": [
