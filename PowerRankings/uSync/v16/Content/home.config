        },
        {
          "alias": "energyExponent",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "30"
        },
        {
          "alias": "characterName",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "Vorgeth, the Boundless Hunger"
        },
        {
          "alias": "characterSource",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "Destiny 2: Forsaken"
        },
        {
          "alias": "details",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "Vorgeth was a Taken Ogre serving the Fatesmiths of D\u00FBl Incaru. He recieved tithes from a band of Taken Wizards who assisted him in his task to hold the petitions of D\u00FBl Incaru\u0027s brood and help her find the Distributary. His servants were as strong as four Darkblades combined, and tithed their power to him. Due to Riven\u0027s curse on the Dreaming City, Vorgeth returns to life every three weeks."
        },
        {
          "alias": "characterVariant",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "Material Space"
        },
        {
          "alias": "characterTitle",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "Keeper of Petitions"
        }
      ]
    },
    {
      "contentTypeKey": "6f386c25-c5f7-4cc6-8761-a63a480078ba",
      "key": "b9fe630b-13a1-47b2-a8f8-aa61f79c7506",
      "udi": null,
      "values": [
        {
          "alias": "energyMultiplicator",
          "culture": null,
