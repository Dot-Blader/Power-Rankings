                              "segment": null,
                              "value": "Destiny: The Taken King"
                            },
                            {
                              "alias": "characterName",
                              "culture": null,
                              "editorAlias": null,
                              "segment": null,
                              "value": "Kovik\u0027s Monster"
                            },
                            {
                              "alias": "characterVariant",
                              "culture": null,
                              "editorAlias": null,
                              "segment": null,
                              "value": "Material Space"
                            },
                            {
                              "alias": "details",
                              "culture": null,
                              "editorAlias": null,
                              "segment": null,
                              "value": "The Silent Brood was the brood assigned to watch over the prisons aboard Oryx\u0027s Dreadnaught. Its leader was a Summoned Ogre who was taken by Kovik, Splicer Priest. Kovik held the Ogre captive using SIVA, and managed to remove its eye in order to enhance his own weapon. This also turned the Ogre into one of his pawns, which would engage enemies directly with its fists."
                            }
                          ]
                        },
                        {
                          "contentTypeKey": "6f386c25-c5f7-4cc6-8761-a63a480078ba",
