                  },
                  {
                    "alias": "characterName",
                    "culture": null,
                    "editorAlias": null,
                    "segment": null,
                    "value": "Phyksin, King Baron"
                  },
                  {
                    "alias": "mainPicture",
                    "culture": null,
                    "editorAlias": null,
                    "segment": null,
                    "value": [
                      {
                        "key": "e493b139-5276-4a40-b29c-05c275eb8736",
                        "mediaKey": "98231e4f-7fe4-4023-897f-8d15d5e44bce",
                        "mediaTypeAlias": "Image",
                        "crops": [],
                        "focalPoint": null
                      }
                    ]
                  },
                  {
                    "alias": "characterSource",
                    "culture": null,
                    "editorAlias": null,
                    "segment": null,
                    "value": "Destiny: The Dark Below"
                  },
                  {
                    "alias": "details",
                    "culture": null,
                    "editorAlias": null,
                    "segment": null,
                    "value": "Phyksin lead the forces of Fallen stationed in the Terrestrial Complex in the Cosmodrome. He was lured into the open when Omnigul, Will of Crota, stirred his forces into action in order to get in the way of incoming Guardians. Phyksin would realize Omnigul\u0027s trickery too late, and would be forced to face the Guardian one on one."
                  }
                ]
              },
              {
                "contentTypeKey": "6f386c25-c5f7-4cc6-8761-a63a480078ba",
                "key": "2b4b8289-f2a2-4c96-b881-ec971799dc8c",
                "udi": null,
                "values": [
                  {
                    "alias": "profilePicture",
                    "culture": null,
                    "editorAlias": null,
                    "segment": null,
                    "value": [
                      {
