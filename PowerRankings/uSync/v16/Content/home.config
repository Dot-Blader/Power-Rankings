        {
          "alias": "characterName",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "Death Egg Robot"
        },
        {
          "alias": "characterSource",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "Sonic the Hedgehog 2"
        },
        {
          "alias": "details",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "The Death Egg Robot was a large mech built by Eggman to act as a final line of defense inside the Death Egg incase of an attack. It was designed to look like a robotic version of Eggman, and was piloted by the Doctor himself. It was stronger than any other robot made by the Doctor at the time, requiring twelve strikes from sonic to bring down. Its destruction would damage the core of the Death Egg, which would fall from orbit and crash as a result."
        },
        {
          "alias": "mainPicture",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": [
            {
              "key": "97ccdb9d-79c0-4e79-b925-4ecb999c5ef9",
              "mediaKey": "5ca88e43-f876-495e-9c3f-fc6ab97e9017",
              "mediaTypeAlias": "Image",
              "crops": [],
              "focalPoint": null
            }
          ]
        }
      ]
    },
