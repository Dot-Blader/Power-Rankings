                              "segment": null,
                              "value": [
                                {
                                  "key": "20929495-cb63-48e0-8ace-9cbeb8cb2644",
                                  "mediaKey": "ce0fe40d-c0d8-4bd2-99f1-ad628a3d7d8a",
                                  "mediaTypeAlias": "Image",
                                  "crops": [],
                                  "focalPoint": null
                                }
                              ]
                            },
                            {
                              "alias": "details",
                              "culture": null,
                              "editorAlias": null,
                              "segment": null,
                              "value": "Ta\u0027aun fought alongside Baxx against the Young Wolf within the Oversoul Throne, trying to kill the Guardian before they could escape with Crota\u0027s essence. They nearly succeeded before Eris Morn teleported the Guardian out."
                            }
                          ]
                        },
                        {
                          "contentTypeKey": "6f386c25-c5f7-4cc6-8761-a63a480078ba",
