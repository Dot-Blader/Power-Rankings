        {
          "alias": "characterName",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "Egg Pawn"
        },
        {
          "alias": "characterSource",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "Sonic Heroes"
        },
        {
          "alias": "details",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "Egg Pawns would take the role of the main infantry of Doctor Eggman\u0027s military. They were built in semblance of the Doctor\u0027s appearance, and were more resilient than typical Badniks, requiring three strikes from Sonic to bring down at the time."
        }
      ]
    },
    {
      "contentTypeKey": "6f386c25-c5f7-4cc6-8761-a63a480078ba",
