            }
          ]
        },
        {
          "alias": "characterName",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "Anti-Air Weapons"
        },
        {
          "alias": "characterSource",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "Destiny"
        },
        {
          "alias": "details",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "In order to deal serious damage to the armored hulls of aircraft and other vehicles, strong weapons are employed. These weapons have enough firepower to breach heavy armor within just one or a handful of shots in most cases, and are usually light enough to be able to keep up with aiming at moving targets."
        },
        {
          "alias": "energyExponent",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "10"
        },
        {
          "alias": "groupMembers",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": {
            "contentData": [
              {
                "contentTypeKey": "6f386c25-c5f7-4cc6-8761-a63a480078ba",
                "key": "436f0743-5740-4593-9423-334ebe2761f8",
                "udi": null,
                "values": [
                  {
                    "alias": "profilePicture",
                    "culture": null,
                    "editorAlias": null,
                    "segment": null,
                    "value": [
                      {
                        "key": "8c720944-c5c9-4a61-8273-6c68be207049",
                        "mediaKey": "8a6af035-5408-4187-88bc-e6968d646d8c",
                        "mediaTypeAlias": "Image",
                        "crops": [],
                        "focalPoint": null
                      }
                    ]
                  },
                  {
                    "alias": "characterName",
                    "culture": null,
                    "editorAlias": null,
                    "segment": null,
                    "value": "Walker Main Cannon"
                  },
                  {
                    "alias": "characterSource",
                    "culture": null,
                    "editorAlias": null,
                    "segment": null,
                    "value": "Destiny"
                  },
                  {
                    "alias": "mainPicture",
                    "culture": null,
                    "editorAlias": null,
                    "segment": null,
                    "value": [
                      {
                        "key": "0e242e9f-68e7-454f-a6ae-2c748df64e01",
                        "mediaKey": "bce1af83-ae90-4c9c-b95b-3535cb82e1e9",
                        "mediaTypeAlias": "Image",
                        "crops": [],
                        "focalPoint": null
                      }
                    ]
                  },
                  {
                    "alias": "details",
                    "culture": null,
                    "editorAlias": null,
                    "segment": null,
                    "value": "Atop Fallen Walkers sits an anti-air cannon that uses a laser-supported targeting system as it takes on large threats. If smaller targets arrive who prove to be capable enough to survive the Fallen\u0027s lesser troops, such as a Guardian, Walkers will often aim their cannons at them instead. Aside the main cannon sits an Arc-powered repeating cannon that fires high-energy bolts of Arc, and these cannons are also found on Skiffs and Ketches. Due to the larger bodies of these airborne vehicles, and by extension the larger Shock Cores within, the cannons fire bolts comparable in power to the Walker\u0027s main cannon in those instances."
                  }
                ]
              },
              {
                "contentTypeKey": "6f386c25-c5f7-4cc6-8761-a63a480078ba",
                "key": "1097ea75-c194-4f05-aa5f-e6e3851f84b1",
                "udi": null,
                "values": [
                  {
                    "alias": "profilePicture",
                    "culture": null,
                    "editorAlias": null,
                    "segment": null,
                    "value": [
                      {
                        "key": "686d07f9-42ec-43a3-903b-3579314e76d5",
                        "mediaKey": "e97d0979-d8bb-46cd-a36f-7b4e87106585",
                        "mediaTypeAlias": "Image",
                        "crops": [],
                        "focalPoint": null
                      }
                    ]
                  },
                  {
                    "alias": "characterName",
                    "culture": null,
                    "editorAlias": null,
                    "segment": null,
                    "value": "Goliath Main Cannon"
                  },
                  {
                    "alias": "characterSource",
                    "culture": null,
                    "editorAlias": null,
                    "segment": null,
                    "value": "Destiny"
                  },
                  {
                    "alias": "mainPicture",
                    "culture": null,
                    "editorAlias": null,
                    "segment": null,
                    "value": [
                      {
                        "key": "b7c2397c-0fef-4c26-87fa-480ad09960cf",
                        "mediaKey": "b872d427-b550-477c-ae40-402c3dc6adbc",
                        "mediaTypeAlias": "Image",
                        "crops": [],
                        "focalPoint": null
                      }
                    ]
                  },
                  {
                    "alias": "details",
                    "culture": null,
                    "editorAlias": null,
                    "segment": null,
                    "value": "Goliath Tanks are armed with a large cannon that charges up a Solar-energy missile which targets enemies with an automatic homing-system. These missiles are loaded with an explosive strong enough to take on aircraft, and also other tanks and dangerous ground-troops. The Cabal utilize these to obliterate enemy bunkers and outpost with minimal effort."
                  }
                ]
              },
              {
                "contentTypeKey": "6f386c25-c5f7-4cc6-8761-a63a480078ba",
                "key": "cf2fc396-dbc4-4b81-abf7-72e2b31a0ca1",
                "udi": null,
                "values": [
                  {
                    "alias": "profilePicture",
                    "culture": null,
