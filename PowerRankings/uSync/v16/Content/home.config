          "segment": null,
          "value": "WYVERN"
        },
        {
          "alias": "characterSource",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "Sonic Frontiers"
        },
        {
          "alias": "details",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "WYVERN was the Titan that roamed the skies above Ares Island after THE END\u0027s assault on the Ancients. It was armed with various weapons enhanced by the power of the Chaos Emeralds which made it a tough fight even for Super Sonic. "
        }
      ]
    },
