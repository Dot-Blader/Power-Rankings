                        "crops": [],
                        "focalPoint": null
                      }
                    ]
                  },
                  {
                    "alias": "mainPicture",
                    "culture": null,
                    "editorAlias": null,
                    "segment": null,
                    "value": [
                      {
                        "key": "a4b6c85e-b292-4583-a8ff-004598ea833b",
                        "mediaKey": "afcb0ec0-23df-4a57-a9df-bbbf3d27ecc4",
                        "mediaTypeAlias": "Image",
                        "crops": [],
                        "focalPoint": null
                      }
                    ]
                  },
                  {
                    "alias": "characterName",
                    "culture": null,
                    "editorAlias": null,
                    "segment": null,
                    "value": "Paskin, King Baron"
                  },
                  {
                    "alias": "characterSource",
                    "culture": null,
                    "editorAlias": null,
                    "segment": null,
                    "value": "Destiny: House of Wolves"
                  },
                  {
                    "alias": "details",
                    "culture": null,
                    "editorAlias": null,
                    "segment": null,
                    "value": "Paskin wielded a ranged weapon whilst negotiating with the House of Wolves alongside Vekis. They were ready to have each other\u0027s backs if the negotiations had turned violent, but would instead use them against a Guardian of the Last City who interfered. "
                  }
                ]
              },
              {
                "contentTypeKey": "6f386c25-c5f7-4cc6-8761-a63a480078ba",
                "key": "d3730b21-1d09-402d-80e3-9288c508dd6b",
                "udi": null,
                "values": [
                  {
                    "alias": "profilePicture",
                    "culture": null,
