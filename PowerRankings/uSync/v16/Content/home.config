            }
          ]
        },
        {
          "alias": "characterName",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "Time Eater"
        },
        {
          "alias": "characterSource",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "Sonic Generations"
        },
        {
          "alias": "details",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "The Time Eater was a primordial being that transcended time and space. It was discovered by Dr. Eggman, and he used its time-manipulative abilities to capture Sonic and his friends in a space between spaces. Along with people, Eggman would also capture significant locations from Sonic\u0027s past, which included locations from the timelines that were erased when Solaris was defeated. This showed the true power of the Time Eater, accessing a timeline that existed above the one of Solaris entirely. The Time Eater was only able to be defeated by two Super Sonics from the present and past combining their power."
        }
      ]
    },
    {
      "contentTypeKey": "6f386c25-c5f7-4cc6-8761-a63a480078ba",
      "key": "e3ebb48b-dcea-4660-aa0f-da516fb255de",
      "udi": null,
      "values": [
        {
          "alias": "energyMultiplicator",
          "culture": null,
