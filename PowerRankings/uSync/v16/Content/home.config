        {
          "alias": "characterSource",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "Destiny 2: Season of the Seraph"
        },
        {
          "alias": "details",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "Ir Hanal was an ancient Hive Wizard who was renowned for her accomplishments during the Ecumene wars. She was a servant of Xivu Arath, and would assault a Seraph Bunker alongside Ir Nithra, where they would battle against a Guardian together."
