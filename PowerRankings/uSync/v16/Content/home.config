                            },
                            {
                              "alias": "details",
                              "culture": null,
                              "editorAlias": null,
                              "segment": null,
                              "value": "Yamaat was an Ascendant Taken Knight stationed alongside Om Alir and Teksis. He used an Ascendant Blight just like his fellow Sentinels to bar the way for intruders, but before their assignment within the monastery Yamaat could be seen leading the Taken forces of Quria throughout the Dreaming City."
                            }
                          ]
                        }
                      ],
