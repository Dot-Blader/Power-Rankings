                    "value": [
                      {
                        "key": "94eb2d66-2096-4901-acf7-8c0fb090cb25",
                        "mediaKey": "936805fe-b28a-4100-bea5-d973d995c9ad",
                        "mediaTypeAlias": "Image",
                        "crops": [],
                        "focalPoint": null
                      }
                    ]
                  },
                  {
                    "alias": "characterSource",
                    "culture": null,
                    "editorAlias": null,
                    "segment": null,
                    "value": "Destiny: House of Wolves"
                  },
                  {
                    "alias": "characterName",
                    "culture": null,
                    "editorAlias": null,
                    "segment": null,
                    "value": "Yavek, Wolf Baron"
                  },
                  {
                    "alias": "details",
                    "culture": null,
                    "editorAlias": null,
                    "segment": null,
                    "value": "Yavek lead negotiations between the House of Wolves and the House of Kings during Skolas\u0027s attempt to unite the different Houses under his Wolf banner. He showed the King Barons Skolas\u0027s plans for an invasion of the Last City, hoping to persuade them into telling Craask to join his House with the Kell of Kells."
                  }
                ]
              },
              {
                "contentTypeKey": "6f386c25-c5f7-4cc6-8761-a63a480078ba",
                "key": "87fd921c-eec4-453c-9a40-f6af44da1b41",
                "udi": null,
                "values": [
                  {
                    "alias": "profilePicture",
                    "culture": null,
                    "editorAlias": null,
                    "segment": null,
                    "value": [
                      {
                        "key": "8c529f7b-bbd5-4543-8953-153dc09511ee",
                        "mediaKey": "5f7b9ec3-5198-4d80-aa41-f176ba069d96",
