        {
          "alias": "profilePicture",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": [
            {
              "key": "232fc09f-407c-4f5d-b60c-37959759e910",
              "mediaKey": "c097fea1-2d17-40d4-9dae-541ad27c0ba1",
