          "segment": null,
          "value": "Toniq, Imprint of Nezarec"
        },
        {
          "alias": "characterSource",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "Destiny 2: Lightfall"
        },
        {
          "alias": "profilePicture",
          "culture": null,
