          "segment": null,
          "value": "10"
        },
        {
          "alias": "characterSource",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "Destiny 2: Beyond Light"
        },
        {
          "alias": "characterName",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "Clovis Bray AI"
        },
        {
          "alias": "details",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "Clovis Bray I created a massive Exo head to house an AI version of himself for when he died. This AI was made to be in control of all BrayTech facilities on Europa, and was given Clovis\u0027s memories and personality, making it essentially Clovis himself reborn. The thickness of the Exo\u0027s plating is greater than ordinary Exos, and it is built out of the same material as Vex units, however it is unknown if there were ever plans for an equally massive and strong body to be made for it."
        },
        {
          "alias": "profilePicture",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": [
            {
              "key": "666b9e07-f1cb-410b-95f5-39aba59704ec",
