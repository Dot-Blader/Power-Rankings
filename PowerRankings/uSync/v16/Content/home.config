                  },
                  {
                    "alias": "characterName",
                    "culture": null,
                    "editorAlias": null,
                    "segment": null,
                    "value": "Banuk, Ur Prince"
                  },
                  {
                    "alias": "characterVariant",
                    "culture": null,
                    "editorAlias": null,
                    "segment": null,
                    "value": "Material Space"
                  },
                  {
                    "alias": "characterSource",
                    "culture": null,
                    "editorAlias": null,
                    "segment": null,
                    "value": "Destiny"
                  },
                  {
                    "alias": "details",
                    "culture": null,
                    "editorAlias": null,
                    "segment": null,
                    "value": "Banuk was the Hive Knight representing the Worm God Ur, the Ever-Hunger. He would lead the Hidden Swarm alongside the other Princes of the Swarm, but unlike his brethren he preferred a ranged Boomer over a close-ranged Cleaver for combat."
                  },
                  {
                    "alias": "mainPicture",
                    "culture": null,
