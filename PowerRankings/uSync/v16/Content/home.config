                    "segment": null,
                    "value": "Ascendant Sentinels"
                  },
                  {
                    "alias": "characterVariant",
                    "culture": null,
                    "editorAlias": null,
                    "segment": null,
                    "value": "Ascendant Plane"
                  },
                  {
                    "alias": "details",
                    "culture": null,
                    "editorAlias": null,
                    "segment": null,
                    "value": "Three Ascendant Taken were assigned to serve D\u00FBl Incaru by working under Val Belyx. After being defeated in material space, they would be returned to the Ascendant Plane, where they would serve D\u00FBl Incaru directly."
                  },
