                    "culture": null,
                    "editorAlias": null,
                    "segment": null,
                    "value": "Crotheon, Gate Keeper"
                  },
                  {
                    "alias": "characterTitle",
                    "culture": null,
                    "editorAlias": null,
                    "segment": null,
                    "value": "Gate Lord"
                  },
                  {
                    "alias": "characterSource",
                    "culture": null,
                    "editorAlias": null,
                    "segment": null,
                    "value": "Destiny 2: Season of the Undying"
                  },
                  {
                    "alias": "details",
                    "culture": null,
                    "editorAlias": null,
                    "segment": null,
                    "value": "Crotheon was presumably a Gate Lord as it was summoned to protect a gate inside the Black Garden during the Vex\u0027s offensives against the moon of Earth. It was destroyed by a fireteam of Guardians seeking to halt the Vex invasion."
                  }
                ]
              },
              {
                "contentTypeKey": "6f386c25-c5f7-4cc6-8761-a63a480078ba",
                "key": "ba552782-de9e-478b-ba3c-6737072a97e8",
