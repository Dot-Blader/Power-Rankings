                  },
                  {
                    "alias": "characterName",
                    "culture": null,
                    "editorAlias": null,
                    "segment": null,
                    "value": "Ubara, Hive Prince"
                  },
                  {
                    "alias": "details",
                    "culture": null,
                    "editorAlias": null,
                    "segment": null,
                    "value": "Ubara was the Ascendant Knight assigned by Savath\u00FBn to lead the brood of Hive she sent to Titan during the Red War. He was able to cause multiple Lightless Guardians to die as they sought refuge on the moon, not knowing about the Hive presence there."
                  },
