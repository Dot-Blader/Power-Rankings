        {
          "alias": "characterName",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "Thrall"
        },
        {
          "alias": "characterSource",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "Destiny"
        },
        {
          "alias": "details",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "When a newborn Krill ritualistically ingests a worm larva they become a Hive Thrall. Thrall are feral and fight aggressively to feed their worm, lest it consumes them. They tithe some of their killing to the Acolyte they serve."
        },
        {
          "alias": "mainPicture",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": [
