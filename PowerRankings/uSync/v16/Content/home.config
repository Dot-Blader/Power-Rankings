                        "focalPoint": null
                      }
                    ]
                  },
                  {
                    "alias": "characterName",
                    "culture": null,
                    "editorAlias": null,
                    "segment": null,
                    "value": "Mortar Blast"
                  },
                  {
                    "alias": "characterSource",
                    "culture": null,
                    "editorAlias": null,
                    "segment": null,
                    "value": "Destiny: The Taken King"
                  },
                  {
                    "alias": "details",
                    "culture": null,
                    "editorAlias": null,
                    "segment": null,
                    "value": "Valus Tlu\u0027urn wielded a massive cannon on his back. This gun fired bolts of Arc-energy that the weapon generated on its own, allowing Tlu\u0027urn to besiege enemy positions for extended periods of time. It was strong enough that it would allow Tlu\u0027urn to take on a Goliath Tank single-handedly."
                  }
                ]
              }
            ],
