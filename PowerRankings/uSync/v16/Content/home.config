          "value": "Temporal"
        },
        {
          "alias": "profilePicture",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": [
            {
              "key": "119b1b2d-f193-4da0-b801-f9ff070a757f",
              "mediaKey": "61f98237-a875-4cc4-b839-f1333c169e39",
