                            {
                              "alias": "details",
                              "culture": null,
                              "editorAlias": null,
                              "segment": null,
                              "value": "As masters of stealth, the Eyes of Crota would rarely be seen by their enemies. When they were, however, they would spring into action, swiftly taking out the threats with Boomers and a personal army of Knights and Thrall. "
                            },
