                  },
                  {
                    "alias": "characterName",
                    "culture": null,
                    "editorAlias": null,
                    "segment": null,
                    "value": "Vorgeth, the Boundless Hunger"
                  },
                  {
                    "alias": "characterVariant",
                    "culture": null,
                    "editorAlias": null,
                    "segment": null,
                    "value": "Ascendant Plane"
                  },
                  {
                    "alias": "characterSource",
                    "culture": null,
                    "editorAlias": null,
                    "segment": null,
                    "value": "Destiny 2: Forsaken"
                  },
                  {
                    "alias": "details",
                    "culture": null,
                    "editorAlias": null,
                    "segment": null,
                    "value": "Vorgeth serves the Fatesmiths of D\u00FBl Incaru by leading the Keepers of Petitions, a group of Taken Wizards. Together they work to assist D\u00FBl Incaru with finding the Distributary through the shattered Throne World Eleusinia, and they return every three weeks even after death due to Quria\u0027s ongoing time loop of the Dreaming City."
                  },
                  {
                    "alias": "energyMultiplicator",
                    "culture": null,
                    "editorAlias": null,
                    "segment": null,
