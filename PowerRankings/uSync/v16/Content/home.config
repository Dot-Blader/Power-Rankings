        },
        {
          "alias": "characterName",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "The Doctor"
        },
        {
          "alias": "characterSource",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "Little Nightmares 2"
        },
        {
          "alias": "details",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "The Doctor ran a hospital in the Pale City. He \u0022improved\u0022 his patients by replacing their limbs with mannequin parts, and using their skin he made facemasks that patients could wear to hide the ugliness they didn\u0027t like seeing in the mirror. He had an uncanny ability to crawl on ceilings, no doubt thanks to the warping influence of the Transmission. He was strong enough to lift entire beds up in the air whilst trying to catch runaway children who stumbled into his horrific hospital."
        },
        {
          "alias": "mainPicture",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": [
            {
              "key": "ed97c549-6988-42b3-b34a-95755681de00",
