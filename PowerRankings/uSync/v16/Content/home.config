        },
        {
          "alias": "details",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "Before undergoing a Summoning Ritual an Ogre is considered Unborn. In order to receive the ritual the Ogres need to prove themselves worthy through some type of test."
        },
        {
          "alias": "characterSource",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "Destiny"
        },
        {
          "alias": "groupMembers",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": {
            "contentData": [
              {
                "contentTypeKey": "6f386c25-c5f7-4cc6-8761-a63a480078ba",
