                    "value": "Destiny 2: Shadowkeep"
                  },
                  {
                    "alias": "details",
                    "culture": null,
                    "editorAlias": null,
                    "segment": null,
                    "value": "After her defeat in material space, Hashlad\u00FBn would have been returned to her Throne World. Her ultimate fate remains unknown however."
                  }
                ]
              },
              {
                "contentTypeKey": "6f386c25-c5f7-4cc6-8761-a63a480078ba",
