              "focalPoint": null
            }
          ]
        },
        {
          "alias": "characterName",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "Sonic the Hedgehog"
        },
        {
          "alias": "characterSource",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "Sonic the Hedgehog"
        },
        {
          "alias": "details",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "Sonic is a blue hedgehog who runs at the speed of sound. When Doctor Eggman attempts to take over the world Sonic takes on his army of robots and stops him, using his incredible speed and power in the process. Sonic can shatter rocks and marble pillars with a single strike, giving him a serious advantage against the lightly armored Badniks of Eggman\u0027s army."
        },
        {
          "alias": "mainPicture",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": [
