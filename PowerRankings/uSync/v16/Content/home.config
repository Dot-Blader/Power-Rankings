                  },
                  {
                    "alias": "characterName",
                    "culture": null,
                    "editorAlias": null,
                    "segment": null,
                    "value": "Lokaar"
                  },
                  {
                    "alias": "characterVariant",
                    "culture": null,
                    "editorAlias": null,
                    "segment": null,
                    "value": "Material Space"
                  },
                  {
                    "alias": "details",
                    "culture": null,
                    "editorAlias": null,
                    "segment": null,
                    "value": "Lokaar was an unnamed Hive Wizard who attempted to assassinate Omnigul, Will of Crota. In response, Crota would attempt to kill Lokaar, but he failed to catch her. He would then demand that his father Oryx would kill the Wizard, but instead Oryx elevated her to his Court and named her \u0022Lokaar\u0022, meaning \u0022Not There\u0022 in the Hive\u0027s language to spite Crota."
                  },
                  {
                    "alias": "mainPicture",
