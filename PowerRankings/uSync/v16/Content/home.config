                            {
                              "alias": "details",
                              "culture": null,
                              "editorAlias": null,
                              "segment": null,
                              "value": "Gornith served alongside the other Planeshifting Taken aboard the Dreadnaught. After being defeated at the hands of a Guardian, Gornith and the others returned from the Ascendant Plane to seek revenge on their killer who dared to challenge them again."
                            }
                          ]
                        },
