        {
          "alias": "characterName",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "Kridis, Dark Priestess"
        },
        {
          "alias": "characterSource",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "Destiny 2: Beyond Light"
        },
        {
          "alias": "details",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "Kridis was the Archon of House of Salvation. She was meant to serve Yamiks Prime and assist it with mechanical aid, but spent most of her time studying the Darkness. She dual-wielded two Pyramid Splinters, which granted her immense power with Stasis. She would conjure two lances of Stasis and wield them as swords in battle."
        },
        {
          "alias": "characterTitle",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "Archon Priest"
        }
      ]
    },
