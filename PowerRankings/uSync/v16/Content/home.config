                  },
                  {
                    "alias": "characterName",
                    "culture": null,
                    "editorAlias": null,
                    "segment": null,
                    "value": "Phydron, Gate Lord"
                  },
                  {
                    "alias": "characterSource",
                    "culture": null,
                    "editorAlias": null,
                    "segment": null,
                    "value": "Destiny 2: The Edge of Fate"
                  },
                  {
                    "alias": "details",
                    "culture": null,
                    "editorAlias": null,
                    "segment": null,
                    "value": "Phydron was a Prescursor Gate Lord tasked by the Conductor to protect a Strangelet Capsule alongside a Vex gate on Kepler. It was summoned by a Guardian who sought to obtain the capsule, and would engage them in a battle immediately. "
                  }
                ]
              },
              {
                "contentTypeKey": "6f386c25-c5f7-4cc6-8761-a63a480078ba",
                "key": "1e618ff7-b797-4bff-b792-f022aa05cad9",
                "udi": null,
                "values": [
                  {
                    "alias": "characterName",
                    "culture": null,
                    "editorAlias": null,
                    "segment": null,
                    "value": "Zeteon, Redemptive Mind"
                  },
                  {
                    "alias": "characterTitle",
                    "culture": null,
                    "editorAlias": null,
                    "segment": null,
                    "value": "Gate Lord"
                  },
                  {
                    "alias": "profilePicture",
                    "culture": null,
                    "editorAlias": null,
                    "segment": null,
                    "value": [
                      {
                        "key": "64defdc8-ae8c-485c-b069-2883c83b50cd",
