        {
          "alias": "characterSource",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "Sonic Heroes"
        },
        {
          "alias": "details",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "The Egg Albatross was a massive barge built by Eggman to transport and protect weapons around his base. It had a weaker version of the Egg Hawk placed on its top to allow Eggman to defend the barge personally if it was attacked. It was used by Metal Sonic to distract Sonic and his friends as he secretly launched the Egg Fleet in preparation to conquer the world. To bring down the entire barge and the weaker Egg Hawk on top it would require one hundred and fifty attacks from Sonic."
        }
      ]
    },
