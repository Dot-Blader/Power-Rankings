                        "focalPoint": null
                      }
                    ]
                  },
                  {
                    "alias": "mainPicture",
                    "culture": null,
                    "editorAlias": null,
                    "segment": null,
                    "value": [
                      {
                        "key": "557e25bc-fb30-4610-9423-a405794dae81",
                        "mediaKey": "fd923164-c82a-47aa-a232-6a258dee67b8",
                        "mediaTypeAlias": "Image",
                        "crops": [],
                        "focalPoint": null
                      }
                    ]
                  },
                  {
                    "alias": "characterSource",
                    "culture": null,
                    "editorAlias": null,
                    "segment": null,
                    "value": "Destiny 2: Lightfall"
                  },
                  {
                    "alias": "characterName",
                    "culture": null,
                    "editorAlias": null,
                    "segment": null,
                    "value": "Valus Dravusk"
                  },
                  {
                    "alias": "details",
                    "culture": null,
                    "editorAlias": null,
                    "segment": null,
                    "value": "Dravusk was a Valus of the Shadow Legion deployed to sabotage the food-creation of the Neomuni. Such a high-ranking member of the legion was deemed necessary to oversee this operation, as a success there could single-handedly end the war with a Cabal victory as the citizens of Neomuna would starve to death. "
                  }
                ]
              },
              {
                "contentTypeKey": "6f386c25-c5f7-4cc6-8761-a63a480078ba",
                "key": "49911265-fd1a-4db0-8504-f15d95c2ea67",
                "udi": null,
                "values": [
                  {
                    "alias": "profilePicture",
                    "culture": null,
                    "editorAlias": null,
                    "segment": null,
                    "value": [
                      {
                        "key": "b1b790eb-34c2-4462-a549-fd0412edf9f5",
                        "mediaKey": "d493ddbd-4353-4e49-a7ff-e137a57d2a07",
                        "mediaTypeAlias": "Image",
                        "crops": [],
                        "focalPoint": null
                      }
                    ]
                  },
                  {
                    "alias": "mainPicture",
                    "culture": null,
                    "editorAlias": null,
                    "segment": null,
                    "value": [
                      {
                        "key": "91973fdc-a0bf-476d-a5be-2f94dd3a1436",
