                      }
                    ]
                  },
                  {
                    "alias": "characterSource",
                    "culture": null,
                    "editorAlias": null,
                    "segment": null,
                    "value": "Destiny"
                  },
                  {
                    "alias": "characterName",
                    "culture": null,
                    "editorAlias": null,
                    "segment": null,
                    "value": "Frigoris, Exiled Baron"
                  },
                  {
                    "alias": "details",
                    "culture": null,
                    "editorAlias": null,
                    "segment": null,
                    "value": "Frigoris was a Baron who joined the House of Exile on the Moon of Earth. He wanted to gain strength for the disheveled House, and launched a daring raid on the Hellmouth. His crews punched a deep hole in the Hive lines, but the Young Wolf encountered him and slew him along with the rest of his followers as they sought to destroy the Shrine of Oryx."
                  }
                ]
              },
              {
                "contentTypeKey": "6f386c25-c5f7-4cc6-8761-a63a480078ba",
                "key": "4eb1c64e-ebe6-4803-83d6-34e13d2b78b3",
                "udi": null,
                "values": [
                  {
