        },
        {
          "alias": "characterName",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "Leviathan-Eater, Bane of the Ammonites"
        },
        {
          "alias": "characterSource",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "Destiny 2: Season of the Witch"
        },
        {
          "alias": "details",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "Originally named Ir Uulxal, the Leviathan-Eater struck the final blow on the Leviathan of Fundament during the Ammonite wars. He was the mightiest servant of Xivu Arath, acting as her foremost commander. He would be summoned by Xivu to Savath\u00FBn\u0027s Throne World to destroy the Young Wolf and Eris Morn, as they were trying to grow Eris strong enough to face Xivu herself. He was one of the oldest Hive in the universe, having been born on Fundament before the Krill became the Hive. He could strike his enemies with a fiery attack with the power of a sunspot."
        },
        {
          "alias": "energyExponent",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "32"
        },
        {
          "alias": "characterVariant",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "Material Space"
        },
        {
          "alias": "characterTitle",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "Favoured Harbinger of Xivu Arath"
        }
      ]
    },
