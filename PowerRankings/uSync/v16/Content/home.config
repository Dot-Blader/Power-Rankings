          "value": [
            {
              "key": "680369a4-e4a9-4d7a-ad97-81e02046bbe2",
              "mediaKey": "88e317fa-ed47-48be-8f45-c1e6ff213596",
              "mediaTypeAlias": "Image",
              "crops": [],
              "focalPoint": null
            }
          ]
        },
        {
          "alias": "characterSource",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "Destiny"
        },
        {
          "alias": "characterName",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "The Black Heart"
        },
        {
          "alias": "details",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "The Heart of the Black Garden was an entity created by the Vex from a seed left behind by the Witness after its visit. It was created to be a copy of the Veil, but it ended up failing. The Vex still found use for the Darkness it was able to emit, as they deduced that worshipping it would grant them its power. The Sol Divisive assigned three Minotaurs to each receive the time-altering powers of the Heart, intending to use them to bring forth the powers of the Vault of Glass."
        }
      ]
    },
    {
      "contentTypeKey": "6f386c25-c5f7-4cc6-8761-a63a480078ba",
      "key": "60c2f715-ca68-4100-a6bf-bb5c63e1fb76",
      "udi": null,
      "values": [
        {
          "alias": "energyMultiplicator",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "Infinite Energy"
        },
        {
          "alias": "profilePicture",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": [
            {
              "key": "6dba9851-0d18-49c4-956b-baa29d5ff81d",
              "mediaKey": "972738fd-44bd-4afa-88b0-08ea97e5e2f2",
              "mediaTypeAlias": "Image",
              "crops": [],
              "focalPoint": null
            }
          ]
        },
        {
          "alias": "characterName",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "Sol Progeny"
        },
        {
          "alias": "characterSource",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "Destiny"
        },
        {
          "alias": "details",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "The Sol Progeny were three Minotaurs created by the Vex to worship and harness the power of the Black Heart. They were meant to use this power to bring forth the powers of the Vault of Glass into material space. This would have allowed the Vex to manipulate time across the universe."
        },
        {
          "alias": "groupMembers",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": {
            "contentData": [
              {
                "contentTypeKey": "6f386c25-c5f7-4cc6-8761-a63a480078ba",
                "key": "5d138ea7-e4f1-4c27-8e43-4de3419e931e",
                "udi": null,
                "values": [
                  {
                    "alias": "profilePicture",
                    "culture": null,
                    "editorAlias": null,
                    "segment": null,
                    "value": [
                      {
                        "key": "2f60faba-883c-456f-9315-27be3c125f39",
                        "mediaKey": "02c21be4-da69-4c32-b8dc-fc451745e11d",
                        "mediaTypeAlias": "Image",
                        "crops": [],
                        "focalPoint": null
                      }
                    ]
                  },
                  {
                    "alias": "characterName",
                    "culture": null,
                    "editorAlias": null,
                    "segment": null,
                    "value": "Primeval Mind"
                  },
                  {
                    "alias": "characterSource",
                    "culture": null,
                    "editorAlias": null,
                    "segment": null,
                    "value": "Destiny"
                  },
                  {
                    "alias": "details",
                    "culture": null,
                    "editorAlias": null,
                    "segment": null,
                    "value": "The Primeval Mind was a model of ancient Precursor Vex, created for the Sol Progeny to represent the past. It would have allowed the Vex to rewrite the past if it hadn\u0027t been destroyed by a Guardian before it and the Black Heart was ready."
                  },
                  {
                    "alias": "mainPicture",
                    "culture": null,
                    "editorAlias": null,
                    "segment": null,
