                    "segment": null,
                    "value": [
                      {
                        "key": "d854a948-df62-4429-bb75-891302769a81",
                        "mediaKey": "67e794d7-8230-476d-9380-3ec70cd731f5",
                        "mediaTypeAlias": "Image",
                        "crops": [],
                        "focalPoint": null
                      }
                    ]
                  },
                  {
                    "alias": "details",
                    "culture": null,
                    "editorAlias": null,
                    "segment": null,
                    "value": "As Ascendant Hive all Darkblades have Throne Worlds which grant them 5-Dimensional power. Within this space Darkblades would often be used as powerful enforcers by the Hive Gods they served."
                  },
                  {
                    "alias": "energyMultiplicator",
                    "culture": null,
                    "editorAlias": null,
                    "segment": null,
