        },
        {
          "alias": "characterSource",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "Destiny"
        },
        {
          "alias": "characterName",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "Planet-Cracker Warhead"
        },
        {
          "alias": "details",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "The Cabal Empire is infamous for blowing up planets and moons for simply getting in their way. They do so using Planet-Cracker Warheads, which are mounted inside a giant bullet-like missile or stored in boxes onboard Cabal ships or around bases. A single warhead had enough power to destroy a Hive War Moon."
        },
        {
          "alias": "mainPicture",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": [
            {
              "key": "b866e60a-dc0c-44f8-88e6-a46da8287235",
              "mediaKey": "07473255-a501-4b93-b4dc-0a443504b902",
              "mediaTypeAlias": "Image",
              "crops": [],
              "focalPoint": null
            }
          ]
        }
      ]
    },
    {
      "contentTypeKey": "6f386c25-c5f7-4cc6-8761-a63a480078ba",
      "key": "219b4c52-297f-460a-8238-290503df40b3",
      "udi": null,
      "values": [
        {
          "alias": "energyMultiplicator",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "Temporal"
        },
        {
          "alias": "characterName",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "Sol Inherent"
        },
        {
          "alias": "characterSource",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "Destiny 2: Shadowkeep"
        },
        {
          "alias": "profilePicture",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": [
            {
              "key": "8cc05f3d-5081-434c-8207-9e3fd036ca58",
              "mediaKey": "ad24c1d5-668e-48d6-b865-b5fb1c86fc6e",
              "mediaTypeAlias": "Image",
              "crops": [],
              "focalPoint": null
            }
          ]
        },
        {
          "alias": "details",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "The Sol Inherent was a group of Vex of the Sol Divisive who received Darkness from a veiled statue inside the Black Garden left behind by the Witness. This power had been laying dormant for years, and only became available for the Vex to harness once the Pyramid Ship on Luna reactivated. The group was set to grow even larger as more Vex were being exposed to the Darkness, but they were stopped by a fireteam of Guardians."
        },
        {
          "alias": "groupMembers",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": {
            "contentData": [
              {
                "contentTypeKey": "6f386c25-c5f7-4cc6-8761-a63a480078ba",
                "key": "cada1a21-4718-4034-a184-2223530f2d94",
                "udi": null,
                "values": [
                  {
                    "alias": "profilePicture",
                    "culture": null,
                    "editorAlias": null,
                    "segment": null,
                    "value": [
                      {
                        "key": "a9d46329-856e-4f96-9f24-24059c647343",
                        "mediaKey": "8a9ce181-70b3-4f7e-9dd3-628810cf815a",
                        "mediaTypeAlias": "Image",
                        "crops": [],
                        "focalPoint": null
                      }
                    ]
                  },
                  {
                    "alias": "characterName",
                    "culture": null,
                    "editorAlias": null,
                    "segment": null,
                    "value": "Consecrated Mind"
                  },
                  {
                    "alias": "characterTitle",
                    "culture": null,
                    "editorAlias": null,
                    "segment": null,
                    "value": "Sol Inherent"
                  },
                  {
                    "alias": "characterSource",
                    "culture": null,
                    "editorAlias": null,
                    "segment": null,
                    "value": "Destiny 2: Shadowkeep"
                  },
                  {
                    "alias": "mainPicture",
                    "culture": null,
                    "editorAlias": null,
                    "segment": null,
                    "value": [
                      {
                        "key": "8dab34b5-9f81-4521-bd7f-49889bd44eb8",
                        "mediaKey": "cee1ea0b-9e41-495e-a936-03e600aa5e53",
                        "mediaTypeAlias": "Image",
                        "crops": [],
                        "focalPoint": null
                      }
                    ]
                  },
                  {
                    "alias": "details",
                    "culture": null,
                    "editorAlias": null,
                    "segment": null,
                    "value": "The Consecrated Mind was a Harpy of the Sol Divisive exposed to the Darkness at the center of the smoking stump in the Black Garden. It was given the task to continue the flow of Darkness into other Vex frames by directly forcing it into their systems. It had situated itself where the Black Heart once was, and would channel Darkness into the Vex in a similar way to the Heart."
                  }
                ]
              },
              {
                "contentTypeKey": "6f386c25-c5f7-4cc6-8761-a63a480078ba",
                "key": "e2bf2f69-934c-408b-a6c1-b68d978a61be",
                "udi": null,
                "values": [
                  {
                    "alias": "profilePicture",
                    "culture": null,
                    "editorAlias": null,
                    "segment": null,
                    "value": [
                      {
                        "key": "a8dab465-77a1-42fa-9bae-31974312ca01",
                        "mediaKey": "7102ab7c-405c-40a0-849b-eb6a7d2be2bb",
                        "mediaTypeAlias": "Image",
                        "crops": [],
                        "focalPoint": null
                      }
                    ]
                  },
                  {
                    "alias": "mainPicture",
                    "culture": null,
                    "editorAlias": null,
                    "segment": null,
                    "value": [
                      {
                        "key": "5138c7c3-1487-43ef-b89f-b2b27ca82e5c",
                        "mediaKey": "b60ded5c-0e59-4d53-b529-8622b61cf58b",
