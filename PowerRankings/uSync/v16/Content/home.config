                    "editorAlias": null,
                    "segment": null,
                    "value": ""
                  },
                  {
                    "alias": "characterVariant",
                    "culture": null,
                    "editorAlias": null,
                    "segment": null,
                    "value": "Ascendant Plane"
                  },
                  {
                    "alias": "details",
                    "culture": null,
                    "editorAlias": null,
                    "segment": null,
                    "value": "Whether or not Ecthar died a final death in the Ascendant Plane is unclear. He was revived by a Ghost as a Lightbearer years after being defeated aboard the Dreadnaught, but whether or not a Ghost can bring back a Hive who\u0027s still alive in the Ascendant Pane is unknown. After being defeated in his Lightbearer form, and having his Ghost crushed, his fate was finally sealed."
                  },
                  {
                    "alias": "mainPicture",
                    "culture": null,
                    "editorAlias": null,
                    "segment": null,
                    "value": ""
                  }
                ]
              },
