                                }
                              ]
                            },
                            {
                              "alias": "details",
                              "culture": null,
                              "editorAlias": null,
                              "segment": null,
                              "value": "Teksis was a Fallen Captain who was Taken by Quria and placed under Val Belyx. Together with the other Sentinels he protected the site of a ritual overseen by Belyx. He used his Ascendant strength to conjure a Blight able to shield the inner sections from intruders."
                            }
                          ]
                        },
                        {
                          "contentTypeKey": "6f386c25-c5f7-4cc6-8761-a63a480078ba",
                          "key": "e2488ca7-4d37-4168-958f-088356b18a38",
