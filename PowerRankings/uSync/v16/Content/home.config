        },
        {
          "alias": "characterName",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "Wizard"
        },
        {
          "alias": "characterSource",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "Destiny"
        },
        {
          "alias": "details",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "Instead of morphing into a Knight, an Acolyte with sufficient strength can choose to morph into a Wizard. In this state the physical durability is lesser than a Knight, but a better capability to call upon the power of the Darkness is available. To counteract the lower natural strength, a Wizard will cloak itself in a naturally generated absorption shield of Solar-energy, giving them a magical barrier that helps protect them from harm."
        }
      ]
    },
    {
      "contentTypeKey": "6f386c25-c5f7-4cc6-8761-a63a480078ba",
      "key": "7b86ac6a-59d8-4082-9d5d-ce637f3448c6",
