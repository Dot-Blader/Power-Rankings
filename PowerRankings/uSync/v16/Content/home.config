          "segment": null,
          "value": "Legionary"
        },
        {
          "alias": "characterSource",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "Destiny"
        },
        {
          "alias": "details",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "Legionaries are the base units of the Cabal Empire\u0027s military. They have tough armor, but due to their young age, they don\u0027t have the size or strength to bear similar armor to their older and larger comrades."
        }
      ]
    },
