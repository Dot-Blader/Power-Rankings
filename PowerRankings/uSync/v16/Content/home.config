                    "editorAlias": null,
                    "segment": null,
                    "value": [
                      {
                        "key": "7af22533-3e12-4be2-bac6-047a81008f06",
                        "mediaKey": "898d6f81-1431-43f0-8a42-8d568cb89d3a",
                        "mediaTypeAlias": "Image",
                        "crops": [],
                        "focalPoint": null
                      }
                    ]
                  },
                  {
                    "alias": "characterName",
                    "culture": null,
                    "editorAlias": null,
                    "segment": null,
                    "value": "Vatch, Psion Flayer"
                  },
                  {
                    "alias": "characterSource",
                    "culture": null,
                    "editorAlias": null,
                    "segment": null,
                    "value": "Destiny"
                  },
                  {
                    "alias": "details",
                    "culture": null,
                    "editorAlias": null,
                    "segment": null,
                    "value": "Vatch was dispatched to the Dust Palace alongside his comrades in order to stop the Warmind\u0027s ongoing assaults. There he would be attacked by Guardians, and fought with both mind and body, but was ultimately defeated. "
                  }
                ]
              },
              {
                "contentTypeKey": "6f386c25-c5f7-4cc6-8761-a63a480078ba",
                "key": "9bcc09da-5678-4ce7-9428-cf8fbe1739ef",
                "udi": null,
                "values": [
                  {
                    "alias": "characterName",
                    "culture": null,
                    "editorAlias": null,
                    "segment": null,
                    "value": "Numoc, Psion Flayer"
                  },
                  {
                    "alias": "profilePicture",
                    "culture": null,
                    "editorAlias": null,
                    "segment": null,
                    "value": [
                      {
                        "key": "5d2e8167-284f-4619-b253-e3417ee20408",
                        "mediaKey": "b5f74baa-60ee-4fd1-b317-f6611e2f785a",
                        "mediaTypeAlias": "Image",
                        "crops": [],
                        "focalPoint": null
                      }
                    ]
                  },
                  {
                    "alias": "mainPicture",
                    "culture": null,
                    "editorAlias": null,
                    "segment": null,
                    "value": [
                      {
                        "key": "881243fd-8961-4f1b-bdb2-d65cf9d97ca6",
                        "mediaKey": "b1c36e5f-2dd5-4225-82ab-475128102e9a",
                        "mediaTypeAlias": "Image",
                        "crops": [],
                        "focalPoint": null
                      }
                    ]
                  },
                  {
                    "alias": "characterSource",
                    "culture": null,
                    "editorAlias": null,
                    "segment": null,
                    "value": "Destiny"
                  },
                  {
                    "alias": "details",
                    "culture": null,
                    "editorAlias": null,
                    "segment": null,
                    "value": "Numoc assisted his comrades in their fight against the Guardians in the Dust Palace in the lost city of Freehold. He would call in reinforcements to assist, but even a small army proved useless against the onslaught of the Guardians. Numoc\u0027s absorption shield was unable to protect him from their Light-enhanced weapons."
                  }
                ]
              }
            ],
            "settingsData": [
