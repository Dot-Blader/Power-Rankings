          "value": "29"
        },
        {
          "alias": "characterName",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "Divisive Mind"
        },
        {
          "alias": "profilePicture",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": [
            {
              "key": "70251bf6-75d8-4ac5-8390-a4e7a219dee7",
              "mediaKey": "dcb61c07-2c3c-4627-a566-01612da3face",
              "mediaTypeAlias": "Image",
              "crops": [],
              "focalPoint": null
            }
          ]
        },
        {
          "alias": "characterSource",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "Destiny"
        },
        {
          "alias": "details",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "The Divisive Mind was the Axis Mind in charge of the Sol Divisive. It oversaw the Undying Mind and the various Gate Lords protecting the gates into the Black Garden. It resided inside the Garden and maintained a barrier that prevented hostile access to the Sol Progeny and the Black Heart. It was encountered by the Young Wolf and destroyed on their journey to end the beating of the Black Heart."
        },
        {
          "alias": "mainPicture",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": [
            {
              "key": "73358360-bae5-4c5d-9327-d7448007be21",
              "mediaKey": "841817f6-8d40-462f-b741-a020ec17c7cb",
              "mediaTypeAlias": "Image",
              "crops": [],
              "focalPoint": null
            }
          ]
        }
      ]
    },
