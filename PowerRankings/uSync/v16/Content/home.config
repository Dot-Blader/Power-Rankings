                              "segment": null,
                              "value": ""
                            },
                            {
                              "alias": "characterName",
                              "culture": null,
                              "editorAlias": null,
                              "segment": null,
                              "value": "Eyes of Crota"
                            },
                            {
                              "alias": "characterVariant",
                              "culture": null,
                              "editorAlias": null,
                              "segment": null,
                              "value": "Ascendant Plane"
                            },
                            {
                              "alias": "characterSource",
                              "culture": null,
                              "editorAlias": null,
                              "segment": null,
                              "value": "Destiny: The Dark Below"
                            },
                            {
                              "alias": "details",
                              "culture": null,
                              "editorAlias": null,
                              "segment": null,
                              "value": "The Eyes of Crota were defeated in material space. After this their souls would return to their respective Throne Worlds within the Ascendant Plane, however it is unknown what happened to them after that."
                            },
                            {
                              "alias": "groupMembers",
                              "culture": null,
