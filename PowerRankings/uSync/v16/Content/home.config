                        "focalPoint": null
                      }
                    ]
                  },
                  {
                    "alias": "characterName",
                    "culture": null,
                    "editorAlias": null,
                    "segment": null,
                    "value": "Ignovun, Chosen of Caiatl"
                  },
                  {
                    "alias": "characterTitle",
                    "culture": null,
                    "editorAlias": null,
                    "segment": null,
                    "value": "Imperial Fleet Commander"
                  },
                  {
                    "alias": "characterSource",
                    "culture": null,
                    "editorAlias": null,
                    "segment": null,
                    "value": "Destiny 2: Season of the Chosen"
                  },
                  {
                    "alias": "details",
                    "culture": null,
                    "editorAlias": null,
                    "segment": null,
                    "value": "Ignovun was the commander of the entire fleet of the Cabal Empire, working on the Empire\u0027s War Council. He was chosen by Empress Caiatl to represent the Empire in a Rite of Proving against Guardians of the Last City. Caiatl saw Ignovun as the strongest champion the Cabal Empire had to offer, and for the ritualistic battle he had been adorned in the strongest armor the Cabal had."
                  }
                ]
              },
              {
                "contentTypeKey": "6f386c25-c5f7-4cc6-8761-a63a480078ba",
                "key": "34f4b517-52ba-4a97-a733-bdd41c876d51",
                "udi": null,
                "values": [
                  {
                    "alias": "profilePicture",
                    "culture": null,
                    "editorAlias": null,
                    "segment": null,
                    "value": [
                      {
                        "key": "eb48705b-e032-49f2-a758-c4c57270bf14",
                        "mediaKey": "4cbe7cda-a5e6-4dda-aa62-18234f6dc0c7",
                        "mediaTypeAlias": "Image",
                        "crops": [],
                        "focalPoint": null
                      }
                    ]
                  },
                  {
                    "alias": "characterName",
                    "culture": null,
                    "editorAlias": null,
                    "segment": null,
                    "value": "Val Aru\u0027un"
                  },
                  {
                    "alias": "characterTitle",
                    "culture": null,
                    "editorAlias": null,
                    "segment": null,
                    "value": "Cabal Strategist"
                  },
                  {
                    "alias": "characterSource",
                    "culture": null,
                    "editorAlias": null,
                    "segment": null,
                    "value": "Destiny: House of Wolves"
                  },
                  {
                    "alias": "mainPicture",
                    "culture": null,
                    "editorAlias": null,
                    "segment": null,
                    "value": [
                      {
                        "key": "c58afb65-8ac0-4d43-bc5a-42408a7d919b",
                        "mediaKey": "fc06a3e8-96a9-47a5-a2e5-4ee68181fad6",
                        "mediaTypeAlias": "Image",
                        "crops": [],
                        "focalPoint": null
                      }
                    ]
                  },
                  {
                    "alias": "details",
                    "culture": null,
                    "editorAlias": null,
                    "segment": null,
                    "value": "Aru\u0027un ascended to the rank of Val whilst in the Prison of Elders. He was respected among his fellow Cabal prisoners, and would crush the ambitions of the younger and lesser warriors who dared to challenge him."
                  }
                ]
              }
