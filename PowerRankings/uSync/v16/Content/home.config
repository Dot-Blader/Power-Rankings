              "focalPoint": null
            }
          ]
        },
        {
          "alias": "mainPicture",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": [
            {
              "key": "543d261b-f6a3-42b6-9887-28666031c152",
              "mediaKey": "90e5dffb-ed3a-4598-9a9f-ffe6cf760052",
              "mediaTypeAlias": "Image",
              "crops": [],
              "focalPoint": null
            }
          ]
        },
        {
          "alias": "details",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "Toniq was a Tormentor, a creature made in the image of Nezarec. He was in charge of assisting Parthenios with forcing Taken into the HyperNet Current domain of the Vex Network, in order to penetrate the CloudArk. He did so by channeling his power into a massive Crux of Darkness and a small Pyramid ship, using Resonance to open a Blight that allowed Taken to flow from the Ascendant Plane directly into the Vex Network. "
        }
      ]
    },
    {
      "contentTypeKey": "6f386c25-c5f7-4cc6-8761-a63a480078ba",
      "key": "fdb9349a-d0f6-4a8e-87fa-bf889189298e",
