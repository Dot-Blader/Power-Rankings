            {
              "key": "3f221f38-2fbf-4dd0-9086-0563e5bfbea2",
              "mediaKey": "0568a24a-0536-4056-b31b-782efdbbc96f",
              "mediaTypeAlias": "Image",
              "crops": [],
              "focalPoint": null
            }
          ]
        },
        {
          "alias": "characterName",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "Starfall Sonic"
        },
        {
          "alias": "characterSource",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "SONIC FRONTIERS"
        },
        {
          "alias": "details",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "When attempting to face off against a not-yet-fully-charged THE END, Super Sonic would be too weak. He allowed the corruptive energies within him gained from Cyber Space to enhance his strength, giving him access to power comparable to when he fought side by side with the Titan SUPREME. With this amount of power he was able to contend with the yet weak THE END, but he was still holding back to not let the corruption overtake him entirely."
        },
        {
          "alias": "characterTitle",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "Cyber-corrupted Super Sonic"
        }
      ]
    },
    {
      "contentTypeKey": "6f386c25-c5f7-4cc6-8761-a63a480078ba",
      "key": "58b8b5bb-5f61-42a7-9914-52dfb107754d",
      "udi": null,
      "values": [
        {
          "alias": "energyMultiplicator",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "7-Dimensional"
        },
        {
          "alias": "profilePicture",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": [
            {
              "key": "4192b9de-9bb8-4d5a-a302-3cd49f58504b",
              "mediaKey": "0852cdea-80ed-480c-82e4-96b5119f1120",
              "mediaTypeAlias": "Image",
              "crops": [],
              "focalPoint": null
            }
          ]
        },
        {
          "alias": "characterName",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "Metal Overlord"
        },
        {
          "alias": "characterSource",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "SONIC HEROES"
        },
        {
          "alias": "mainPicture",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": [
            {
              "key": "c6cd4719-0de8-48a5-92c7-2731d565b8bf",
              "mediaKey": "7ed94b9f-51d9-4f65-81c6-958d7c748ae9",
              "mediaTypeAlias": "Image",
              "crops": [],
              "focalPoint": null
            }
          ]
        },
        {
          "alias": "details",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "Metal Sonic transformed into this incredibly powerful form in order to conquer the world. He had combined the data of all of Sonic\u0027s friends, and Sonic himself, with the power of the Chaos Emeralds which made him so strong that Dr. Eggman was unsure of whether the Emeralds\u0027 power would be enough to stop him. Metal Overlord\u0027s absolute strength was evident as he battled against Super Sonic, Tails and Knuckles as he casually threw ships from the Egg Fleet at the heroes."
        }
      ]
    },
    {
      "contentTypeKey": "6f386c25-c5f7-4cc6-8761-a63a480078ba",
      "key": "447444bf-a410-4fec-9079-d6d01f5f1ac7",
      "udi": null,
      "values": [
        {
          "alias": "energyMultiplicator",
          "culture": null,
