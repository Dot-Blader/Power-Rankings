                        "crops": [],
                        "focalPoint": null
                      }
                    ]
                  },
                  {
                    "alias": "mainPicture",
                    "culture": null,
                    "editorAlias": null,
                    "segment": null,
                    "value": [
                      {
                        "key": "becd1ffb-f793-49b0-880f-94a09a979762",
