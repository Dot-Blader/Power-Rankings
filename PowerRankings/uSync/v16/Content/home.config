            }
          ]
        },
        {
          "alias": "characterName",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "The Templar"
        },
        {
          "alias": "characterSource",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "Destiny"
        },
        {
          "alias": "details",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "The Templar was a Vex Hydra situated in the Vault of Glass. It had the ability to perceive the designs of the Oracles, and to bring those designs into existence. It would do so through the Ritual of Negation, deleting any unwanted being from the timeline. This power was limited to only affecting those who stepped inside the Vault, but through the Sol Progeny the Vex were in the process of finding a way to bring this power out of the Vault, allowing the Templar to alter the timeline in its entirety without the targets being inside the Vault."
        }
      ]
    },
