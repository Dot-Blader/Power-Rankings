        },
        {
          "alias": "characterName",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "Eramis, Kell of Darkness"
        },
        {
          "alias": "details",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "Eramis was the  founder and Kell of the House of Salvation on Europa. She led the Dark Council and oversaw the gifting of Darkness to her people through Pyramid Splinters. She had a gauntlet that allowed her to draw Stasis-power from a Splinter of her own, which she would use to show her followers how Darkness would be the salvation of all Eliksni."
        },
        {
          "alias": "profilePicture",
          "culture": null,
