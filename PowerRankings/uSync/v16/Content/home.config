        },
        {
          "alias": "characterName",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "The Hypnotist"
        },
        {
          "alias": "characterSource",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "Little Nightmares 3"
        },
        {
          "alias": "details",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "The Hypnotist was in charge of the Institute, a location within the Spiral. He seems to have been a man from the real world named Otto, who forcefully entered the Nowhere in order to find out what happened to his sister. Over time his body was warped by the Transmission, and he became massive. His arms and legs became able to stretch, allowing him to reach around the entire building\u0027s interior halls. The palms of his hands even gained eyes of their own, allowing him to see far out of sight of his head. Thanks to his massive size, he had the strength to drag large walls of the collapsing building in order to keep it from falling apart on top of him. "
        },
        {
          "alias": "mainPicture",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": [
            {
              "key": "3b602c19-131e-4560-bf82-afee636d0803",
              "mediaKey": "1c5f0e16-d6d6-479d-aecd-023cd658e1df",
              "mediaTypeAlias": "Image",
              "crops": [],
              "focalPoint": null
            }
          ]
        }
      ]
    },
