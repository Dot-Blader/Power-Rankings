                            {
                              "alias": "details",
                              "culture": null,
                              "editorAlias": null,
                              "segment": null,
                              "value": "Purtra was a deceptive Taken Wizard who defended the Dreadnaught against challengers. She would fight alongside the other Planeshifting Taken in the Founts when they were summoned from the Ascendant Plane by the same Guardian who killed them all individually previously."
                            }
                          ]
                        },
