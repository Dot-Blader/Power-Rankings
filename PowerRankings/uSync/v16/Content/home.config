        {
          "alias": "characterName",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "Minotaur"
        },
        {
          "alias": "mainPicture",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": [
            {
              "key": "6ef20dc7-e0a8-4a3d-b217-635c2e501f79",
              "mediaKey": "377eec6d-b87c-4462-a8c0-95796e4ece0b",
              "mediaTypeAlias": "Image",
              "crops": [],
              "focalPoint": null
            }
          ]
        },
        {
          "alias": "characterSource",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "Destiny"
        },
        {
          "alias": "details",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "Minotaurs wield Torch Hammers, and dedicate most of their processing power to construction. They have thicker and harder plating than the other basic Vex units, and can turn their construction tool against hostile beings if needed. They often have a built-in Void-energy absorption shield, which resists any non-Void attacks."
        }
      ]
    },
    {
      "contentTypeKey": "6f386c25-c5f7-4cc6-8761-a63a480078ba",
      "key": "e5db4f54-25da-4105-9863-dbd1da414301",
      "udi": null,
      "values": [
        {
          "alias": "energyMultiplicator",
