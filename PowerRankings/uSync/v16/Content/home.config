                    "value": [
                      {
                        "key": "04ff1e5e-6a9f-4155-bab1-185432cbe54a",
                        "mediaKey": "98fa52d1-2be0-4421-9d37-9d88e9d1a0d8",
                        "mediaTypeAlias": "Image",
                        "crops": [],
                        "focalPoint": null
                      }
                    ]
                  },
                  {
                    "alias": "mainPicture",
                    "culture": null,
                    "editorAlias": null,
                    "segment": null,
                    "value": [
                      {
                        "key": "fc5c6ad2-1a67-4039-af0c-52ce3905931f",
                        "mediaKey": "26026505-31df-4609-ab01-a4f996e6acc0",
                        "mediaTypeAlias": "Image",
                        "crops": [],
                        "focalPoint": null
                      }
                    ]
                  },
                  {
                    "alias": "characterName",
                    "culture": null,
                    "editorAlias": null,
                    "segment": null,
                    "value": "Acanthos, Gate Lord"
                  },
                  {
                    "alias": "characterSource",
                    "culture": null,
                    "editorAlias": null,
                    "segment": null,
                    "value": "Destiny 2"
                  },
                  {
                    "alias": "details",
                    "culture": null,
                    "editorAlias": null,
                    "segment": null,
                    "value": "Acanthos was a Gate Lord summoned onto 7066 Nessus after the House of Dusk settled onto the unstable Centaur following Cayde-6\u0027s arrival there. Its purpose was to ensure that the Fallen couldn\u0027t enter the Vex Network from there, but it would be engaged by a Guardian mid-battle and forced to fight against them instead. The Guardian destroyed the Minotaur and progressed towards Cayde-6\u0027s location. "
                  }
                ]
              },
              {
                "contentTypeKey": "6f386c25-c5f7-4cc6-8761-a63a480078ba",
                "key": "020e89db-2835-45a5-8832-fd3f6276550a",
                "udi": null,
                "values": [
                  {
                    "alias": "profilePicture",
                    "culture": null,
                    "editorAlias": null,
                    "segment": null,
                    "value": [
                      {
                        "key": "b5f37242-48a7-4bd1-8115-2e2a3c8ec6bf",
                        "mediaKey": "0281884c-712b-4fb5-b406-f8883d1e6c2e",
                        "mediaTypeAlias": "Image",
                        "crops": [],
                        "focalPoint": null
                      }
                    ]
                  },
                  {
                    "alias": "mainPicture",
                    "culture": null,
                    "editorAlias": null,
                    "segment": null,
                    "value": [
                      {
                        "key": "456208db-f691-4d08-88d7-1bef015ba10b",
                        "mediaKey": "dd8741d2-ea70-4a41-875f-110a0f409d16",
                        "mediaTypeAlias": "Image",
                        "crops": [],
                        "focalPoint": null
                      }
                    ]
                  },
                  {
                    "alias": "characterName",
                    "culture": null,
                    "editorAlias": null,
                    "segment": null,
                    "value": "Qodron, Gate Lord"
                  },
                  {
                    "alias": "characterTitle",
                    "culture": null,
                    "editorAlias": null,
                    "segment": null,
                    "value": "The Forever Eater, Vex Chronovore"
                  },
                  {
                    "alias": "characterSource",
                    "culture": null,
                    "editorAlias": null,
                    "segment": null,
                    "value": "Destiny: House of Wolves"
                  },
                  {
                    "alias": "details",
                    "culture": null,
                    "editorAlias": null,
                    "segment": null,
                    "value": "Qodron was a Gate Lord that foresaw that it would defeat a \u0022Light\u0022 in the Prison of Elders in the future and intentionally let itself get captured there. It was a mighty champion to any prisoners who dared challenge it, but it would be destroyed by the Light it had presumably foreseen when a Guardian fireteam challenged it and won, seemingly proving its prediction false."
                  }
                ]
              }
            ],
            "settingsData": [
