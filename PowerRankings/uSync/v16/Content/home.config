                        {
                          "contentTypeKey": "6f386c25-c5f7-4cc6-8761-a63a480078ba",
                          "key": "914b3c3a-5eaa-4792-8eda-5039b9c75175",
                          "udi": null,
                          "values": [
                            {
                              "alias": "characterName",
                              "culture": null,
                              "editorAlias": null,
                              "segment": null,
                              "value": "Alak-Tor, Fatesmith of Incaru"
                            },
                            {
                              "alias": "characterVariant",
                              "culture": null,
                              "editorAlias": null,
                              "segment": null,
                              "value": "Ascendant Plane"
                            },
                            {
                              "alias": "characterSource",
                              "culture": null,
                              "editorAlias": null,
                              "segment": null,
                              "value": "Destiny 2: Forsaken"
                            },
                            {
                              "alias": "details",
                              "culture": null,
                              "editorAlias": null,
                              "segment": null,
                              "value": "Alak-Tor and the other Fatesmiths have the unique ability to be resummoned back into existance immediately by D\u00FBl Incaru, even after suffering final deaths inside the Ascendant Plane. Their fate is bound to D\u00FBl Incaru and her purpose of finding the Distributary, and so as long as she needs protection, Alak-Tor will return to serve."
                            },
                            {
