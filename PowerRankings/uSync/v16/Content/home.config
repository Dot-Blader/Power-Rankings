          ]
        },
        {
          "alias": "details",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "Seemingly being the source of the Transmission, the Thin Man causes grotesque effects on the entire Nowhere. He wanders the Pale City, which has its streets and buildings warped and distorted by his mere presence."
        },
        {
          "alias": "characterSource",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "Little Nightmares 2"
        }
