        },
        {
          "alias": "mainPicture",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": [
            {
              "key": "7521ad90-d017-449d-b092-df0848deb81e",
              "mediaKey": "2b9e05e6-b0c6-4067-bf8f-f9fef35a45a8",
