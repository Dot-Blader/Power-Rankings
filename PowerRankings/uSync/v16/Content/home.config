                  }
                ]
              },
              {
                "contentTypeKey": "6f386c25-c5f7-4cc6-8761-a63a480078ba",
                "key": "a57f9d3a-ce32-45fe-9a28-3797fb8a9eb8",
                "udi": null,
                "values": [
                  {
                    "alias": "characterName",
                    "culture": null,
                    "editorAlias": null,
                    "segment": null,
                    "value": "Baimogg, Unchained Wrath"
                  },
                  {
                    "alias": "characterVariant",
                    "culture": null,
                    "editorAlias": null,
                    "segment": null,
                    "value": "Ascendant Plane"
                  },
                  {
                    "alias": "characterSource",
                    "culture": null,
                    "editorAlias": null,
                    "segment": null,
                    "value": "Destiny 2: Season of Defiance"
                  },
                  {
                    "alias": "details",
                    "culture": null,
                    "editorAlias": null,
                    "segment": null,
                    "value": "Baimogg was a Chimera, a Taken Servitor, serving the Shadow Legion during their assault on Earth. Baimogg assisted Gor\u0027ath Gath in spreading Blight throughout the European Dead Zone. After being defeated in material space its soul would return to the Ascendant Plane, where its ultimate fate remains unknown."
                  },
                  {
                    "alias": "profilePicture",
                    "culture": null,
                    "editorAlias": null,
                    "segment": null,
                    "value": ""
                  },
                  {
                    "alias": "mainPicture",
                    "culture": null,
                    "editorAlias": null,
                    "segment": null,
                    "value": ""
                  }
                ]
              },
              {
                "contentTypeKey": "6f386c25-c5f7-4cc6-8761-a63a480078ba",
                "key": "7aa159fd-5619-4121-b6df-17d7980b0950",
                "udi": null,
                "values": [
                  {
                    "alias": "characterName",
                    "culture": null,
                    "editorAlias": null,
                    "segment": null,
                    "value": "Exomida, Taken of the Witness"
                  },
                  {
                    "alias": "characterVariant",
                    "culture": null,
                    "editorAlias": null,
                    "segment": null,
                    "value": "Ascendant Plane"
                  },
                  {
                    "alias": "characterSource",
                    "culture": null,
                    "editorAlias": null,
                    "segment": null,
                    "value": "Destiny 2: Season of Defiance"
                  },
                  {
                    "alias": "profilePicture",
                    "culture": null,
