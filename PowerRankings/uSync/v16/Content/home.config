        {
          "alias": "details",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "RED PILLARs were variants of the TOWER stationed on Ouranos Island. They could extend sharp blades from the lower body sections that made it incredibly hard for attackers to deal damage to them without sustaining too much damage themselves."
        }
      ]
    },
