            }
          ]
        },
        {
          "alias": "characterName",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "Brakion, Genesis Mind"
        },
        {
          "alias": "characterSource",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "Destiny 2"
        },
        {
          "alias": "details",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "Brakion was the Vex Axis Mind that controlled the interior of the Pyramidion. This structure linked all Vex Machine-Worlds to each other and the Vex Network, and contained infinite-dimensional space. Brakion wielded the ability to manipulate this reality, warping it in various ways to prevent any intruders from navigating the network."
        },
        {
          "alias": "mainPicture",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": [
            {
              "key": "18920c4b-b7e5-4865-b8ff-e31a11ed24bd",
              "mediaKey": "2381a26c-1ff8-4367-b3e0-7c523b9ee781",
              "mediaTypeAlias": "Image",
              "crops": [],
              "focalPoint": null
            }
          ]
        }
      ]
    },
