                  {
                    "alias": "details",
                    "culture": null,
                    "editorAlias": null,
                    "segment": null,
                    "value": "These ancient witches failed to withstand Guardians in material space multiple times, but whether or not they ever died their final deaths within the Ascendant Plane is unknown."
                  },
                  {
                    "alias": "profilePicture",
                    "culture": null,
                    "editorAlias": null,
                    "segment": null,
                    "value": ""
