            }
          ]
        },
        {
          "alias": "characterName",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "Fallen Elders"
        },
        {
          "alias": "characterSource",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "Destiny"
        },
        {
          "alias": "details",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "The Fallen who recieved the largest rations of Ether would grow physically bigger and stronger than the others. These Eliksni would usually be the ones with the highest ranks within a Fallen House. Due to their greater rank, they would wear armor more durable than the smaller, weaker, and lesser of rank Eliksni would be allowed to. "
        },
        {
          "alias": "groupMembers",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": {
            "contentData": [
              {
                "contentTypeKey": "6f386c25-c5f7-4cc6-8761-a63a480078ba",
                "key": "85948e94-c591-4619-8ce5-d3411929c477",
                "udi": null,
                "values": [
                  {
                    "alias": "profilePicture",
                    "culture": null,
                    "editorAlias": null,
                    "segment": null,
                    "value": [
                      {
                        "key": "ac2b1703-7be4-4afd-abbc-bf74d1aab3b6",
                        "mediaKey": "8ba690c9-8416-4b7b-9cbd-ae5af93ceb91",
                        "mediaTypeAlias": "Image",
                        "crops": [],
                        "focalPoint": null
                      }
                    ]
                  },
                  {
                    "alias": "characterName",
                    "culture": null,
                    "editorAlias": null,
                    "segment": null,
                    "value": "Kalliks, Baron of House Dusk"
                  },
                  {
                    "alias": "characterSource",
                    "culture": null,
                    "editorAlias": null,
                    "segment": null,
                    "value": "Destiny 2: Episode Echoes"
                  },
                  {
                    "alias": "mainPicture",
                    "culture": null,
                    "editorAlias": null,
                    "segment": null,
                    "value": [
                      {
                        "key": "da46f036-cd1d-416f-b613-f68653f2d456",
                        "mediaKey": "f574c9f2-8497-478d-83ee-41526487f233",
                        "mediaTypeAlias": "Image",
                        "crops": [],
                        "focalPoint": null
                      }
                    ]
                  },
                  {
                    "alias": "details",
                    "culture": null,
                    "editorAlias": null,
                    "segment": null,
                    "value": "Kalliks is a rare example of a Baron having recieved sufficient Ether to reach a full-grown size. As a member of the House of Dusk, Kalliks had more resources available than typical Barons, and used them to take control of the surface of Nessus after the defeat of the Witness saw an artifact arrive there. His tactics allowed his forces to capture the local Vex for study, but the artifact had already been found by someone else. Kalliks was assaulted by a team of Guardians, and would send his massive army of Fallen at them as he retreated into the deeper parts of Nessus."
                  }
                ]
              },
              {
                "contentTypeKey": "6f386c25-c5f7-4cc6-8761-a63a480078ba",
                "key": "d63c585a-d734-40b5-a17b-3cd61094f770",
                "udi": null,
                "values": [
                  {
                    "alias": "profilePicture",
                    "culture": null,
                    "editorAlias": null,
                    "segment": null,
                    "value": [
                      {
                        "key": "d895f217-2f3d-4e70-9f18-d345ecfea2e1",
                        "mediaKey": "f4169b95-05a3-4cc5-8423-28dffdbb1108",
                        "mediaTypeAlias": "Image",
                        "crops": [],
                        "focalPoint": null
                      }
                    ]
                  },
                  {
                    "alias": "mainPicture",
                    "culture": null,
                    "editorAlias": null,
                    "segment": null,
                    "value": [
                      {
                        "key": "6c714ee7-5e0d-4009-80c2-69a596aaa1ac",
                        "mediaKey": "06bb37b6-0e66-4b44-884b-125f246b683c",
                        "mediaTypeAlias": "Image",
                        "crops": [],
                        "focalPoint": null
                      }
                    ]
                  },
                  {
                    "alias": "characterName",
                    "culture": null,
                    "editorAlias": null,
                    "segment": null,
                    "value": "Aksor, Archon Priest"
                  },
                  {
                    "alias": "characterSource",
                    "culture": null,
                    "editorAlias": null,
                    "segment": null,
                    "value": "Destiny"
                  },
                  {
                    "alias": "details",
                    "culture": null,
                    "editorAlias": null,
                    "segment": null,
                    "value": "Aksor was an Archon serving the Prime Servitor Kaliks Prime during the Reef Wars. As many others in the House of Wolves, once the war was over he was imprisoned in the Prison of Elders. After having lost their Archon, the House of Winter called upon Taniks, the Scarred. Draksis, the House of Winter\u0027s Kell, personally paid Taniks to infiltrate the prison and break Aksor out for him. The raid was successful, however as the Winters were preparing Aksor\u0027s release from the cryopod he was kept in, a Guardian fireteam attacked, and would face Aksor just as he exited the pod."
                  }
                ]
              },
              {
                "contentTypeKey": "6f386c25-c5f7-4cc6-8761-a63a480078ba",
                "key": "61e262fc-24b6-4df7-b50d-42309d61d1e7",
                "udi": null,
                "values": [
                  {
                    "alias": "profilePicture",
                    "culture": null,
                    "editorAlias": null,
                    "segment": null,
                    "value": [
                      {
                        "key": "cacd2aef-126e-45af-8ec3-028f21e88d03",
                        "mediaKey": "ee505dab-830f-4c4d-8592-51749d3a1f5f",
                        "mediaTypeAlias": "Image",
                        "crops": [],
                        "focalPoint": null
                      }
                    ]
                  },
                  {
                    "alias": "mainPicture",
                    "culture": null,
                    "editorAlias": null,
                    "segment": null,
                    "value": [
                      {
                        "key": "90c72061-2030-4adb-871d-37fd9b0dead1",
                        "mediaKey": "aa0835c6-6b44-4164-a91c-7355261e147f",
                        "mediaTypeAlias": "Image",
                        "crops": [],
                        "focalPoint": null
                      }
                    ]
                  },
                  {
                    "alias": "characterName",
                    "culture": null,
                    "editorAlias": null,
                    "segment": null,
                    "value": "Riksis, Devil Archon"
                  },
                  {
                    "alias": "characterSource",
                    "culture": null,
                    "editorAlias": null,
                    "segment": null,
                    "value": "Destiny"
                  },
                  {
                    "alias": "details",
                    "culture": null,
                    "editorAlias": null,
                    "segment": null,
                    "value": "Riksis was the Archon of the House of Devils, serving Sepiks Prime. He slew many newly risen Guardians in the Cosmodrome, and would take their skulls as trophies. Justice was given to the Last City however when a newly risen Guardian faced Riksis in single combat and managed to take him out. This Guardian would go on to slay Sepiks too, avenging their fallen brethren."
                  }
                ]
              },
              {
                "contentTypeKey": "6f386c25-c5f7-4cc6-8761-a63a480078ba",
                "key": "4f5bac85-6db5-4273-bcc3-596821737257",
                "udi": null,
                "values": [
                  {
                    "alias": "characterName",
                    "culture": null,
                    "editorAlias": null,
                    "segment": null,
                    "value": "Taniks, the Scarred"
                  },
                  {
                    "alias": "characterSource",
                    "culture": null,
                    "editorAlias": null,
                    "segment": null,
                    "value": "Destiny: House of Wolves"
                  },
                  {
                    "alias": "profilePicture",
                    "culture": null,
                    "editorAlias": null,
                    "segment": null,
                    "value": [
                      {
                        "key": "6ef9c52b-5f2f-4f8d-8967-ef2f0206ef14",
                        "mediaKey": "66619913-7cc5-4bad-a410-2579489e69e7",
                        "mediaTypeAlias": "Image",
                        "crops": [],
                        "focalPoint": null
                      }
                    ]
                  },
                  {
                    "alias": "mainPicture",
                    "culture": null,
                    "editorAlias": null,
                    "segment": null,
                    "value": [
                      {
                        "key": "715d912c-27a4-4dd6-b32b-2e8df54ff9a8",
                        "mediaKey": "15ad1f77-afc9-4666-8127-582d8ee8f603",
                        "mediaTypeAlias": "Image",
                        "crops": [],
                        "focalPoint": null
                      }
                    ]
                  },
                  {
                    "alias": "details",
                    "culture": null,
                    "editorAlias": null,
                    "segment": null,
                    "value": "Taniks killed his House\u0027s Kell and abandoned the idea of kneeling to a ruler, becoming a mercenary who would take jobs most mercenaries wouldn\u0027t dare. He became such a menace to the Last City that the Vanguard sent out a team to hunt him down and kill him. They succeeded, but not without losses. Taniks would however prove that the cybernetic enhancements he had given himself to become stronger had been a good investment. Taniks rose from the dead, as his mechanical parts could be repaired by his crewmates. With very little organic matter left in his body, he became extremely hard to permanently kill."
                  },
                  {
                    "alias": "characterVariant",
                    "culture": null,
                    "editorAlias": null,
                    "segment": null,
                    "value": "Scarred Mercenary"
                  }
                ]
              },
              {
                "contentTypeKey": "6f386c25-c5f7-4cc6-8761-a63a480078ba",
                "key": "8ef104b3-0ff2-4b6e-a1db-91c7c97cd160",
                "udi": null,
                "values": [
                  {
                    "alias": "profilePicture",
                    "culture": null,
                    "editorAlias": null,
                    "segment": null,
                    "value": [
                      {
                        "key": "361c5f5a-9500-4c48-84ef-50ae1048c5f9",
                        "mediaKey": "7b7be483-2d37-4a21-ad61-2e3621c18b4a",
                        "mediaTypeAlias": "Image",
                        "crops": [],
                        "focalPoint": null
                      }
                    ]
                  },
                  {
                    "alias": "mainPicture",
                    "culture": null,
                    "editorAlias": null,
                    "segment": null,
                    "value": [
                      {
                        "key": "ba4a96d3-6f82-41ad-94a4-c6e1587c035e",
                        "mediaKey": "601db79c-e9e2-4d9f-87a9-0ef92716519d",
                        "mediaTypeAlias": "Image",
                        "crops": [],
                        "focalPoint": null
                      }
                    ]
                  },
                  {
                    "alias": "characterSource",
                    "culture": null,
                    "editorAlias": null,
                    "segment": null,
                    "value": "Destiny"
                  },
                  {
                    "alias": "characterName",
                    "culture": null,
                    "editorAlias": null,
                    "segment": null,
                    "value": "Draksis, Winter Kell"
                  },
                  {
                    "alias": "details",
                    "culture": null,
                    "editorAlias": null,
                    "segment": null,
                    "value": "Draksis was the Kell of the House of Winter. His House ruled most of Venus, and were one of the largest threats to the Last City in the solar system. He was brave enough to dock his Ketch Wintership-Simiks-fel in the Ishtar Sink, where he would personally oversee his House\u0027s command over the Ishtar Collective\u0027s academy. He would often lead his troops from the frontline, but could otherwise be found atop his throne within his ship."
                  }
                ]
              },
              {
                "contentTypeKey": "6f386c25-c5f7-4cc6-8761-a63a480078ba",
                "key": "ef5690b3-1ec2-407b-bd7d-a4e80c21672b",
                "udi": null,
                "values": [
                  {
                    "alias": "profilePicture",
                    "culture": null,
                    "editorAlias": null,
                    "segment": null,
                    "value": [
                      {
                        "key": "54876f2c-e55f-44c0-9e7a-6643dba25b5b",
                        "mediaKey": "fd20a199-2706-4581-a164-d3186ba83580",
                        "mediaTypeAlias": "Image",
                        "crops": [],
                        "focalPoint": null
                      }
                    ]
                  },
                  {
                    "alias": "mainPicture",
                    "culture": null,
                    "editorAlias": null,
                    "segment": null,
                    "value": [
                      {
                        "key": "453dac34-814e-4d14-bcb0-dc65b84e791b",
                        "mediaKey": "931d29dc-1a32-4393-8214-fc6561d21e83",
                        "mediaTypeAlias": "Image",
                        "crops": [],
                        "focalPoint": null
                      }
                    ]
                  },
                  {
                    "alias": "characterName",
                    "culture": null,
                    "editorAlias": null,
                    "segment": null,
                    "value": "Skolas, Kell of Kells"
                  },
                  {
                    "alias": "characterTitle",
                    "culture": null,
                    "editorAlias": null,
                    "segment": null,
                    "value": "The Rabid, Kell of Wolves"
                  },
                  {
                    "alias": "characterVariant",
                    "culture": null,
                    "editorAlias": null,
                    "segment": null,
                    "value": ""
                  },
                  {
                    "alias": "characterSource",
                    "culture": null,
                    "editorAlias": null,
                    "segment": null,
                    "value": "Destiny: House of Wolves"
                  },
                  {
                    "alias": "details",
                    "culture": null,
                    "editorAlias": null,
                    "segment": null,
                    "value": "Skolas became the Kell of the House of Wolves during the Reef Wars, but would be captured by the Awoken and sent to the Prison of Elders. His House would become servants of their Awoken captors, and after an event manipulated by the Nine led to Skolas being free, the House would betray the Awoken, and flee together with Skolas. Skolas declared himself the \u0022Kell of Kells\u0022, a prophetic Kell who would unite all Fallen Houses under one banner. Skolas swayed most of the leaderless House of Winter to join him. He assaulted the Vault of Glass, and using its tech he would summon troops of his House from other timelines."
                  }
                ]
              }
            ],
