        },
        {
          "alias": "characterName",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "Drachna, Favored by Incaru"
        },
        {
          "alias": "characterSource",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "Destiny 2: Forsaken"
        },
        {
          "alias": "details",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "Drachna was a Darkblade who lead a group of other Darkblades. They tithed their tributes to him, and he was regarded as one of the strongest servants of D\u00FBl Incaru\u0027s broods. Every three weeks he returns from defeat due to Quria\u0027s time loop."
        },
        {
          "alias": "characterVariant",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "Material Space"
        }
      ]
    },
    {
      "contentTypeKey": "6f386c25-c5f7-4cc6-8761-a63a480078ba",
      "key": "43bf34d9-6801-4531-aa7e-824c475d456b",
