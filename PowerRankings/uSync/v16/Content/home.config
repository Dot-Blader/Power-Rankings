          "segment": null,
          "value": "Kranox, the Graven"
        },
        {
          "alias": "characterTitle",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "Keeper of Secrets"
        },
        {
          "alias": "characterVariant",
          "culture": null,
          "editorAlias": null,
