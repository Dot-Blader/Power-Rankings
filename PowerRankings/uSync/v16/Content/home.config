          "value": "Vandal"
        },
        {
          "alias": "characterSource",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "Destiny"
        },
        {
          "alias": "mainPicture",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": [
            {
              "key": "0ddbe77a-a524-494c-8f41-ff2a8ec62ae5",
              "mediaKey": "a53ddc90-a007-488a-a8e6-f153b33bbe78",
              "mediaTypeAlias": "Image",
              "crops": [],
              "focalPoint": null
            }
          ]
        },
        {
          "alias": "details",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "Vandals typically have stronger armor than Dregs. They make up the rank-and-file of a Fallen House, as far as honorable members go. They have a decent portion of Ether for consumption, and grow to a slightly larger and stronger size than Dregs."
        }
      ]
    },
    {
      "contentTypeKey": "6f386c25-c5f7-4cc6-8761-a63a480078ba",
      "key": "901a0cb1-3824-4ffc-bc9d-a41df9c0ed8a",
