          "segment": null,
          "value": "Cyber Sonic"
        },
        {
          "alias": "characterSource",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "SONIC FRONTIERS"
        },
        {
          "alias": "mainPicture",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": [
            {
              "key": "6990b0b2-6fb5-4ccf-a769-8f61dba2f203",
              "mediaKey": "e4fa3649-c976-4205-8d8d-0e4fde4e6135",
              "mediaTypeAlias": "Image",
              "crops": [],
              "focalPoint": null
            }
          ]
        },
        {
          "alias": "details",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "By ignoring the warnings of the Master King Koco and going all in with his Cyber-corruption, Super Sonic was enhanced with the full power of Cyber Energy. In this temporary and extremely unstable state Sonic was able to bring an end to THE END itself with a single attack. "
        },
        {
          "alias": "characterTitle",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "Fully Cyber-corrupted Super Sonic"
        }
      ]
    }
  ],
