          "segment": null,
          "value": "KNIGHT"
        },
        {
          "alias": "characterSource",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "Sonic Frontiers"
        },
        {
          "alias": "details",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "KNIGHT was armed with a sword and shield which, along with its body, had been enhanced by the power of the Chaos Emeralds. Tails noted that taking on this Titan would be difficult, even for Super Sonic."
        }
      ]
    },
    {
      "contentTypeKey": "6f386c25-c5f7-4cc6-8761-a63a480078ba",
