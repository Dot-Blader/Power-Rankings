                  },
                  {
                    "alias": "characterName",
                    "culture": null,
                    "editorAlias": null,
                    "segment": null,
                    "value": "Hands of Oryx"
                  },
                  {
                    "alias": "characterSource",
                    "culture": null,
                    "editorAlias": null,
                    "segment": null,
                    "value": "Destiny: The Taken King"
                  },
                  {
                    "alias": "details",
                    "culture": null,
                    "editorAlias": null,
                    "segment": null,
                    "value": "The Hands of Oryx were sent to Crota\u0027s Oversoul Throne when the Death Ceremony held there was interrupted by the Young Wolf. The Hands were about to end the Guardian\u0027s life when Eris Morn teleported them out of harm\u0027s way at the last second."
                  },
                  {
                    "alias": "groupMembers",
                    "culture": null,
                    "editorAlias": null,
                    "segment": null,
                    "value": {
                      "contentData": [
                        {
                          "contentTypeKey": "6f386c25-c5f7-4cc6-8761-a63a480078ba",
                          "key": "2c3ca361-422c-4016-93b6-05115a405ebe",
                          "udi": null,
                          "values": [
                            {
                              "alias": "characterVariant",
                              "culture": null,
