                        "focalPoint": null
                      }
                    ]
                  }
                ]
              },
              {
                "contentTypeKey": "6f386c25-c5f7-4cc6-8761-a63a480078ba",
                "key": "155d6b5d-3bb0-47c2-b160-aadea57d7b55",
                "udi": null,
                "values": [
                  {
                    "alias": "characterName",
                    "culture": null,
                    "editorAlias": null,
                    "segment": null,
                    "value": "Crota, Son of Oryx"
                  },
                  {
                    "alias": "characterSource",
                    "culture": null,
                    "editorAlias": null,
                    "segment": null,
                    "value": "Destiny: The Dark Below"
                  },
                  {
                    "alias": "profilePicture",
                    "culture": null,
                    "editorAlias": null,
                    "segment": null,
                    "value": [
                      {
                        "key": "35cc497f-f4ee-45fe-8334-e5e12d9ae15e",
                        "mediaKey": "0ade9649-d51b-4235-a06f-c9c016b246ef",
                        "mediaTypeAlias": "Image",
                        "crops": [],
                        "focalPoint": null
                      }
                    ]
                  },
                  {
                    "alias": "characterTitle",
                    "culture": null,
                    "editorAlias": null,
                    "segment": null,
                    "value": "The Hope-Eater, Prince of Annihilation"
                  },
                  {
                    "alias": "characterVariant",
                    "culture": null,
                    "editorAlias": null,
                    "segment": null,
                    "value": "Ascendant Plane"
                  },
                  {
                    "alias": "details",
                    "culture": null,
                    "editorAlias": null,
                    "segment": null,
                    "value": "Within his Throne World Crota was communing with oryx to plan their final assault on Earth. A fireteam of Guardians managed to breach the Throne World, and killed Ir Y\u00FBt, warranting Crota himself to emerge to fight them. After a legendary battle, the Lightbearers managed to bring Crota a final death by cutting him down with his own sword, a deed that reverberated throughout the universe."
                  },
                  {
                    "alias": "mainPicture",
                    "culture": null,
                    "editorAlias": null,
                    "segment": null,
                    "value": [
                      {
                        "key": "8ed93996-b90f-4ce3-aac2-2c5e0c9f8123",
                        "mediaKey": "b368b7ae-7e8e-4ed3-babc-34f00cdd8091",
                        "mediaTypeAlias": "Image",
                        "crops": [],
                        "focalPoint": null
                      }
                    ]
                  }
                ]
              },
              {
                "contentTypeKey": "6f386c25-c5f7-4cc6-8761-a63a480078ba",
                "key": "3fe52883-e59b-4a3f-aa43-8b939c91d6ae",
                "udi": null,
                "values": [
