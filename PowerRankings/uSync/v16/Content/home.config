        {
          "alias": "characterName",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "Egg Hammer"
        },
        {
          "alias": "characterSource",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "Sonic Heroes"
        },
        {
          "alias": "details",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "Egg Hammers were massive robots built by Doctor Eggman to defend key positions in the territories he had captured. They wielded massive hammers that they would swing with incredible force at Sonic and his friends, and were extremely durable. They required thirty strikes from Sonic to be brought down, however due to his superior brute strength Knuckles would usually take point in engagements with these massive robots."
        }
      ]
    },
