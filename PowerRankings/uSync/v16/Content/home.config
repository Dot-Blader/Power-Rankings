        {
          "alias": "characterName",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "Herald of Finality"
        },
        {
          "alias": "characterSource",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "Destiny 2: The Final Shape"
        },
        {
          "alias": "details",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "The Herald of Finality was a Taken Captain assigned by the Witness to act as the final line of defense for the monolith where the Witness was enacting the Final Shape. In order to ensure that any intruders were destroyed, the Herald was imbued with the powers of the fallen Disciples of the Witness."
        },
        {
          "alias": "energyExponent",
          "culture": null,
          "editorAlias": null,
