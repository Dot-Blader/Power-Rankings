                    "value": "Material Space"
                  },
                  {
                    "alias": "details",
                    "culture": null,
                    "editorAlias": null,
                    "segment": null,
                    "value": "The Warpriest was a member of Oryx\u0027s Court, and one of the most powerful Hive Knights in the universe. He had tasked himself with assisting Oryx with conquests and slaughter so well that one day Oryx wouldn\u0027t need to take time away from his work to reach the Final Shape."
                  },
                  {
                    "alias": "characterSource",
                    "culture": null,
                    "editorAlias": null,
                    "segment": null,
                    "value": "Destiny: The Taken King"
                  }
                ]
