        },
        {
          "alias": "characterName",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "Zo\u0027aurc, Explicator of Planets"
        },
        {
          "alias": "characterSource",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "Destiny 2: Lightfall"
        },
        {
          "alias": "profilePicture",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": [
            {
              "key": "563185aa-6572-4644-9342-75d97f64f1b7",
              "mediaKey": "39e27521-9baa-407d-a326-c4699a2405fd",
              "mediaTypeAlias": "Image",
              "crops": [],
              "focalPoint": null
            }
          ]
        },
        {
          "alias": "mainPicture",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": [
            {
              "key": "e86f6bb0-5aa6-4c1a-8115-bddfa5228886",
              "mediaKey": "b5507332-90a0-415b-9f22-a14b4cc898e9",
              "mediaTypeAlias": "Image",
              "crops": [],
              "focalPoint": null
            }
          ]
        },
        {
          "alias": "details",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "Zo\u0027aurc was an Incendior of the Shadow Legion placed in the Witness\u0027s personal Pyramid Ship Essence. He was assigned to inspect the planets that the Witness had Taken, scanning and searching them for information of interest to the Witness. When assaulted by invaders, he could use the Pyramid Ship\u0027s systems to detonate any planet available, annihilating the threat. He had enhanced his own armor with both the Resonance of the Pyramid-technology from Essence, and the Light from the Traveler\u0027s growing roots."
        }
      ]
    },
    {
      "contentTypeKey": "6f386c25-c5f7-4cc6-8761-a63a480078ba",
      "key": "e85ca114-9b7b-461a-8c22-4978ac1960c7",
