        {
          "alias": "characterName",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "Warden Vincu\u0027us"
        },
        {
          "alias": "characterSource",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "Destiny 2: Season of Defiance"
        },
        {
          "alias": "details",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "Vincu\u0027us was the warden of the Pyramidial prison complex established in the EDZ by the Shadow Legion. Within the structure he utilized two standard Cruxes of Darkness and one larger sized Crux to enhance his shielding and weapons with their Darkness. He was guarding a set of human prisoners as a fireteam of Guardians of the Last City arrived to the rescue, and he engaged the Lightbearers directly once they breached the prison\u0027s defenses."
        },
        {
          "alias": "energyExponent",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "25"
        },
