        {
          "alias": "characterName",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "Dolgith, Blade of Reasoning"
        },
        {
          "alias": "characterSource",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "Destiny 2: The Final Shape"
        },
        {
          "alias": "details",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "Dolgith was a powerful Taken Ogre that commanded a group of Ascendant Darkblades in the Pale Heart. It was employed by the Witness to cut the Young Wolf out of existence if they refused to reason with the Witness. Through the use of the Aegis granted to the Young Wolf by the Traveler itself, Dolgith would be brought down and returned to the Ascendant Plane."
        },
        {
          "alias": "characterVariant",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "Pale Heart"
        },
