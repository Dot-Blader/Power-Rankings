        },
        {
          "alias": "characterName",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "Marauder"
        },
        {
          "alias": "characterSource",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "Destiny 2"
        },
        {
          "alias": "details",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "Marauders are Vandals that specialize in stealth. Before the Red War they were similar to regular Vandals except for their cloaking technology and preference for close-ranged Shock Blades, but during the rise of the House of Dusk most Marauders started donning helmets with more optical sensors than they needed. This was because the Eliksni find that more eyes on a person makes them more attractive. For Marauders, it also makes them more intimidating to enemies who catch a glimpse of them without their stealth-tech active."
        }
      ]
    },
    {
      "contentTypeKey": "6f386c25-c5f7-4cc6-8761-a63a480078ba",
      "key": "c663a403-7804-4038-8940-a500902dabaf",
