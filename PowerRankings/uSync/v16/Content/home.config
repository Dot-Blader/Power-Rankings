                  {
                    "alias": "characterTitle",
                    "culture": null,
                    "editorAlias": null,
                    "segment": null,
                    "value": "The Hope-Eater, Prince of Annihilation"
                  },
                  {
                    "alias": "characterVariant",
                    "culture": null,
                    "editorAlias": null,
                    "segment": null,
                    "value": "Material Space"
                  },
                  {
                    "alias": "details",
                    "culture": null,
                    "editorAlias": null,
                    "segment": null,
                    "value": "Crota was the firstborn son of Oryx, and the most powerful member of the Court of Oryx. As a Hive Knight, Crota had fought to become a legendary demon, wielding a sword that could drain the Light from anyone it touched. He would use this to slay thousands of Guardians during the Great Disaster, and would scar humanity forever through his actions."
                  },
                  {
                    "alias": "mainPicture",
                    "culture": null,
                    "editorAlias": null,
                    "segment": null,
