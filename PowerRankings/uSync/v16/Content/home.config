        {
          "alias": "characterName",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "Swarm Princes"
        },
        {
          "alias": "characterTitle",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "Royalty of Nightmare"
        },
        {
          "alias": "characterVariant",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "Material Space"
        },
        {
          "alias": "characterSource",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "Destiny"
        },
        {
          "alias": "details",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "The Swarm Princes were four Ascendant Knights leading the Hidden Swarm. They each represented one of the four remaining Worm Gods, and together had created the legendary sword Light-Eater. They worked as Generals to the Fist of Crota, Sardon. "
        },
        {
          "alias": "groupMembers",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": {
            "contentData": [
              {
                "contentTypeKey": "6f386c25-c5f7-4cc6-8761-a63a480078ba",
                "key": "c62b0669-678a-493b-9a75-dd7772cfe345",
                "udi": null,
                "values": [
