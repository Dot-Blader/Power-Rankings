                    "editorAlias": null,
                    "segment": null,
                    "value": "Destiny 2: Season of the Lost"
                  },
                  {
                    "alias": "characterName",
                    "culture": null,
                    "editorAlias": null,
                    "segment": null,
                    "value": "Kelgorath, Risen from Bones"
                  },
                  {
                    "alias": "characterTitle",
                    "culture": null,
                    "editorAlias": null,
                    "segment": null,
                    "value": "Knight Champion of Death"
                  },
                  {
                    "alias": "details",
                    "culture": null,
                    "editorAlias": null,
                    "segment": null,
                    "value": "Kelgorath was a Hive Knight who Xivu Arath believed could grow stronger by learning about the tactics and skills of the Young Wolf through repeated engagements. He would face them multiple times, and indeed become Ascendant in time. In his Ascendant form Kelgorath led Xivu\u0027s forces during their assault on the exorcism of Savath\u00FBn\u0027s worm."
                  },
                  {
                    "alias": "characterVariant",
                    "culture": null,
                    "editorAlias": null,
                    "segment": null,
                    "value": "Material Space"
                  }
                ]
              },
              {
                "contentTypeKey": "6f386c25-c5f7-4cc6-8761-a63a480078ba",
