        },
        {
          "alias": "profilePicture",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": [
            {
              "key": "25941320-61ab-465f-807a-5588d99414c3",
              "mediaKey": "562c6bf2-6cc6-4dcc-9994-87d4b93dfca4",
              "mediaTypeAlias": "Image",
              "crops": [],
              "focalPoint": null
            }
          ]
        },
        {
          "alias": "characterName",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "Prime Servitors"
        },
        {
          "alias": "details",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "Each House of the Fallen has a Prime Servitor, which supplies most of the House\u0027s needed Ether. Due to their reliance on Ether to survive, the Fallen worship these machines as Gods. Archon\u0027s act as mechanics and servants of their Prime Servitors, and make sure that the armored hulls of their Machine-Gods are up to their divine standards."
        },
        {
          "alias": "characterSource",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "Destiny"
        },
        {
          "alias": "characterTitle",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "Machine-Gods"
        },
        {
          "alias": "groupMembers",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": {
            "contentData": [
              {
                "contentTypeKey": "6f386c25-c5f7-4cc6-8761-a63a480078ba",
                "key": "169c56fa-afd6-44bf-8cdc-37b4b033b814",
                "udi": null,
                "values": [
                  {
                    "alias": "profilePicture",
                    "culture": null,
                    "editorAlias": null,
                    "segment": null,
                    "value": [
                      {
                        "key": "a02498a1-7771-42e9-a5ea-489b90fbf4dc",
                        "mediaKey": "603ced41-d526-44de-96e9-8d1a004a1aae",
                        "mediaTypeAlias": "Image",
                        "crops": [],
                        "focalPoint": null
                      }
                    ]
                  },
                  {
                    "alias": "characterName",
                    "culture": null,
                    "editorAlias": null,
                    "segment": null,
                    "value": "Yamiks Prime"
                  },
                  {
                    "alias": "characterSource",
                    "culture": null,
                    "editorAlias": null,
                    "segment": null,
                    "value": "Destiny 2: Beyond Light"
                  },
                  {
                    "alias": "mainPicture",
                    "culture": null,
                    "editorAlias": null,
                    "segment": null,
                    "value": [
                      {
                        "key": "39e5d4c6-cb18-4897-bb22-b560a2a84493",
                        "mediaKey": "dbdb5bd9-2255-4c55-8405-ee143d7cd2c7",
                        "mediaTypeAlias": "Image",
                        "crops": [],
                        "focalPoint": null
                      }
                    ]
                  },
                  {
                    "alias": "details",
                    "culture": null,
                    "editorAlias": null,
                    "segment": null,
                    "value": "As the Prime Servitor of House of Salvation, Yamiks was not treated with the same kind of worship as other Primes. The House of Salvation sought to end the Fallen\u0027s reliance on Servitors through technology derived from the Black Fleet. Yamiks was served by Kridis, the Dark Priestess who spent more time studying the Darkness than serving her Machine-God."
                  }
                ]
              },
              {
                "contentTypeKey": "6f386c25-c5f7-4cc6-8761-a63a480078ba",
                "key": "70ba399c-5c14-41f7-ae71-686a8b340b3a",
                "udi": null,
                "values": [
                  {
                    "alias": "profilePicture",
                    "culture": null,
                    "editorAlias": null,
                    "segment": null,
                    "value": [
                      {
                        "key": "600d666d-0f16-47e4-b8ae-36d6aa0df8e4",
                        "mediaKey": "7aa5e434-69b7-4079-a4f0-ff5b974faa35",
                        "mediaTypeAlias": "Image",
                        "crops": [],
                        "focalPoint": null
                      }
                    ]
                  },
                  {
                    "alias": "mainPicture",
                    "culture": null,
                    "editorAlias": null,
                    "segment": null,
                    "value": [
                      {
                        "key": "ef0f45d2-3e0a-4aa4-88fc-9f469ddbaf72",
                        "mediaKey": "07607782-8b68-4a45-aae0-855d1b16f335",
                        "mediaTypeAlias": "Image",
                        "crops": [],
                        "focalPoint": null
                      }
                    ]
                  },
                  {
                    "alias": "characterName",
                    "culture": null,
                    "editorAlias": null,
                    "segment": null,
                    "value": "Orbiks Prime"
                  },
                  {
                    "alias": "characterSource",
                    "culture": null,
                    "editorAlias": null,
                    "segment": null,
                    "value": "Destiny: The Taken King"
                  },
                  {
                    "alias": "details",
                    "culture": null,
                    "editorAlias": null,
                    "segment": null,
                    "value": "Orbiks Prime was a Servitor of the House of Wolves. It was originally destroyed, but in their desperation during the Taken War, the remnants of the House of Wolves used the remains of Orbiks to rebuild it. With the strength of Orbiks Prime at their backs, the Wolves managed to secure a foothold inside a Cabal base. There Orbiks would launch waves of servants at the Cabal, and any others who tried to get them out."
                  }
                ]
              },
              {
                "contentTypeKey": "6f386c25-c5f7-4cc6-8761-a63a480078ba",
                "key": "e739d1eb-1581-4e63-ba69-e51adb22c7ba",
                "udi": null,
                "values": [
                  {
                    "alias": "profilePicture",
                    "culture": null,
                    "editorAlias": null,
                    "segment": null,
                    "value": [
                      {
                        "key": "d2823f81-4da2-401d-b3dc-8e9cddd3cbf2",
                        "mediaKey": "14bb622d-945f-4426-ad37-871033036aed",
                        "mediaTypeAlias": "Image",
                        "crops": [],
                        "focalPoint": null
                      }
                    ]
                  },
                  {
                    "alias": "mainPicture",
                    "culture": null,
                    "editorAlias": null,
                    "segment": null,
                    "value": [
                      {
                        "key": "5d491996-1b91-44a1-be62-c5994f8454a0",
                        "mediaKey": "51db2c8a-c7fb-4a0a-a3f1-bd82257fe1d6",
                        "mediaTypeAlias": "Image",
                        "crops": [],
                        "focalPoint": null
                      }
                    ]
                  },
                  {
                    "alias": "characterName",
                    "culture": null,
                    "editorAlias": null,
                    "segment": null,
                    "value": "Sepiks Prime"
                  },
                  {
                    "alias": "characterSource",
                    "culture": null,
                    "editorAlias": null,
                    "segment": null,
                    "value": "Destiny"
                  },
                  {
                    "alias": "details",
                    "culture": null,
                    "editorAlias": null,
                    "segment": null,
                    "value": "Sepiks Prime was the Prime Servitor of the House of Devils. After the loss of the Devil Kell Solkis to Saint-14, Sepiks was temporarily in charge of the House until a new Kell could be assigned. Craask, Kell of Kings, then took control of the House of Devils, using Sepiks as a sort of puppet leader. To the members of the House of Devils, Sepiks was a true God, and they would offer tributes to it by giving material to its Archon Riksis. "
                  }
                ]
              },
              {
                "contentTypeKey": "6f386c25-c5f7-4cc6-8761-a63a480078ba",
                "key": "22ee822f-0274-4ce1-b523-5ebf1a7fedaf",
                "udi": null,
                "values": [
                  {
                    "alias": "characterName",
                    "culture": null,
                    "editorAlias": null,
                    "segment": null,
                    "value": "Kaliks Reborn"
                  },
                  {
                    "alias": "characterSource",
                    "culture": null,
                    "editorAlias": null,
                    "segment": null,
                    "value": "Destiny: House of Wolves"
                  },
                  {
                    "alias": "profilePicture",
                    "culture": null,
                    "editorAlias": null,
                    "segment": null,
                    "value": [
                      {
                        "key": "f42019ca-c393-4bd8-948b-253baf96872d",
                        "mediaKey": "8a84ced0-96bb-4323-b146-ea6926377ce2",
                        "mediaTypeAlias": "Image",
                        "crops": [],
                        "focalPoint": null
                      }
                    ]
                  },
                  {
                    "alias": "mainPicture",
                    "culture": null,
                    "editorAlias": null,
                    "segment": null,
                    "value": [
                      {
                        "key": "9a382672-2aaf-4a03-a78d-d94927b77be7",
                        "mediaKey": "e7b416de-8b3d-4e16-88a9-f2080dd4039a",
                        "mediaTypeAlias": "Image",
                        "crops": [],
                        "focalPoint": null
                      }
                    ]
                  },
                  {
                    "alias": "details",
                    "culture": null,
                    "editorAlias": null,
                    "segment": null,
                    "value": "Kaliks Prime was a Prime Servitor of the House of Wolves. It was lost mysteriously however, and in the Prison of Elders those of the House of Wolves who still needed a Prime to worship rebuilt Kaliks from parts of lesser Servitors. Due to not having used any parts from the original, they couldn\u0027t name it Kaliks Prime and instead used the term \u0022Reborn\u0022 to describe this new copy."
                  }
                ]
              },
              {
                "contentTypeKey": "6f386c25-c5f7-4cc6-8761-a63a480078ba",
                "key": "e7a59197-4342-49c3-b690-2184cbe11b64",
                "udi": null,
                "values": [
                  {
                    "alias": "profilePicture",
                    "culture": null,
