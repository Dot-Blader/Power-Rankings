              },
              {
                "contentTypeKey": "6f386c25-c5f7-4cc6-8761-a63a480078ba",
                "key": "e7be74fc-9c32-4896-8bb0-9a62b57cc1c0",
                "udi": null,
                "values": [
                  {
                    "alias": "details",
                    "culture": null,
                    "editorAlias": null,
                    "segment": null,
                    "value": "D\u00FBl Incaru attempted to breach the Awoken home dimension known as \u0022The Distributary\u0022 through the shattered Throne World Eleusinia. She positioned herself atop a massive tower, and had Taken of Quria positioned all throughout the Throne World in order to assume control over it and to protect her from intruders. After being defeated by a fireteam of Guardians, a time loop created by Quria was started, which would loop the events of the last three weeks leading up to Incaru\u0027s death over and over again, with Incaru herself always returning and being slain at the end of each cycle. This allows her to keep searching for the way into the Distributary forever."
                  },
                  {
                    "alias": "profilePicture",
                    "culture": null,
                    "editorAlias": null,
                    "segment": null,
                    "value": [
                      {
                        "key": "04606cec-8937-4a6a-a571-86cb7e377628",
