                    ]
                  },
                  {
                    "alias": "characterName",
                    "culture": null,
                    "editorAlias": null,
                    "segment": null,
                    "value": "Kargen, the Technocrat"
                  },
                  {
                    "alias": "characterTitle",
                    "culture": null,
                    "editorAlias": null,
                    "segment": null,
                    "value": "Psion Flayer"
                  },
                  {
                    "alias": "characterSource",
                    "culture": null,
                    "editorAlias": null,
                    "segment": null,
                    "value": "Destiny 2: Warmind"
                  },
                  {
                    "alias": "details",
                    "culture": null,
                    "editorAlias": null,
                    "segment": null,
                    "value": "Kargen was a unified set of Psion Flayers. He and his crew of Cabal pillaged Vex artifacts from various installations across the solar system. His fascination with the Vex would lead to him using his power and intellect to breach the Vex Gate Network, and would use it to summon troops into battle against the Guardians of the Last City."
                  },
                  {
                    "alias": "mainPicture",
                    "culture": null,
                    "editorAlias": null,
                    "segment": null,
                    "value": [
                      {
                        "key": "5524ae6c-e2ef-48be-a5bf-6b102bea84dd",
                        "mediaKey": "8e10168c-6d63-4de1-bcb9-47214fa5d148",
                        "mediaTypeAlias": "Image",
                        "crops": [],
                        "focalPoint": null
                      }
                    ]
