                    ]
                  },
                  {
                    "alias": "characterSource",
                    "culture": null,
                    "editorAlias": null,
                    "segment": null,
                    "value": "Destiny"
                  },
                  {
                    "alias": "details",
                    "culture": null,
                    "editorAlias": null,
                    "segment": null,
                    "value": "Telthor was an Ogre who was placed in the Chamber of Night. His purpose was to guard the ritual where the Hive were draining the Traveler of its Light through one of its shards. If he had succeeded in defending the place from the Guardian of the Last City who attacked, he would have gotten to receive a Summoning Ritual."
                  }
                ]
              },
              {
                "contentTypeKey": "6f386c25-c5f7-4cc6-8761-a63a480078ba",
                "key": "ddcedaca-e951-47e1-bb0d-df7b8805ec24",
