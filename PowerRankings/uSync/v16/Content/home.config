          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "Egg Mobile"
        },
        {
          "alias": "profilePicture",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": [
            {
              "key": "5b77e816-ccb6-4588-96f3-a609ebdd03a6",
              "mediaKey": "84907853-2275-4699-954a-367f56bbe94c",
              "mediaTypeAlias": "Image",
