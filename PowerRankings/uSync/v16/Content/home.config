                    "value": "Destiny 2: Season of Defiance"
                  },
                  {
                    "alias": "details",
                    "culture": null,
                    "editorAlias": null,
                    "segment": null,
                    "value": "Baimogg was a Chimera, a Taken Servitor, serving the Shadow Legion during their assault on Earth. Baimogg assisted Gor\u0027ath Gath in spreading Blight throughout the European Dead Zone. "
                  }
                ]
              },
              {
                "contentTypeKey": "6f386c25-c5f7-4cc6-8761-a63a480078ba",
                "key": "4707ca67-60b4-4d2f-9d48-4b0f52828a8f",
                "udi": null,
                "values": [
                  {
                    "alias": "details",
                    "culture": null,
                    "editorAlias": null,
                    "segment": null,
                    "value": "Exomida was originally a Servitor that was Taken by the Witness. It was moved out of material space and stationed within the Ascendant Plane during the Shadow Legion\u0027s assault on Earth."
                  },
                  {
                    "alias": "characterName",
                    "culture": null,
                    "editorAlias": null,
                    "segment": null,
                    "value": "Exomida, Taken of the Witness"
                  },
                  {
                    "alias": "characterVariant",
