                  {
                    "alias": "characterName",
                    "culture": null,
                    "editorAlias": null,
                    "segment": null,
                    "value": "Herd"
                  },
                  {
                    "alias": "characterVariant",
                    "culture": null,
                    "editorAlias": null,
                    "segment": null,
                    "value": "Candy Factory Worker"
                  },
                  {
                    "alias": "characterSource",
                    "culture": null,
                    "editorAlias": null,
                    "segment": null,
                    "value": "Little Nightmares 3"
                  },
                  {
                    "alias": "details",
                    "culture": null,
                    "editorAlias": null,
                    "segment": null,
                    "value": "The members of the Herd who work in the Candy Factory are carried into the facility hanging from lines like cows being herded into a slaughter house. It seems like on top of handling the machinery that produces candy, those who die from the poor working conditions end up being used as ingredients for the next batch of candy."
                  }
                ]
              },
              {
                "contentTypeKey": "6f386c25-c5f7-4cc6-8761-a63a480078ba",
                "key": "4b21675f-a9e2-48b8-b245-51d11b8c6457",
                "udi": null,
                "values": [
                  {
                    "alias": "characterName",
                    "culture": null,
                    "editorAlias": null,
                    "segment": null,
                    "value": "Herd"
                  },
                  {
                    "alias": "profilePicture",
                    "culture": null,
                    "editorAlias": null,
                    "segment": null,
                    "value": [
                      {
                        "key": "20b16b39-f9db-49e0-9411-896071528db7",
                        "mediaKey": "58094d05-4f3f-4555-b192-62c71d37e5a9",
