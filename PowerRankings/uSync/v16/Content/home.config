                  {
                    "alias": "characterVariant",
                    "culture": null,
                    "editorAlias": null,
                    "segment": null,
                    "value": "Material Space"
                  },
                  {
                    "alias": "details",
                    "culture": null,
                    "editorAlias": null,
                    "segment": null,
                    "value": "Krughor, also known as Kraghoor, was a Hive Ogre and the first being to be placed in the Court of Oryx. Krughor\u0027s death had been hidden in the curses of his accursed followers by Savath\u00FBn. Krughor lead the attack on the Taishibethi worlds and blighted them with his armies of cursed Thrall."
                  },
                  {
                    "alias": "mainPicture",
                    "culture": null,
                    "editorAlias": null,
                    "segment": null,
                    "value": [
                      {
                        "key": "b27ddfe7-78d6-4563-80a6-9885f173f43b",
