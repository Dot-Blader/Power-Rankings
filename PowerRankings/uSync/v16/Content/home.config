                  {
                    "alias": "characterVariant",
                    "culture": null,
                    "editorAlias": null,
                    "segment": null,
                    "value": "Material Space"
                  },
                  {
                    "alias": "details",
                    "culture": null,
                    "editorAlias": null,
                    "segment": null,
                    "value": "Ecthar was a Hive Knight and member of the Court of Oryx. He represented the Sword Logic that all Hive under Oryx believed in, and would watch over the Silent Brood in the Dreadnaught\u0027s prison areas as they rendered Oryx\u0027s enemies down into chitin, reduced to a mere material in accordance with the Sword Logic."
                  },
                  {
                    "alias": "mainPicture",
                    "culture": null,
                    "editorAlias": null,
