        {
          "alias": "characterSource",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "Destiny 2"
        },
        {
          "alias": "details",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "The weakest Eliksni tend to choose a more aggressive fighting style than others, choosing to wield Arc-charged spears that can cut through anything. They have a weaker exoskeleton than Dregs, relying on their swiftness for survival."
        }
      ]
    },
    {
      "contentTypeKey": "6f386c25-c5f7-4cc6-8761-a63a480078ba",
      "key": "43070659-1d85-4e9c-8bd6-f9ef583d7937",
