                              "segment": null,
                              "value": "Phogoth, the Untamed"
                            },
                            {
                              "alias": "characterTitle",
                              "culture": null,
                              "editorAlias": null,
                              "segment": null,
                              "value": "Hive Abomination"
                            },
                            {
                              "alias": "characterVariant",
                              "culture": null,
                              "editorAlias": null,
                              "segment": null,
                              "value": "Material Space"
                            },
                            {
                              "alias": "characterSource",
                              "culture": null,
                              "editorAlias": null,
                              "segment": null,
                              "value": "Destiny"
                            },
                            {
                              "alias": "details",
                              "culture": null,
                              "editorAlias": null,
                              "segment": null,
                              "value": "Phogoth was a powerful Ogre Summoned to be a new champion for Crota. After the ritual, Phogoth became extremely violent, and was chained by the Hive in an attempt to keep him in place. A fireteam of Guardians found Phogoth, and as he sensed their Light he was unleashed in a furious rage. He broke out of his chains and engaged the Guardians aggressively."
                            }
                          ]
                        },
