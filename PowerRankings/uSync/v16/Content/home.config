        },
        {
          "alias": "characterVariant",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "Material Space"
        },
        {
          "alias": "details",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "The Court of Oryx consisted of Oryx\u0027s most powerful servants. They accomplished many things throughout history, exterminating entire civilizations such as the Taishibethi. They even brought down the Gift Mast, a structure made by the Traveler out of a black hole\u0027s polar jet, tens of thousands of lightyears long. Billions of years of growth and conquest made the Court\u0027s members grow extremely powerful."
        },
        {
          "alias": "profilePicture",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": [
            {
              "key": "89825e9c-ed5e-465c-9095-80b35212e629",
