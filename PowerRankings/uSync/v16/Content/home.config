                  },
                  {
                    "alias": "details",
                    "culture": null,
                    "editorAlias": null,
                    "segment": null,
                    "value": "Urrox was a Prince of the Hive who led a brood of Hive that was lost to time. He was incarcerated in the Prison of Elders, and would stay alive there through the destruction of daring challengers. He wielded a unique ability to set his surroundings ablaze in a fire burning with his dark power."
                  },
                  {
                    "alias": "characterTitle",
                    "culture": null,
                    "editorAlias": null,
                    "segment": null,
                    "value": "Scion of Oryx"
                  }
                ]
              },
