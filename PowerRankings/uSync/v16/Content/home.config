                    "culture": null,
                    "editorAlias": null,
                    "segment": null,
                    "value": "Kelgorath, Risen from Bones"
                  },
                  {
                    "alias": "characterTitle",
                    "culture": null,
                    "editorAlias": null,
                    "segment": null,
                    "value": "Knight Champion of Death"
                  },
                  {
                    "alias": "characterVariant",
                    "culture": null,
                    "editorAlias": null,
                    "segment": null,
                    "value": "Ascendant Plane"
                  },
                  {
                    "alias": "characterSource",
                    "culture": null,
                    "editorAlias": null,
                    "segment": null,
                    "value": "Destiny 2: Season of the Lost"
                  },
                  {
                    "alias": "details",
                    "culture": null,
                    "editorAlias": null,
                    "segment": null,
                    "value": "Kelgorath would be reborn after his defeat in material space just like all other times he died and came back. Exactly how this process occured is unclear, but after reaching Ascendant strength its possible his soul survived inside his Throne World."
                  }
                ]
              },
