          "segment": null,
          "value": "THE END"
        },
        {
          "alias": "mainPicture",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": [
            {
              "key": "92dd0738-13ff-4805-934f-cbc437827763",
              "mediaKey": "e415726f-afcb-493b-b8ee-f22dd3beaa64",
              "mediaTypeAlias": "Image",
              "crops": [],
              "focalPoint": null
            }
          ]
        },
        {
          "alias": "characterSource",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "SONIC FRONTIERS"
        },
        {
          "alias": "details",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "THE END was a being of untold origin and design. It appeared to lower-dimensional beings as a small purple moon due to their inability to comprehend its actual appearance. At its full strength it was more powerful than the 8-Dimensional strength that the four Chaos Emerald-enhanced Titans could present when fighting together, and described itself as infinite in comparison to the \u0022finite\u0022 beings and machines Sonic had faced before."
        }
      ]
    },
    {
      "contentTypeKey": "6f386c25-c5f7-4cc6-8761-a63a480078ba",
      "key": "e751b846-2bf4-4089-9e3f-7e34789c02b7",
