                    "editorAlias": null,
                    "segment": null,
                    "value": "Summoned Ogres"
                  },
                  {
                    "alias": "characterSource",
                    "culture": null,
                    "editorAlias": null,
                    "segment": null,
                    "value": "Destiny"
                  },
                  {
                    "alias": "details",
                    "culture": null,
                    "editorAlias": null,
                    "segment": null,
                    "value": "After succeeding in a test, an Unborn Ogre can receive a Summoning Ritual. This ritual focuses their rage, and enhances their power to Ascendancy. "
                  },
                  {
                    "alias": "characterVariant",
                    "culture": null,
