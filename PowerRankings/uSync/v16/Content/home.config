          "value": "SPIDER"
        },
        {
          "alias": "characterSource",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "Sonic Frontiers"
        },
        {
          "alias": "details",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "SPIDERs were advanced robots built by the Ancients. They would use their massive legs to stomp enemies, and could fling enemies incredible distances by using the suspension of their highly mobile legs."
        }
      ]
    },
    {
      "contentTypeKey": "6f386c25-c5f7-4cc6-8761-a63a480078ba",
