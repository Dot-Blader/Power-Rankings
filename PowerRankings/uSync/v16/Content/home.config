                    "segment": null,
                    "value": [
                      {
                        "key": "c997dda6-c7e7-4414-a197-bef5636fb9c6",
                        "mediaKey": "4bc8739b-13fd-4f69-b21d-41b0cfa420c9",
                        "mediaTypeAlias": "Image",
                        "crops": [],
                        "focalPoint": null
                      }
                    ]
                  },
                  {
                    "alias": "mainPicture",
                    "culture": null,
                    "editorAlias": null,
                    "segment": null,
                    "value": [
                      {
                        "key": "ae61f927-7bc4-4872-9f7e-6531caa7290a",
                        "mediaKey": "c52e79f1-bff3-4418-a6d7-757e2dce088b",
                        "mediaTypeAlias": "Image",
                        "crops": [],
                        "focalPoint": null
                      }
                    ]
                  },
                  {
                    "alias": "characterName",
                    "culture": null,
                    "editorAlias": null,
                    "segment": null,
                    "value": "Kar\u0027uul, Indomitable Champion"
                  },
                  {
                    "alias": "characterSource",
                    "culture": null,
                    "editorAlias": null,
                    "segment": null,
                    "value": "Destiny 2: Lightfall"
                  },
                  {
                    "alias": "details",
                    "culture": null,
                    "editorAlias": null,
                    "segment": null,
                    "value": "Kar\u0027uul was sent to fight against the Young Wolf after Garaask fell in battle against them. He was considered an even stronger champion, having enhanced his already durable Colossus armor with Pyramid-tech. Even with this paracausal power however, he would be slain."
                  }
                ]
              },
              {
                "contentTypeKey": "6f386c25-c5f7-4cc6-8761-a63a480078ba",
                "key": "9e7d7ad9-d862-4fab-a9b3-93076f5763b4",
                "udi": null,
                "values": [
                  {
                    "alias": "profilePicture",
                    "culture": null,
                    "editorAlias": null,
                    "segment": null,
                    "value": [
                      {
                        "key": "e9ebd50c-9ba1-4bf4-b2b3-f4a536102329",
                        "mediaKey": "1b03dc13-1476-4d49-8264-d559b214b309",
                        "mediaTypeAlias": "Image",
                        "crops": [],
                        "focalPoint": null
                      }
                    ]
                  },
                  {
                    "alias": "mainPicture",
                    "culture": null,
                    "editorAlias": null,
                    "segment": null,
                    "value": [
                      {
                        "key": "f72f084d-f033-47d0-9822-066d1bd452f9",
                        "mediaKey": "ebeff055-28da-45b5-a68d-dd8cc27266a1",
                        "mediaTypeAlias": "Image",
                        "crops": [],
                        "focalPoint": null
                      }
                    ]
                  },
                  {
                    "alias": "characterSource",
                    "culture": null,
                    "editorAlias": null,
                    "segment": null,
                    "value": "Destiny 2: Lightfall"
                  },
                  {
                    "alias": "characterName",
                    "culture": null,
                    "editorAlias": null,
                    "segment": null,
                    "value": "Val Bho\u0027kaurl"
                  },
                  {
                    "alias": "details",
                    "culture": null,
                    "editorAlias": null,
                    "segment": null,
                    "value": "Val Bho\u0027kaurl was the strongest champion Calus had available to throw at the Young Wolf during their attempt to destroy the Radial Mast. His strength was so great that the Guardian was unable to penetrate his shield with their Light. He would be deployed to the Irkalla Complex to link the Radial Mast with the Veil, and nearly defeated the Young Wolf. He was unraveled by the newly discovered Darkness power Strand at the hands of the Guardian, proving that the Slayer of Oryx truly was mightier in the end."
                  }
                ]
              },
              {
                "contentTypeKey": "6f386c25-c5f7-4cc6-8761-a63a480078ba",
                "key": "05ce9583-136a-4dac-a379-d732be7b9fa9",
                "udi": null,
                "values": [
                  {
                    "alias": "profilePicture",
                    "culture": null,
                    "editorAlias": null,
                    "segment": null,
                    "value": [
