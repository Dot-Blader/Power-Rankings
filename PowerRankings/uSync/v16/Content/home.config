        },
        {
          "alias": "profilePicture",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": [
            {
              "key": "86637710-45de-470b-afa2-0668d8ab635d",
              "mediaKey": "fc60221b-da38-47a1-9c24-9ab91e8a2094",
              "mediaTypeAlias": "Image",
              "crops": [],
              "focalPoint": null
            }
          ]
        },
        {
          "alias": "characterName",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "Ice Reapers"
        },
        {
          "alias": "characterSource",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "Destiny"
        },
        {
          "alias": "details",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "Flayers are the highest ranking and most powerful natural Psions. Their psionic telekinesis allowed the three Ice Reapers to move Phobos into a temporary position, where they were to eventually release it onto the surface of Mars as a contingency if the Cabal\u0027s war turned towards a defeat. The Ice Reapers were also skilled at hacking, and were sent by Valus Ta\u0027aurc to hack into the Martian Warmind\u0027s central cortex in order to stop its orbital bombardments of Cabal positions across the planet."
        },
        {
          "alias": "characterTitle",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "Psion Flayers"
        },
        {
          "alias": "groupMembers",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": {
            "contentData": [
              {
                "contentTypeKey": "6f386c25-c5f7-4cc6-8761-a63a480078ba",
                "key": "a05cad23-82ad-42b4-b178-4cdbaec66a15",
                "udi": null,
                "values": [
                  {
                    "alias": "profilePicture",
                    "culture": null,
                    "editorAlias": null,
                    "segment": null,
                    "value": [
                      {
                        "key": "58db3050-ba72-4dd7-bbde-604c5e7c080b",
                        "mediaKey": "46068ab4-982a-4788-a62a-ad2f03053caf",
                        "mediaTypeAlias": "Image",
                        "crops": [],
                        "focalPoint": null
                      }
                    ]
                  },
                  {
                    "alias": "characterName",
                    "culture": null,
                    "editorAlias": null,
                    "segment": null,
                    "value": "Kolar, Psion Flayer"
                  },
                  {
                    "alias": "characterSource",
                    "culture": null,
                    "editorAlias": null,
                    "segment": null,
                    "value": "Destiny"
                  },
                  {
                    "alias": "details",
                    "culture": null,
                    "editorAlias": null,
                    "segment": null,
                    "value": "Kolar wielded an Arc-energy absorption shield, which allowed him greater resistance to non-Arc elements than his regular Cabal-issued armor. He fought alongside his comrades in the Dust Palace, as a Guardian fireteam attempted to stop them from meddling with the Warmind."
                  },
                  {
                    "alias": "mainPicture",
                    "culture": null,
                    "editorAlias": null,
                    "segment": null,
                    "value": [
                      {
                        "key": "3b65f814-d74b-4adb-a0b2-97f6dec808a5",
                        "mediaKey": "55b75868-dfe7-4b21-bde6-67e5c02dc798",
                        "mediaTypeAlias": "Image",
                        "crops": [],
                        "focalPoint": null
                      }
                    ]
                  }
                ]
              },
              {
                "contentTypeKey": "6f386c25-c5f7-4cc6-8761-a63a480078ba",
                "key": "41824712-20ca-44bb-a333-21ec5b2db48c",
                "udi": null,
                "values": [
                  {
                    "alias": "mainPicture",
                    "culture": null,
                    "editorAlias": null,
                    "segment": null,
                    "value": [
                      {
                        "key": "d55fa242-bbbd-40fb-b4a0-2bd34ff34d9c",
