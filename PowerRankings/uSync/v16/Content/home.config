            }
          ]
        },
        {
          "alias": "characterName",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "The Janitor"
        },
        {
          "alias": "characterSource",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "Little Nightmares"
        },
        {
          "alias": "details",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "The Janitor, whose name was Roger based off of the name badge he wore, worked in the lower parts of the Maw. He was a resident of the Nowhere, and had been affected by the Transmission emitted from the Signal Tower. His arms were unusually long, and his legs unusually short. The long arms helped him with various maintenance purposes, and he could use them to easily lift his own weight high and low as he maneuvered the Maw. Other than janitorial and maintenance work, the Janitor also captured children, who were sent to the kitchen to suffer a disturbing fate."
        },
        {
          "alias": "characterTitle",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": ""
        }
      ]
    },
    {
      "contentTypeKey": "6f386c25-c5f7-4cc6-8761-a63a480078ba",
      "key": "1a19e7fb-eb14-4438-a279-bef7103290db",
