        {
          "alias": "characterName",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "GIGANTO"
        },
        {
          "alias": "characterSource",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "Sonic Frontiers"
        },
        {
          "alias": "details",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "GIGANTO was one of the Titans built by the Ancients as a last resort to deal with THE END. They were enhanced with the power of the Chaos Emeralds, which made them so strong that Sonic couldn\u0027t even scratch GIGANTO before turning into Super Sonic."
        }
      ]
    },
