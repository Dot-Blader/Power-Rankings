        },
        {
          "alias": "characterName",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "Koregos, the Wordline"
        },
        {
          "alias": "characterSource",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "Destiny 2: The Edge of Fate"
        },
        {
          "alias": "details",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "Koregos was an incredibly powerful Harpy under the command of the Conductor. It was placed inside the singularity of III\u0027s corpse, and through its 4-Dimensional power was able to merge itself with the wordline of Earth itself. Having control over the entire space-time history of Earth would have allowed the Conductor to alter the history of the planet to suit her goals, but a fireteam of Guardians put Koregos down before that could happen. "
        },
        {
          "alias": "mainPicture",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": [
            {
              "key": "3880b344-c2cb-4cdd-99a3-89c591fc4115",
              "mediaKey": "f6aeffa5-0709-4a9a-9872-9b29706869b8",
              "mediaTypeAlias": "Image",
              "crops": [],
              "focalPoint": null
            }
          ]
        }
      ]
    },
    {
