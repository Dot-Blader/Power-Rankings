                            },
                            {
                              "alias": "characterName",
                              "culture": null,
                              "editorAlias": null,
                              "segment": null,
                              "value": "Baxx, Hand of Oryx"
                            },
                            {
                              "alias": "characterSource",
                              "culture": null,
                              "editorAlias": null,
                              "segment": null,
                              "value": "Destiny: The Taken King"
                            },
                            {
                              "alias": "details",
                              "culture": null,
                              "editorAlias": null,
                              "segment": null,
                              "value": "Baxx was summoned into the Oversoul Throne alongside Ta\u0027aun to stop the Young Wolf from escaping with a portion of Crota\u0027s essence. The power of Baxx and Ta\u0027aun combined was sufficient to make Eris Morn teleport the Guardian out of danger to save them from certain death."
                            }
