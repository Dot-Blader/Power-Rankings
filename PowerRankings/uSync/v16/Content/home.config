                        "crops": [],
                        "focalPoint": null
                      }
                    ]
                  },
                  {
                    "alias": "details",
                    "culture": null,
                    "editorAlias": null,
                    "segment": null,
                    "value": "An Hamaat was using Taken Blights to vertically manipulate the fabric of the universe. She did so alongside An Salaak. The Young Wolf would discover the ritual and killed them both, but due to the time loop of the Dreaming City they are brought back to life continuously to keep attempting to finish their ritual."
                  }
                ]
              },
              {
                "contentTypeKey": "6f386c25-c5f7-4cc6-8761-a63a480078ba",
