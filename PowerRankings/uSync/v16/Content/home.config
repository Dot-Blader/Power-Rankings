            }
          ]
        }
      ]
    },
    {
      "contentTypeKey": "6f386c25-c5f7-4cc6-8761-a63a480078ba",
      "key": "c1d5385b-09a5-4736-9d74-d8e58bec16eb",
      "udi": null,
      "values": [
        {
          "alias": "energyMultiplicator",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "5-Dimensional"
        },
        {
          "alias": "characterName",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "Solaris"
        },
        {
          "alias": "characterSource",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "SONIC THE HEDGEHOG"
        },
        {
          "alias": "details",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "Solaris was an entity that existed beyond time and which could devour entire timelines and the very concept of 4-Dimensional time as a whole. Within the fifth dimension it existed across the past, present and future, and would therefore require three separate Chaos Emerald-enhanced beings to defeat it in each era at the same time, lest it would return from destruction. To further ensure that Solaris would never rise to devour time its original shape as a small flame would be blown out, erasing the timelines where Solaris would have won."
        },
        {
          "alias": "profilePicture",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": [
            {
              "key": "9fa367c7-9aac-457d-8ca1-2fb8ce091ee4",
              "mediaKey": "44c8eecd-5760-4eeb-a583-cf06edfc3838",
              "mediaTypeAlias": "Image",
              "crops": [],
              "focalPoint": null
            }
          ]
        },
        {
          "alias": "mainPicture",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": [
            {
              "key": "1eed5dd6-62ac-48fc-9d7b-dfe1f387ab52",
              "mediaKey": "4a75dfda-ccdc-4f6b-9ee5-62518eea47dc",
              "mediaTypeAlias": "Image",
              "crops": [],
              "focalPoint": null
            }
          ]
        },
        {
          "alias": "characterTitle",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "Flame of Hope"
        }
      ]
    },
    {
      "contentTypeKey": "6f386c25-c5f7-4cc6-8761-a63a480078ba",
      "key": "d4d9076f-b2d9-4f68-8cc6-71473c01e1f4",
      "udi": null,
      "values": [
        {
          "alias": "energyMultiplicator",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "5-Dimensional"
        },
        {
          "alias": "profilePicture",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": [
            {
              "key": "c6e68faf-6bf3-4028-b3a6-e4120bc2b088",
              "mediaKey": "492fba75-ee8a-4687-82ae-1436bb2afcba",
              "mediaTypeAlias": "Image",
              "crops": [],
              "focalPoint": null
            }
          ]
        },
        {
          "alias": "characterName",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "Super Sonic"
        },
        {
          "alias": "characterSource",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "Sonic the Hedgehog"
        },
        {
          "alias": "mainPicture",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": [
            {
              "key": "05e65859-8cf4-49b9-aa9b-781b0d9adc8a",
              "mediaKey": "85298fe4-1aff-430c-bfee-31cf600b0f10",
              "mediaTypeAlias": "Image",
              "crops": [],
              "focalPoint": null
            }
          ]
        },
        {
          "alias": "details",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "By combining the power of all seven Chaos Emeralds, Sonic can become Super Sonic. In this state he is invulnerable to any form of damage, and can access a well of infinite Chaos Energy to wield against his opponents. The amount of power the Chaos Emeralds grant is based on emotions and thoughts and can therefore vary, but at maximum they can allow Super Sonic to wield 5-Dimensional power."
        }
      ]
    },
    {
      "contentTypeKey": "6f386c25-c5f7-4cc6-8761-a63a480078ba",
      "key": "c14e6630-bd00-46c3-9c56-48f47c7d64d3",
      "udi": null,
      "values": [
        {
          "alias": "energyMultiplicator",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "6-Dimensional"
        },
        {
          "alias": "profilePicture",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": [
            {
              "key": "e4dcb0bd-3fdc-4f36-86dc-6ef8ec438eb0",
              "mediaKey": "e794a790-9cc8-45c9-b562-eb33a91f0794",
