                  {
                    "alias": "characterName",
                    "culture": null,
                    "editorAlias": null,
                    "segment": null,
                    "value": "High Celebrant of Xivu Arath"
                  },
                  {
                    "alias": "characterSource",
                    "culture": null,
                    "editorAlias": null,
                    "segment": null,
                    "value": "Destiny 2: Season of the Hunt"
                  },
                  {
                    "alias": "details",
                    "culture": null,
                    "editorAlias": null,
                    "segment": null,
                    "value": "The High Celebrant was an Ascendant Knight serving Xivu Arath. He was assigned to make the Hive of the Sol system join her forces, and to be turned into Wrathborn if they refused. During negotiations with members of the Hidden Swarm, the Warlock Osiris interfered. The High Celebrant would conjure a visage of Xivu Arath herself, which would stun Osiris. This gave the Celebrant an opening to kill Osiris, but his attack was blocked and absorbed by Osiris\u0027s Ghost Sagira instead. Killing Sagira would lead to Osiris being Lightless, and for this crime the Guardians of the Last City would begin a hunt for this mighty warrior."
                  },
                  {
                    "alias": "characterVariant",
                    "culture": null,
                    "editorAlias": null,
                    "segment": null,
                    "value": "Material Space"
                  },
                  {
                    "alias": "characterTitle",
                    "culture": null,
                    "editorAlias": null,
                    "segment": null,
                    "value": "War\u0027s Celebrant"
                  }
                ]
              },
