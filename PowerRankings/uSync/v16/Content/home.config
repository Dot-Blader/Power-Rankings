            }
          ]
        },
        {
          "alias": "characterName",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "Skiff"
        },
        {
          "alias": "characterSource",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "Destiny"
        },
        {
          "alias": "details",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "Skiffs were dropships used by the Fallen to deploy troops and Walkers into battle or transport materials between the ground and the massive Ketches usually stationed in orbit. They were armed with a strong Arc-weapon to clear the landing area and support the troops being deployed, and had armor strong enough to withstand small-arms fire effectively."
        },
        {
          "alias": "mainPicture",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": [
            {
              "key": "05bf78ff-5125-4afd-95ca-895754867485",
              "mediaKey": "d46368f2-0819-46fc-940a-9610bd8e8c7f",
              "mediaTypeAlias": "Image",
              "crops": [],
              "focalPoint": null
            }
          ]
        },
        {
          "alias": "energyExponent",
          "culture": null,
