        {
          "alias": "characterName",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "Quria, Blade Transform"
        },
        {
          "alias": "characterSource",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "Destiny 2: Season of the Splicer"
        },
        {
          "alias": "details",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "Quria was a Vex Mind built to understand the Sword Logic. After learning how it worked it was able to grow powerful, but not powerful enough to withstand Oryx. It managed to simulate a younger version of him, without all his incredible power. Oryx Took Quria, and after experiencing this Quria could simulate an Oryx capable of Taking. Oryx, not realizing this, gave Quria to Savath\u00FBn, thinking that she might find this silly Vex interesting. Instead, she would use Quria\u0027s ability to Take control of Oryx\u0027s Taken after he died."
        },
        {
          "alias": "characterTitle",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "The Dreaming Mind"
        },
        {
          "alias": "mainPicture",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": [
            {
              "key": "c84d2713-f56f-416b-a326-4aec7f8ebd0b",
              "mediaKey": "3347c7fe-2ee2-4041-8ded-b9f61cee369f",
              "mediaTypeAlias": "Image",
              "crops": [],
              "focalPoint": null
            }
          ]
        }
      ]
    },
