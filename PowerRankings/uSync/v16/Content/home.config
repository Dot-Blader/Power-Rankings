        {
          "alias": "characterName",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "Goliath Tank"
        },
        {
          "alias": "characterSource",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "Destiny"
        },
        {
          "alias": "details",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "The Cabal Empire deployed Goliath Tanks to assault enemy positions. They are heavily armored, and equipped with a variety of weapons, allowing them to face almost any opposing force head-on. They hover over the ground, allowing them to traverse any terrain, and also allowing them to swiftly spin and move around in a way that makes them surprisingly fast for vehicles of their size."
        },
        {
          "alias": "energyExponent",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "11"
        },
