        },
        {
          "alias": "characterName",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "Acolyte"
        },
        {
          "alias": "details",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "After a century of struggling and clawing, a Thrall will morph into an Acolyte. With this a heightened level of intelligence is reached, allowing them to channel their power through weapons like Shredders. They command a number of Thrall, who tithe to them, and in turn the Acolyte tithes some of their killing to a Knight or Wizard that they serve."
        },
        {
          "alias": "characterSource",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "Destiny"
        },
        {
          "alias": "mainPicture",
