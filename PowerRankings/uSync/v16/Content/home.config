        },
        {
          "alias": "characterName",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "Morphon, Blighted Mind"
        },
        {
          "alias": "characterSource",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "Destiny: The Taken King"
        },
        {
          "alias": "details",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "Morphon was a Taken Hydra used by Oryx to assume control over the Vault of Glass. It may have been the Templar itself, Taken back into existence by Oryx after its destruction. It was able to manipulate the Oracles of the Vault to give itself an incredibly powerful shield, similar to the Templar. Through Morphon Oryx would attempt to Take the entire Vex Network across all timelines that converged in the Vault, but the Vex would trick a Guardian of the Last City to enter the Vault and slay the Taken, saving the Vex in the process."
        }
      ]
    },
    {
      "contentTypeKey": "6f386c25-c5f7-4cc6-8761-a63a480078ba",
      "key": "d2c713ce-fcfe-41b9-b9ef-95e54ec144ed",
      "udi": null,
      "values": [
