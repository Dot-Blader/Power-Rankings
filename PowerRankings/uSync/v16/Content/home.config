          "segment": null,
          "value": "Xaras, Greed of Xivu Arath"
        },
        {
          "alias": "characterSource",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "Destiny 2: Forsaken"
        },
        {
          "alias": "profilePicture",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": [
            {
              "key": "0e260b73-a49a-4625-a659-1a2c08c5dac1",
              "mediaKey": "bcca4e9b-c13c-4baf-8f4d-f66b5c959849",
              "mediaTypeAlias": "Image",
              "crops": [],
              "focalPoint": null
            }
          ]
        },
        {
          "alias": "details",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "Xaras was a Chimera leading a group of Taken in servitude to Xivu Arath in the Harbinger\u0027s Seclude. Xaras was tasked with stealing Awoken artifacts that contained the secret knowledge of the Awoken people, but a Guardian of the Last City was dispatched to recover the relics and put an end to Xaras. Due to Quria\u0027s time loop, Xaras is brought back to life every three weeks to retry its task."
        },
        {
          "alias": "characterVariant",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "Material Space"
        },
        {
          "alias": "mainPicture",
