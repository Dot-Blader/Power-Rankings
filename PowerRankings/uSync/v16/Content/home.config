                        "focalPoint": null
                      }
                    ]
                  },
                  {
                    "alias": "characterName",
                    "culture": null,
                    "editorAlias": null,
                    "segment": null,
                    "value": "Garaask, Undying Inferno"
                  },
                  {
                    "alias": "characterSource",
                    "culture": null,
                    "editorAlias": null,
                    "segment": null,
                    "value": "Destiny 2: Lightfall"
                  },
                  {
                    "alias": "details",
                    "culture": null,
                    "editorAlias": null,
                    "segment": null,
                    "value": "Garaask was an Incendior of the Shadow Legion who enhanced himself with Pyramid-tech. He was sent by Calus to fight against the Young Wolf, and was considered one of the strongest champions available in the legion at the time. "
                  }
                ]
              },
              {
                "contentTypeKey": "6f386c25-c5f7-4cc6-8761-a63a480078ba",
                "key": "0049415e-7d6d-4442-9990-b66f4ec61268",
                "udi": null,
                "values": [
                  {
                    "alias": "profilePicture",
                    "culture": null,
