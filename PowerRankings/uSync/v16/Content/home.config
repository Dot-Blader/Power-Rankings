                  {
                    "alias": "characterName",
                    "culture": null,
                    "editorAlias": null,
                    "segment": null,
                    "value": "Thalnok, Fanatic of Crota"
                  },
                  {
                    "alias": "characterVariant",
                    "culture": null,
                    "editorAlias": null,
                    "segment": null,
                    "value": "Material Space"
                  },
                  {
                    "alias": "details",
                    "culture": null,
                    "editorAlias": null,
                    "segment": null,
                    "value": "Thalnok was a Hive Knight who obsessed with being as similar to Crota as possible, in order to mimic and thus reach his power. Oryx would see Thalnok as foolish, but he also saw value in him. Oryx elevated Thalnok to his Court so that he could observe his distant son\u0027s progress by observing the changes in Thalnok."
                  },
                  {
                    "alias": "mainPicture",
                    "culture": null,
                    "editorAlias": null,
                    "segment": null,
                    "value": [
