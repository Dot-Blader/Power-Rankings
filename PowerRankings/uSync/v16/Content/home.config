          "value": "Destiny"
        },
        {
          "alias": "details",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "Captains lead squads of Vandals and Dregs, and have a greater Ether ration than their subordinates. They also have stronger armor, which helps them when the greedy Dregs try to seize their loot for their own gain."
        }
      ]
    },
    {
      "contentTypeKey": "6f386c25-c5f7-4cc6-8761-a63a480078ba",
      "key": "4e9dbc4c-c1a4-4810-9339-d96508df36eb",
