        {
          "alias": "characterName",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "Great Eggman Robo"
        },
        {
          "alias": "characterSource",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "Sonic the Hedgehog 3 \u0026 Knuckles"
        },
        {
          "alias": "details",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "After relaunching the Death Egg a second time by using the Master Emerald, Eggman positioned the powerful emerald inside a giant mech. This robot had the unique ability to focus the energies of the Master Emerald into a laser, which Eggman would be forced to use against Sonic as he tried to bring down the Death Egg once again. The casing that stored the Master Emerald was built to the same specs as the Death Egg Robot."
        },
        {
          "alias": "mainPicture",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": [
            {
              "key": "2f121994-d22d-4844-a077-4855b3bfc66b",
