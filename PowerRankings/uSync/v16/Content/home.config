                  },
                  {
                    "alias": "details",
                    "culture": null,
                    "editorAlias": null,
                    "segment": null,
                    "value": "After succeeding in a test, an Unborn Ogre can receive a Summoning Ritual. This ritual focuses their rage, and enhances their power to Ascendancy. "
                  },
