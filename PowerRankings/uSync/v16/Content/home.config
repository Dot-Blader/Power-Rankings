        {
          "alias": "characterName",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "Hydra"
        },
        {
          "alias": "characterSource",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "Destiny"
        },
        {
          "alias": "details",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "Hydra\u0027s are typically surrounded by translucent matrices that protect them from material harm, dissolving bullets into the Vex Network on impact. Their mind cores can process data faster than any other Vex frame, and is naturally protected by heavy armor."
        }
      ]
    },
