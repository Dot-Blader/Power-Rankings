          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "Belmon, Transcendent Mind"
        },
        {
          "alias": "profilePicture",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": [
            {
              "key": "e10dfb9c-1c24-4e3f-bea0-00a3c2100121",
              "mediaKey": "0c8bc9df-84fe-423c-a607-30e992211c1c",
              "mediaTypeAlias": "Image",
              "crops": [],
              "focalPoint": null
            }
          ]
        },
        {
          "alias": "characterSource",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "Destiny 2: Beyond Light"
        },
        {
          "alias": "details",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "Belmon was a massive Vex Hydra that was in charge of invading Europa and converting it into a Machine-World. It drew power from the data in its vast mind core, every small detail about the process of converting every molecule in the planetoid. It had the ability to transcend destruction, returning after being defeated to attempt its invasion multiple times."
        },
        {
          "alias": "mainPicture",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": [
            {
