        },
        {
          "alias": "characterSource",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "Destiny"
        },
        {
          "alias": "characterName",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "Corrective Mind"
        },
        {
          "alias": "details",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "The Axis Mind of the Hezen Corrective was a powerful Cyclops. Its purpose was to deal with the House of Winter of the Fallen, whilst also being a distraction for those who wanted to learn about the Hezen Protective. It had a mind core that stretched across the entire mantle of Venus, and drew immense amounts of energy from it."
        },
        {
          "alias": "energyMultiplicator",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "1,46"
        },
