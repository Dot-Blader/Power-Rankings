        },
        {
          "alias": "characterSource",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "Sonic the Hedgehog"
        },
        {
          "alias": "details",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "Doctor Eggman is usually found flying around in his Egg Mobile. It\u0027s a machine made to be able to integrate various weapons into its system, allowing Eggman to directly take on threats of various kinds in many different environments. The basic Egg Mobile is more resilient than the basic Badniks of the Eggman Empire, requiring eight hits from Sonic to be brought down during their first meeting."
        },
        {
          "alias": "mainPicture",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": [
            {
              "key": "6de4615e-f9fa-42e9-987e-3eb54acbbe14",
              "mediaKey": "f76a4c6c-abc1-4e90-8001-1d32f43f797f",
              "mediaTypeAlias": "Image",
              "crops": [],
              "focalPoint": null
            }
          ]
        }
      ]
    },
