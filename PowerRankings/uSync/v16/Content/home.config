          "value": [
            {
              "key": "2e30edc0-0fff-43ea-9644-ab2d5f1656df",
              "mediaKey": "de315c79-f1ad-4e73-a526-675dcef0fe64",
              "mediaTypeAlias": "Image",
              "crops": [],
              "focalPoint": null
            }
          ]
        },
        {
          "alias": "details",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "The Restorative Mind was one of many members of the Weavers, Vex minds summoned when a node in their network is lost. Theosyion was summoned to Venus in order to undo the destruction of Sekrion, the Nexus Mind. It would do this by opening up a bridge to another timeline, attempting to bring a version of Sekrion into our timeline through it."
        }
      ]
    },
