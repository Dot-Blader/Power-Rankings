          "segment": null,
          "value": "The First Knife"
        },
        {
          "alias": "characterVariant",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "Material Space"
        },
        {
          "alias": "characterSource",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "Destiny 2: The Final Shape"
        },
        {
          "alias": "details",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "The Witness saw itself as the metaphorical knife wielded by the Winnower to cut the universe into a perfect final shape. It was the most powerful being of Darkness in the universe, and spent billions of years chasing the Traveler in its quest to end all suffering in the universe. Just one seed left behind by the Witness in the Black Garden was used by the Vex to create the Black Heart."
        },
        {
          "alias": "mainPicture",
          "culture": null,
          "editorAlias": null,
          "segment": null,
