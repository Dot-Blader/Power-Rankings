                      }
                    ]
                  },
                  {
                    "alias": "characterName",
                    "culture": null,
                    "editorAlias": null,
                    "segment": null,
                    "value": "Sanctified Mind"
                  },
                  {
                    "alias": "characterTitle",
                    "culture": null,
                    "editorAlias": null,
                    "segment": null,
                    "value": "Sol Inherent"
                  },
                  {
                    "alias": "characterSource",
                    "culture": null,
                    "editorAlias": null,
                    "segment": null,
                    "value": "Destiny 2: Shadowkeep"
                  },
                  {
                    "alias": "details",
                    "culture": null,
                    "editorAlias": null,
                    "segment": null,
                    "value": "The Sanctified Mind was situated on top of the smoking stump of the Tree of Silver Wings inside the Black Garden. It was the Mind in charge of harnessing the Darkness of the veiled statue within the stump, leading the Vex\u0027s attempts at achieving divinity through its power. It merged the Darkness with the Vex\u0027s radiolarian fluid, causing unnatural warping of the the nearby Vex architecture as the foreign energy surged through it."
                  }
                ]
              }
            ],
