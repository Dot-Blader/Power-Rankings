          "segment": null,
          "value": "Centurion"
        },
        {
          "alias": "characterSource",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "Destiny"
        },
        {
          "alias": "mainPicture",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": [
            {
              "key": "29eb2c78-3c66-41af-90f1-2056acb3217a",
              "mediaKey": "f7e857af-2e53-4c0e-bf50-f1bfaffd424c",
              "mediaTypeAlias": "Image",
              "crops": [],
              "focalPoint": null
            }
          ]
        },
        {
          "alias": "details",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "Centurions are officers of the Cabal military, leading squads of Legionaries, Phalanxes and other units. They have stronger armor than those of a lower rank, and often have an absorption shield built into their armor. This shield gives an extra layer of resistance outside the Centurion\u0027s standard armor. "
        }
      ]
    },
    {
      "contentTypeKey": "6f386c25-c5f7-4cc6-8761-a63a480078ba",
      "key": "b1490eb9-0d8c-4e54-87a0-ec804b9ee708",
