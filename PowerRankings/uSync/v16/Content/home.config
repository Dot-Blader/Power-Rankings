                      }
                    ]
                  },
                  {
                    "alias": "characterName",
                    "culture": null,
                    "editorAlias": null,
                    "segment": null,
                    "value": "Naksis, Devil Baron"
                  },
                  {
                    "alias": "characterSource",
                    "culture": null,
                    "editorAlias": null,
                    "segment": null,
                    "value": "Destiny"
                  },
                  {
                    "alias": "details",
                    "culture": null,
                    "editorAlias": null,
                    "segment": null,
                    "value": "Naksis was a Baron of the House of Winter who deserted his House for unknown reasons. He joined the House of Devils, and before even having time to change from his Winter-colors to bear the colors of the Devils, he was sent into battle. A fireteam of Guardians was assaulting the Devil\u0027s Lair hunting for Sepiks Prime, and so Naksis was deployed to prove his loyalty and worth by ending the fireteam."
                  }
                ]
              }
            ],
