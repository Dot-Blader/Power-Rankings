                    ]
                  },
                  {
                    "alias": "characterName",
                    "culture": null,
                    "editorAlias": null,
                    "segment": null,
                    "value": "Voice of Riven"
                  },
                  {
                    "alias": "characterVariant",
                    "culture": null,
                    "editorAlias": null,
                    "segment": null,
                    "value": "Material Space"
                  },
                  {
                    "alias": "characterSource",
                    "culture": null,
                    "editorAlias": null,
                    "segment": null,
                    "value": "Destiny 2: Forsaken"
                  },
                  {
                    "alias": "details",
                    "culture": null,
                    "editorAlias": null,
                    "segment": null,
                    "value": "The Voice of Riven was a Taken Servitor that was used by Riven of a Thousand Voices to manipulate Uldren Sov. Riven was trapped in the Dreaming City and used Uldren to open the Dreaming City to the outside world by speaking to him with the voice of his sister Mara Sov. After opening the gates, Uldren was captured by the Voice of Riven, and the Young Wolf engaged the Chimera in battle, defeating it and releasing Uldren."
                  }
                ]
              },
              {
                "contentTypeKey": "6f386c25-c5f7-4cc6-8761-a63a480078ba",
                "key": "5601d80d-e1c3-4c73-aab5-6aeabe550b31",
                "udi": null,
                "values": [
                  {
                    "alias": "profilePicture",
                    "culture": null,
                    "editorAlias": null,
                    "segment": null,
                    "value": [
                      {
