        },
        {
          "alias": "characterName",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "Crux of Darkness"
        },
        {
          "alias": "characterSource",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "Destiny 2"
        },
        {
          "alias": "details",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "Pyramid-tech can contain Darkness in various forms, typically channeling Resonance. A Crux of Darkness is a commonly seen type of Pyramid-tech utilized by the forces of the Witness in various ways. The House of Salvation use them to boost their Stasis-abilities\u0027 regeneration effects, and Sizmic the Net-Desecrator of the Shadow Legion used one to channel his power in order to hack into the CloudArk.  "
        },
        {
          "alias": "mainPicture",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": [
            {
              "key": "5926dff0-9035-413a-8e5c-ffdb52c22dc8",
              "mediaKey": "88263d0c-47dc-4fa0-b707-2a3c77c255d4",
              "mediaTypeAlias": "Image",
              "crops": [],
              "focalPoint": null
            }
          ]
        },
        {
          "alias": "energyExponent",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "24"
        }
      ]
    },
    {
      "contentTypeKey": "6f386c25-c5f7-4cc6-8761-a63a480078ba",
      "key": "e96bca7a-d3fe-4e24-9199-c348c7e76ad3",
