          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "Exo of Clovis Bray I"
        }
      ]
    },
    {
      "contentTypeKey": "6f386c25-c5f7-4cc6-8761-a63a480078ba",
      "key": "69f23f73-da8f-420b-b86f-a4ddc8d9145e",
