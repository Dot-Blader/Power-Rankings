          "segment": null,
          "value": ""
        },
        {
          "alias": "characterName",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "D\u00FBl Incaru, the Eternal Return"
        },
        {
          "alias": "characterSource",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "Destiny 2: Forsaken"
        },
        {
          "alias": "details",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "D\u00FBl Incaru was a powerful Witch serving on the Court of Savath\u00FBn. She was assigned by her mother to attempt to breach the Distributary through the shattered Throne World Eleusinia. D\u00FBl Incaru would send her forces to assault the Dreaming City in material space as she herself entered the Ascendant Plane. She would receive tithes from her servants, three Ascendant Darkblades who acted as her bodyguards and Fatesmiths. After being defeated, a time loop activated that keeps returning her back to life to this very day."
        },
        {
          "alias": "characterTitle",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "Daughter of Savath\u00FBn"
        },
        {
          "alias": "characterVariant",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "Material Space"
        }
      ]
    },
