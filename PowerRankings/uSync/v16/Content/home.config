      "key": "6cb44ead-040e-4b59-ac7a-cc1c91a2f67c",
      "udi": null,
      "values": [
        {
          "alias": "energyMultiplicator",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "Infinite-Dimensional"
        },
        {
          "alias": "profilePicture",
          "culture": null,
