                            }
                          ]
                        },
                        {
                          "contentTypeKey": "6f386c25-c5f7-4cc6-8761-a63a480078ba",
                          "key": "534118c3-0061-4676-a243-3991b2fad6d9",
                          "udi": null,
                          "values": [
                            {
                              "alias": "characterName",
                              "culture": null,
                              "editorAlias": null,
                              "segment": null,
                              "value": "Ba-Kuur, Fatesmith of Incaru"
                            },
                            {
                              "alias": "characterVariant",
                              "culture": null,
                              "editorAlias": null,
                              "segment": null,
                              "value": "Ascendant Plane"
                            },
                            {
                              "alias": "characterSource",
                              "culture": null,
                              "editorAlias": null,
                              "segment": null,
                              "value": "Destiny 2: Forsaken"
                            },
                            {
                              "alias": "details",
                              "culture": null,
                              "editorAlias": null,
                              "segment": null,
                              "value": "Ba-Kuur returns every three weeks to keep protecting D\u00FBl Incaru due to the time loop over the Dreaming City. He and the other two Fatesmiths hold the finite thoughts that can pierce D\u00FBl Incaru\u0027s infinite shielding."
                            },
                            {
                              "alias": "profilePicture",
                              "culture": null,
                              "editorAlias": null,
                              "segment": null,
                              "value": [
                                {
                                  "key": "d2ab43ee-ddf0-4357-8793-6e1fcff7bf26",
                                  "mediaKey": "c9941065-a180-40c3-ba64-fc97b5ab7eaf",
                                  "mediaTypeAlias": "Image",
                                  "crops": [],
                                  "focalPoint": null
                                }
                              ]
                            },
