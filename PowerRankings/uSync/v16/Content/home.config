                        "mediaTypeAlias": "Image",
                        "crops": [],
                        "focalPoint": null
                      }
                    ]
                  },
                  {
                    "alias": "mainPicture",
                    "culture": null,
                    "editorAlias": null,
                    "segment": null,
                    "value": [
                      {
                        "key": "8d3b3864-c14a-4ed6-9334-37f2e277bb4c",
                        "mediaKey": "f5b33994-590c-43fe-b088-da305c7f789e",
                        "mediaTypeAlias": "Image",
                        "crops": [],
                        "focalPoint": null
                      }
                    ]
                  },
                  {
                    "alias": "characterSource",
                    "culture": null,
                    "editorAlias": null,
                    "segment": null,
                    "value": "Destiny"
                  },
                  {
                    "alias": "characterName",
                    "culture": null,
                    "editorAlias": null,
                    "segment": null,
                    "value": "Grayliks, Winter Baron"
                  },
                  {
                    "alias": "details",
                    "culture": null,
                    "editorAlias": null,
                    "segment": null,
                    "value": "Grayliks worked with Simiks-3 to infiltrate the hidden archive of the Ishtar Collective on Venus. His forces were in the process of hacking into the archive as the Young Wolf showed up, destroyed Simiks-3, and promptly opened the way inside the archive. This Guardian was seeking the knowledge stored within themselves, but Grayliks brought a crew of Fallen and followed the Guardian inside to avenge their lost comrades."
                  }
                ]
              },
              {
                "contentTypeKey": "6f386c25-c5f7-4cc6-8761-a63a480078ba",
                "key": "34a80669-6599-405c-9b3e-61db5029b9ab",
                "udi": null,
                "values": [
                  {
                    "alias": "profilePicture",
