                      }
                    ]
                  },
                  {
                    "alias": "mainPicture",
                    "culture": null,
                    "editorAlias": null,
                    "segment": null,
                    "value": [
                      {
                        "key": "6e7eb312-427a-406a-ba47-160281bc65ed",
                        "mediaKey": "11a6744d-232a-465e-a326-d7c668dc38e6",
                        "mediaTypeAlias": "Image",
                        "crops": [],
                        "focalPoint": null
                      }
                    ]
                  },
                  {
                    "alias": "details",
                    "culture": null,
                    "editorAlias": null,
                    "segment": null,
                    "value": "Exomida was originally a Servitor that was Taken by the Witness. It was placed as a guard within the Ascendant Plane on the edge of the prison complex used by Warden Vincu\u0027us to hold human captives. Exomida used a massive Blight to channel its power in order to block the way into the material space interior of the prison."
                  }
                ]
              },
              {
                "contentTypeKey": "6f386c25-c5f7-4cc6-8761-a63a480078ba",
