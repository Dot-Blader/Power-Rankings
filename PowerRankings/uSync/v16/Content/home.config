                  {
                    "alias": "characterName",
                    "culture": null,
                    "editorAlias": null,
                    "segment": null,
                    "value": "Alak-Hul, the Darkblade"
                  },
                  {
                    "alias": "characterTitle",
                    "culture": null,
                    "editorAlias": null,
                    "segment": null,
                    "value": "Foster Son of Oryx"
                  },
                  {
                    "alias": "characterVariant",
                    "culture": null,
                    "editorAlias": null,
                    "segment": null,
                    "value": "Material Space"
                  },
                  {
                    "alias": "details",
                    "culture": null,
                    "editorAlias": null,
                    "segment": null,
                    "value": "Alak-Hul was a foster son to Oryx, with his original parents being unknown. He was one of Oryx\u0027s most beloved servants, and a member of his Court. He would attempt to take the Osmium Throne from Oryx by raising an army of Thrall, but he would be put down by Oryx and imprisoned aboard the Dreadnaught."
                  },
                  {
                    "alias": "mainPicture",
                    "culture": null,
                    "editorAlias": null,
                    "segment": null,
                    "value": [
                      {
                        "key": "a9049a3e-2cab-4892-afb1-fadf054061cb",
