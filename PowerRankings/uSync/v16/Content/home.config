                    ]
                  },
                  {
                    "alias": "characterName",
                    "culture": null,
                    "editorAlias": null,
                    "segment": null,
                    "value": "Zydron, Gate Lord"
                  },
                  {
                    "alias": "characterSource",
                    "culture": null,
                    "editorAlias": null,
                    "segment": null,
                    "value": "Destiny"
                  },
                  {
                    "alias": "details",
                    "culture": null,
                    "editorAlias": null,
                    "segment": null,
                    "value": "Zydron was the Gate Lord targeted by the Young Wolf on their journey to find a way to enter the Black Garden in order to destroy the Black Heart. Zydron was in charge of protecting a gate located just beneath the Citadel in the Ishtar Sink, and was summoned and destroyed by the Guardian. Its eye was used to forcibly open the Martian gate to the Black Garden."
                  }
                ]
              },
              {
                "contentTypeKey": "6f386c25-c5f7-4cc6-8761-a63a480078ba",
                "key": "35569d0c-6a3c-45ac-80b4-11ac03242b13",
                "udi": null,
                "values": [
                  {
                    "alias": "profilePicture",
                    "culture": null,
