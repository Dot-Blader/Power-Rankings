                  },
                  {
                    "alias": "details",
                    "culture": null,
                    "editorAlias": null,
                    "segment": null,
                    "value": "The twin daughters of the mighty Oryx were incredibly inventive. They created the Annihilator Totems that became staple defenses of most Ascendant Hive\u0027s Throne Worlds. They also created the weapon that Oryx\u0027s Dreadnaught could unleash by drawing power from the sword of Oryx, Willbreaker. The twins mastered the Deathsong, a song which could kill anyone who heard it from start to finish."
                  },
                  {
                    "alias": "profilePicture",
                    "culture": null,
                    "editorAlias": null,
                    "segment": null,
                    "value": ""
                  }
                ]
              },
              {
                "contentTypeKey": "6f386c25-c5f7-4cc6-8761-a63a480078ba",
                "key": "e7cd4fb2-a04b-436e-9357-fc56c2602f51",
                "udi": null,
                "values": [
