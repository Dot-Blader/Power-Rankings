        },
        {
          "alias": "characterSource",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "Sonic Frontiers"
        },
        {
          "alias": "details",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "FORTRESS units could be seen flying above Chaos Island. They were huge and heavily armored, and loaded with special targeting systems that allowed them to carpet-bomb vast regions as a means of utterly destroying any invading forces."
        }
      ]
    },
