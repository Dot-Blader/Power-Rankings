                      }
                    ]
                  },
                  {
                    "alias": "characterName",
                    "culture": null,
                    "editorAlias": null,
                    "segment": null,
                    "value": "Nezarec, Final God of Pain"
                  },
                  {
                    "alias": "characterTitle",
                    "culture": null,
                    "editorAlias": null,
                    "segment": null,
                    "value": "The Purest Light, The Darkest Hour"
                  },
                  {
                    "alias": "characterSource",
                    "culture": null,
                    "editorAlias": null,
                    "segment": null,
                    "value": "Destiny 2: Lightfall"
                  },
                  {
                    "alias": "details",
                    "culture": null,
                    "editorAlias": null,
                    "segment": null,
                    "value": "Nezarec was a primordial being who cherished inflicting pain on anyone he could. Little is known about his origins, but he was worshipped by the Psions before the Cabal Empire enslaved them. He was less a person and more an idea, and he could survive even after his physical body was killed and dissected just from people having memories and nightmares of him. He would be revived by the Traveler unintentionally, regrowing his body from only his head into a new one inspired by Rhulk\u0027s Lubraean genetics."
                  }
                ]
              }
            ],
