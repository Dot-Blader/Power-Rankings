        {
          "alias": "characterSource",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "Destiny 2"
        },
        {
          "alias": "characterName",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "Protheon, Modular Mind"
        },
        {
          "alias": "details",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "Protheon was an experimental Vex Axis Mind found on 7066 Nessus. It was designed to have a modular weapons system, allowing it to adapt to any environment or enemy type. The Red Legion of the Cabal accidentally stumbled upon it during a mining operation on the Centaur, and struggled to contend with its power. A fireteam of Guardians were sent to the Inverted Spire in order to put down the mighty Minotaur, as Failsafe calculated that a battle between the Cabal and Protheon could lead to the destruction of Nessus in its entirety."
        }
      ]
    },
    {
      "contentTypeKey": "6f386c25-c5f7-4cc6-8761-a63a480078ba",
      "key": "474f4594-93ae-4df3-9e0d-5476e3161e67",
