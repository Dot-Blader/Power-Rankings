        },
        {
          "alias": "characterName",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "The Twin Chefs"
        },
        {
          "alias": "characterSource",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "Little Nightmares"
        },
        {
          "alias": "details",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "The Twin Chefs work in the Maw\u0027s kitchen, preparing the food meant for the Guests. They use various ingredients in their dishes such as vegetables, fish, and even children. Children are transported from the prison by the Janitor, and along with any unfortunate children visiting the kitchen on their own, get added to soups and other dishes. The Chefs aggressively hunt down any roaming children in their kitchen, showing their surprising strength whilst doing so as they smash tables apart in order to catch their prey."
        },
        {
          "alias": "characterTitle",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "A Pair of Brutes"
        },
        {
          "alias": "groupMembers",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": {
            "contentData": [
