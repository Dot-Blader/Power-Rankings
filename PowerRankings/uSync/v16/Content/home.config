          "alias": "characterName",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "Phalanx"
        },
        {
          "alias": "characterSource",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "Destiny"
        },
        {
          "alias": "details",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "Phalanxes of the Cabal Empire wield shields that are as strong as ship\u0027s armored hulls. They use these mainly for defense, but can also knock enemies over with a strong bash. "
        },
        {
          "alias": "mainPicture",
          "culture": null,
