        {
          "alias": "characterName",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "Dendron, Root Mind"
        },
        {
          "alias": "characterSource",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "Destiny 2: Curse of Osiris"
        },
        {
          "alias": "details",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "During the Collapse, Dendron was situated on the top of a spire on Mercury. Within just a few days this powerful Cyclops oversaw the full conversion of Mercury into a Machine-World of the Vex. The sudden expanse of Vex influence in the system was so significant that the Traveler itself used its Light to stun the Vex out of being able to convert more worlds for centuries. Dendron\u0027s fate would remain unknown, but simulations of its actions would haunt Guardians who entered the Infinite Forest."
        },
        {
          "alias": "energyExponent",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "30"
        },
        {
          "alias": "mainPicture",
          "culture": null,
          "editorAlias": null,
          "segment": null,
