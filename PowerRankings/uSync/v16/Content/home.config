        },
        {
          "alias": "details",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "Simiks-3 was a High Servitor of the House of Winter. It worked with Grayliks to invade and access the Ishtar Collective\u0027s archive on Venus. High Servitors produced more Ether than regular Servitors."
        },
        {
          "alias": "characterTitle",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "High Servitor"
        }
      ]
    },
