        },
        {
          "alias": "characterName",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "Shank"
        },
        {
          "alias": "characterSource",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "Destiny"
        },
        {
          "alias": "details",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "Shanks are small drones made by the Fallen to bolster their forces and serve maintenance purposes. They are tough, and are small enough to fit where Dregs don\u0027t. They can be found repairing Walkers, or gunning down intruders on Fallen territory."
        }
      ]
    },
    {
      "contentTypeKey": "6f386c25-c5f7-4cc6-8761-a63a480078ba",
      "key": "fae79b4d-6f32-465f-96ad-94cd22e53d54",
