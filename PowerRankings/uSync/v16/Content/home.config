                  {
                    "alias": "characterName",
                    "culture": null,
                    "editorAlias": null,
                    "segment": null,
                    "value": "Chef"
                  },
                  {
                    "alias": "characterSource",
                    "culture": null,
                    "editorAlias": null,
                    "segment": null,
                    "value": "Little Nightmares"
                  },
                  {
                    "alias": "details",
                    "culture": null,
                    "editorAlias": null,
                    "segment": null,
                    "value": "This Chef would be the first to encounter Six during her journey through the kitchen. Being interrupted as he was cooking, he tried to catch the small child, but to no avail."
                  }
                ]
              },
              {
                "contentTypeKey": "6f386c25-c5f7-4cc6-8761-a63a480078ba",
                "key": "4257f410-fd3d-4707-b78d-19f0831bc827",
