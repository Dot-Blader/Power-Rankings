        },
        {
          "alias": "characterName",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "The Teacher"
        },
        {
          "alias": "characterSource",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "Little Nightmares 2"
        },
        {
          "alias": "details",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "The Teacher is as her title suggests a teacher, but her students are not normal kids. Her school is filled with bullies, who express their mischief at anyone except the Teacher. She can extend her neck an incredibly long distance due to the warping of the Transmission, allowing her to catch any of her students misbehaving, and she punishes miscreants harshly. She will aggressively chase any children who enter the school, even bending apart metallic vents with her head as she tries to catch those who disobey her strict rules."
        }
      ]
    },
    {
      "contentTypeKey": "6f386c25-c5f7-4cc6-8761-a63a480078ba",
      "key": "224a0fd5-45a5-4aaf-9867-7284bd0f6a9c",
