        },
        {
          "alias": "characterName",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "Sekrion, the Nexus Mind"
        },
        {
          "alias": "characterSource",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "Destiny"
        },
        {
          "alias": "details",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "Sekrion was the Axis Mind of the Hezen Protective, constructed for the sole purpose of transforming the planet Venus into a Machine-World. Its ability to alter Venus was slowed by the Traveler during the Collapse, where it halted all Vex-activity after their successful transformation of Mercury. Centuries later Sekrion would restart its process and begin altering every molecule across all of Venus, but it was engaged by a Guardian fireteam and subsequently destroyed. "
        },
        {
          "alias": "mainPicture",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": [
            {
              "key": "acf31d62-5fa1-48cb-80ef-f12e727c0c5e",
              "mediaKey": "1dc23ad0-e33e-43d3-bf6f-14bdaa667085",
              "mediaTypeAlias": "Image",
              "crops": [],
              "focalPoint": null
            }
          ]
        },
        {
          "alias": "characterVariant",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "Hezen Lord"
        }
      ]
    },
    {
      "contentTypeKey": "6f386c25-c5f7-4cc6-8761-a63a480078ba",
      "key": "256c3fe1-f177-4637-9a31-2a8bc0e45198",
      "udi": null,
      "values": [
        {
          "alias": "energyMultiplicator",
          "culture": null,
