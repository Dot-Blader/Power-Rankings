    {
      "contentTypeKey": "6f386c25-c5f7-4cc6-8761-a63a480078ba",
      "key": "eb8c0ab2-5c5c-4d9c-a455-db3e73fdd8b7",
      "udi": null,
      "values": [
        {
          "alias": "energyMultiplicator",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "Temporal"
        },
        {
          "alias": "characterName",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "Sekrion, Subverted Mind"
        },
        {
          "alias": "characterVariant",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "Taken"
        },
        {
          "alias": "characterSource",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "Destiny: The Taken King"
        },
        {
          "alias": "details",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "During the Taken War, Oryx would Take Sekrion as the Vex were fixing the Hydra and adding the Templar\u0027s shield to it. The Vex were hoping to make Sekrion indestructible in order to allow the Hydra to finish its work on converting Venus, but Oryx foiled their plans right away. A fireteam of Guardians arrived to defeat the resurrected Sekrion, being surprised to see it Taken and protected by an indestructible barrier."
        },
        {
          "alias": "profilePicture",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": [
            {
              "key": "6f13262b-270c-42d4-8aaa-75b6e91790b1",
              "mediaKey": "a12299bf-be8e-48ad-bc9a-02cabaad0307",
              "mediaTypeAlias": "Image",
              "crops": [],
              "focalPoint": null
            }
          ]
        },
