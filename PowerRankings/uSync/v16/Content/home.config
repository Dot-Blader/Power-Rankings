          "segment": null,
          "value": "STRIDER"
        },
        {
          "alias": "characterSource",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "Sonic Frontiers"
        },
        {
          "alias": "details",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "STRIDER guardians were found on Ares Island, positioned in such a way that they would cover large areas each. They were equipped with advanced weapons and durable armor. They would utilize electricity as weapons by unleashing the electric energy contained within their core, striking enemies like lightning."
        }
      ]
    },
