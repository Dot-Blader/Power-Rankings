        },
        {
          "alias": "profilePicture",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": [
            {
              "key": "eabe5352-eb8c-4d7f-b186-4b7936f2f2ff",
              "mediaKey": "006239d5-507f-4862-a524-b69e52db8d20",
              "mediaTypeAlias": "Image",
              "crops": [],
              "focalPoint": null
