          "value": "Sonic CD"
        },
        {
          "alias": "characterName",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "Noro-Noro"
        },
        {
          "alias": "details",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "Noro-Noro was a typical Badnik assigned by Dr. Eggman to patrol the Quartz Quadrant during his occupation of Little Planet. When Sonic arrived to stop Eggman, the Noro-Noros would fight against Sonic. During the fighting large chunks of quartz would loosen and fall towards Sonic and the Badniks, but the metallic hulls of the Badniks withstood the falling debris without a scratch."
        },
        {
          "alias": "mainPicture",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": [
            {
              "key": "7570c539-5408-4238-93d9-abfc054c0a33",
              "mediaKey": "39a26e6f-ea01-4b3f-8145-9eb10a75b110",
              "mediaTypeAlias": "Image",
              "crops": [],
              "focalPoint": null
            }
          ]
        },
        {
          "alias": "characterTitle",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "Badnik"
        }
      ]
    },
    {
