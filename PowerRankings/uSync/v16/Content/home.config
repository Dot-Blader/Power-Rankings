          "alias": "characterName",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "Interceptor"
        },
        {
          "alias": "characterSource",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "Destiny"
        },
        {
          "alias": "profilePicture",
