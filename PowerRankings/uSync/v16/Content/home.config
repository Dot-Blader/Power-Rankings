                  },
                  {
                    "alias": "energyExponent",
                    "culture": null,
                    "editorAlias": null,
                    "segment": null,
                    "value": ""
                  },
                  {
                    "alias": "characterName",
                    "culture": null,
                    "editorAlias": null,
                    "segment": null,
                    "value": "Leviathan-Eater, Bane of the Ammonites"
                  },
                  {
                    "alias": "characterVariant",
                    "culture": null,
                    "editorAlias": null,
                    "segment": null,
                    "value": "Ascendant Plane"
                  },
                  {
                    "alias": "characterSource",
                    "culture": null,
                    "editorAlias": null,
                    "segment": null,
                    "value": "Destiny 2: Season of the Witch"
                  },
                  {
                    "alias": "details",
                    "culture": null,
                    "editorAlias": null,
                    "segment": null,
                    "value": "Originally named Ir Uulxal, the Leviathan-Eater struck the final blow on the Leviathan of Fundament during the Ammonite wars. He was the mightiest servant of Xivu Arath, acting as her foremost commander. He would be summoned by Xivu to Savath\u00FBn\u0027s Throne World to destroy the Young Wolf and Eris Morn, as they were trying to grow Eris strong enough to face Xivu herself. He was one of the oldest Hive in the universe, having been born on Fundament before the Krill became the Hive."
                  },
                  {
                    "alias": "profilePicture",
                    "culture": null,
                    "editorAlias": null,
                    "segment": null,
                    "value": [
                      {
                        "key": "fb380a59-7e7e-4058-94c5-970012698514",
                        "mediaKey": "492afc32-ee10-40ee-bbf9-5b87abb7bc4a",
                        "mediaTypeAlias": "Image",
                        "crops": [],
                        "focalPoint": null
                      }
                    ]
                  },
                  {
                    "alias": "characterTitle",
                    "culture": null,
                    "editorAlias": null,
                    "segment": null,
                    "value": "Favoured Harbinger of Xivu Arath"
                  },
                  {
                    "alias": "mainPicture",
                    "culture": null,
                    "editorAlias": null,
                    "segment": null,
                    "value": [
                      {
                        "key": "68d6febc-2fd7-494d-a54b-f4a221cee342",
                        "mediaKey": "8c6ce97e-05a4-4876-ada4-e50da19131e9",
