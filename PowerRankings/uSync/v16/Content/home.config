          ]
        },
        {
          "alias": "characterName",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "MASTER NINJA"
        },
        {
          "alias": "characterSource",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "Sonic Frontiers"
        },
        {
          "alias": "details",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "MASTER NINJAs were the strongest guardians built by the Ancients. They were stationed on Ouranos Island, protecting the sealed Titan SUPREME from hostile threats. They were more advanced than any other version of the NINJA guardian, with stronger armor, superior agility, quicker reflexes and disorientation-based abilities."
        }
      ]
    },
    {
      "contentTypeKey": "6f386c25-c5f7-4cc6-8761-a63a480078ba",
