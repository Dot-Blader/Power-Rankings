        {
          "alias": "characterName",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "Dreg"
        },
        {
          "alias": "characterSource",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "Destiny"
        },
        {
          "alias": "details",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "When an Eliksni is shamed by its superiors, they have their lower arms docked and are starved of Ether so they shrink and become weaker. These are the Dreg, and due to not having anything left to lose, and everything to gain, they fight ferociously. "
        }
      ]
    },
    {
      "contentTypeKey": "6f386c25-c5f7-4cc6-8761-a63a480078ba",
      "key": "8612904c-2534-43e5-8677-d432c724d343",
