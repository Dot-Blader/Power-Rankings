                    "segment": null,
                    "value": "Destiny: The Taken King"
                  },
                  {
                    "alias": "details",
                    "culture": null,
                    "editorAlias": null,
                    "segment": null,
                    "value": "The Hands of Oryx were two beings Taken by Oryx during the Taken War. After having lost two members of his Court Oryx needed replacements, and chose two promising champions to act as his left and right hands in the war."
                  },
                  {
                    "alias": "groupMembers",
                    "culture": null,
                    "editorAlias": null,
                    "segment": null,
                    "value": {
                      "contentData": [
                        {
