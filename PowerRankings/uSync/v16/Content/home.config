        {
          "alias": "characterName",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "The Guests"
        },
        {
          "alias": "characterSource",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "Little Nightmares"
        },
        {
          "alias": "details",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "The Guests are residents of the Nowhere who are ravenous with hunger. They are brought to the Maw in order to feast on the food made by the Chefs, and will eat basically anything put on their plate. Due to their massive size, they are incredibly strong, able to smash tables apart easily whilst aggressively chasing Six in hopes of getting a small snack."
        },
        {
          "alias": "characterTitle",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": ""
        }
      ]
    },
    {
      "contentTypeKey": "6f386c25-c5f7-4cc6-8761-a63a480078ba",
