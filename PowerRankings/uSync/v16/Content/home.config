        {
          "alias": "characterName",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "TANK"
        },
        {
          "alias": "characterSource",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "Sonic Frontiers"
        },
        {
          "alias": "details",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "TANKs were one of the strongest guardians built by the Ancients. They patrolled Ares Island\u0027s hot deserts, and were as heavily armored as their name suggests. They were armed with various weapons, and had the ability to generate a massive tornado on the spot, engulfing and disorienting any opponents as it assaulted them with its weapons."
        }
      ]
    },
    {
      "contentTypeKey": "6f386c25-c5f7-4cc6-8761-a63a480078ba",
