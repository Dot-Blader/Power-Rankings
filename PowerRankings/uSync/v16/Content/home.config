        },
        {
          "alias": "profilePicture",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": [
            {
              "key": "d0335bc7-42f1-42db-aa8a-970c58b4a90e",
              "mediaKey": "d3ec6c61-1b9f-45ac-a793-ad75f45059ea",
