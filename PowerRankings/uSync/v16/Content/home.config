          "value": [
            {
              "key": "2fad8808-d84d-46cb-9322-138fbf81af2a",
              "mediaKey": "be6d12ea-859c-4337-a2d8-889c06fb91d0",
              "mediaTypeAlias": "Image",
              "crops": [],
              "focalPoint": null
            }
          ]
        },
        {
          "alias": "characterName",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "Two Super States"
        },
        {
          "alias": "characterSource",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "Sonic the Hedgehog"
        },
        {
          "alias": "details",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "The combined power of two Chaos Emerald-enhanced beings increases up to 6-Dimensional power. With this Sonic and his younger self were able to defeat the Time Eater, and Super Sonic fighting together with Burning Blaze could defeat the Egg Wizard. The combined power of Super Sonic and the Titan SUPREME was enough to defeat THE END before it had regained its original strength."
        }
      ]
    },
    {
      "contentTypeKey": "6f386c25-c5f7-4cc6-8761-a63a480078ba",
      "key": "6f901a41-8096-4dfb-9add-7a4f83ac1265",
      "udi": null,
      "values": [
        {
          "alias": "energyMultiplicator",
