            }
          ]
        },
        {
          "alias": "characterName",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "Walker"
        },
        {
          "alias": "characterSource",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "Destiny"
        },
        {
          "alias": "details",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "Walkers are heavily armored autonomous machines made by the Fallen. They have an on-board Shank factory that can produce maintenance drones mid-combat, allowing them to stay in combat for long periods of time. They have weapons fit for dealing with both small and large targets, with a massive anti-air gun mounted on a rotating turret on the top."
        },
        {
          "alias": "characterTitle",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "Spider Tank"
        }
      ]
    },
    {
      "contentTypeKey": "6f386c25-c5f7-4cc6-8761-a63a480078ba",
      "key": "2f0f4826-41bb-4a43-9de2-fd2052654dea",
      "udi": null,
      "values": [
        {
          "alias": "energyMultiplicator",
          "culture": null,
          "editorAlias": null,
