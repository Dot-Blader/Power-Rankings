          "editorAlias": null,
          "segment": null,
          "value": "Destiny"
        },
        {
          "alias": "details",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "Harpies are mobile and can fly. They are assigned to scout and patrol Vex territories, and can scan for targets and gather data more efficiently than other Vex frames."
        }
      ]
    },
    {
      "contentTypeKey": "6f386c25-c5f7-4cc6-8761-a63a480078ba",
