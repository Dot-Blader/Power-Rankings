                  },
                  {
                    "alias": "characterName",
                    "culture": null,
                    "editorAlias": null,
                    "segment": null,
                    "value": "Sylok, the Defiled"
                  },
                  {
                    "alias": "characterVariant",
                    "culture": null,
                    "editorAlias": null,
                    "segment": null,
                    "value": "Material Space"
                  },
                  {
                    "alias": "characterSource",
                    "culture": null,
                    "editorAlias": null,
                    "segment": null,
                    "value": "Destiny 2: Episode: Revenant"
                  },
                  {
                    "alias": "details",
                    "culture": null,
                    "editorAlias": null,
                    "segment": null,
                    "value": "Sylok was imprisoned by the Awoken, but manipulated them into torturing him so he could grow stronger with the Darkness through overcoming the pain. He would be challenged by a Guardian and defeated. but about ten years later he returned to face his killer, now being Ascendant and having a more intimidating appearance."
                  },
                  {
                    "alias": "mainPicture",
                    "culture": null,
                    "editorAlias": null,
                    "segment": null,
                    "value": [
                      {
                        "key": "c0556baf-e149-48f5-91e4-97652cee4eb0",
                        "mediaKey": "048d9922-c79c-4544-8fe8-8c3e73f75dc1",
                        "mediaTypeAlias": "Image",
                        "crops": [],
                        "focalPoint": null
                      }
                    ]
                  }
                ]
              },
              {
                "contentTypeKey": "6f386c25-c5f7-4cc6-8761-a63a480078ba",
                "key": "ae12667a-0f90-4f04-b3d6-83402aa506f4",
                "udi": null,
                "values": [
                  {
                    "alias": "profilePicture",
