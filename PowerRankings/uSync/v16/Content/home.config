                  {
                    "alias": "characterSource",
                    "culture": null,
                    "editorAlias": null,
                    "segment": null,
                    "value": "Destiny 2: Season of the Risen"
                  },
                  {
                    "alias": "characterName",
                    "culture": null,
                    "editorAlias": null,
                    "segment": null,
                    "value": "Qabix, Insurgent"
                  },
                  {
                    "alias": "details",
                    "culture": null,
                    "editorAlias": null,
                    "segment": null,
                    "value": "Qabix was a Psion who led the defectors from the Cabal Empire on Mars, working for Yirix\u0027s enclave. He broadcast propaganda hoping to see more Psions defect, and gained support from Calus. The propaganda included information about the future he had gained through his psionic premonitions."
                  }
                ]
              },
              {
                "contentTypeKey": "6f386c25-c5f7-4cc6-8761-a63a480078ba",
                "key": "dde92e11-8c65-410f-9a52-aa1c36ecf621",
                "udi": null,
                "values": [
                  {
                    "alias": "profilePicture",
                    "culture": null,
