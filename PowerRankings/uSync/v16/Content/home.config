          "alias": "characterName",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "Ir Nithra, Scourge of the Ammonite"
        },
        {
          "alias": "characterSource",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "Destiny 2: Season of the Seraph"
        },
        {
          "alias": "details",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "Ir Nithra was a Wizard who fought for Xivu Arath against the Ammonite during the early times of the Hive. She would be deployed with Ir Hanal to conquer a Seraph Complex and hold it as Guardians assaulted it."
        },
        {
          "alias": "energyExponent",
