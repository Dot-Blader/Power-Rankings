                  },
                  {
                    "alias": "characterName",
                    "culture": null,
                    "editorAlias": null,
                    "segment": null,
                    "value": "Ixel, the Far-Reaching"
                  },
                  {
                    "alias": "characterSource",
                    "culture": null,
                    "editorAlias": null,
                    "segment": null,
                    "value": "Destiny 2: Season of the Chosen"
                  },
                  {
                    "alias": "details",
                    "culture": null,
                    "editorAlias": null,
                    "segment": null,
                    "value": "Ixel was a Psion Triune who sought to gain favor with Empress Caiatl by supplying tactical information that could help the Empire win its future wars. Ixel wanted to investigate the Vex\u0027s technology and use her psionic abilities to compare premonitions of the future with the Vex\u0027s simulations of the future. Her Valus didn\u0027t care for this idea, so she slew him and took over the command of the squad."
                  }
                ]
              },
              {
                "contentTypeKey": "6f386c25-c5f7-4cc6-8761-a63a480078ba",
                "key": "d98ccdfb-65af-428b-9835-7553c061f185",
