    {
      "contentTypeKey": "6f386c25-c5f7-4cc6-8761-a63a480078ba",
      "key": "fcb03786-0d1b-4e6a-b621-ef315fb0ba88",
      "udi": null,
      "values": [
        {
          "alias": "energyMultiplicator",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "1,51"
        },
        {
          "alias": "characterName",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "Tekton, Constructive Mind"
        },
        {
          "alias": "characterSource",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "Destiny 2"
        },
        {
          "alias": "details",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "Tekton was the Axis Mind in charge of transforming the Jovian moon Io into a Machine-World. It was discovered by Asher Mir, who would send his assistant Guardian to take out the mind in order to hinder the Vex\u0027s progress with their conversion. It was using data received from the nearby Pyramidion, giving insight to how the Vex conversions work and why most worlds with a Vex presence appear to have Pyramidions built early in the process."
        },
        {
          "alias": "energyExponent",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "29"
        },
        {
          "alias": "profilePicture",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": [
