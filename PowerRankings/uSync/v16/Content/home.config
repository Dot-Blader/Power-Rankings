            }
          ]
        },
        {
          "alias": "characterName",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "The Undying Mind"
        },
        {
          "alias": "characterSource",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "Destiny: The Dark Below"
        },
        {
          "alias": "details",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "The Undying Mind was an ancient Vex Hydra built to keep the Black Garden sealed away from material space. It was seen as integral to the Vex\u0027s ability to convert the universe according to their designs, as losing control over the Black Garden could allow the Vex\u0027s enemies to gain an advantage over them. To make sure this Mind would be undying, it was able to be recovered from destruction through summoning a copy of it from another timeline. "
        },
        {
          "alias": "energyExponent",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "28"
        }
      ]
    },
    {
      "contentTypeKey": "6f386c25-c5f7-4cc6-8761-a63a480078ba",
      "key": "20e12c6b-3e94-41ba-b036-55d86af1e205",
      "udi": null,
      "values": [
