        {
          "alias": "characterVariant",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "Ascendant Plane"
        },
        {
          "alias": "characterName",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "Oryx, the Taken King"
        },
        {
          "alias": "characterTitle",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "First Navigator, King of Shapes"
        },
        {
          "alias": "details",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "Within the Ascendant Plane Oryx\u0027s true power and appearance could be seen. With his power to Take, he would attempt to take the entire Vex Network, and only failed due to Guardians interfering. Even with the powers of infinite-dimensional existence itself the Vex couldn\u0027t stop Oryx on their own, showing the true extent of his might."
        },
        {
          "alias": "characterSource",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "Destiny: The Taken King"
        },
        {
          "alias": "energyMultiplicator",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "Infinite-Dimensional"
        }
      ]
    },
