                      }
                    ]
                  },
                  {
                    "alias": "characterSource",
                    "culture": null,
                    "editorAlias": null,
                    "segment": null,
                    "value": "Destiny 2: Lightfall"
                  },
                  {
                    "alias": "characterName",
                    "culture": null,
                    "editorAlias": null,
                    "segment": null,
                    "value": "Valus Tharum"
                  },
                  {
                    "alias": "characterTitle",
                    "culture": null,
                    "editorAlias": null,
                    "segment": null,
                    "value": "Gladitorial Overseer"
                  },
                  {
                    "alias": "details",
                    "culture": null,
                    "editorAlias": null,
                    "segment": null,
                    "value": "Tharum oversaw a \u0022secret\u0022 fighting pit inside the Typhon Imperator. Calus knew about this activity, but allowed it to exist because he saw the value in letting his men train against each other and experiment with their new Pyramid-tech. When a Guardian of the Last City found the secret entrance to the fighting pit, Valus Tharum sent his fighters to stop the Guardian. After failing, and letting the Guardian reach the central fighting pit, Valus Tharum had had enough. He entered the arena through a Cabal Drop Pod, instantly killing a Centurion champion who was awaiting a chance to fight he Lightbearer."
                  }
                ]
              },
              {
                "contentTypeKey": "6f386c25-c5f7-4cc6-8761-a63a480078ba",
                "key": "4561d37c-1cff-4059-b04e-516dca9fe517",
                "udi": null,
                "values": [
                  {
                    "alias": "profilePicture",
                    "culture": null,
                    "editorAlias": null,
