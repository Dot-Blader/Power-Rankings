        },
        {
          "alias": "characterName",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "The Viewers"
        },
        {
          "alias": "characterSource",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "Little Nightmares 2"
        },
        {
          "alias": "details",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "The Viewers are what remains of the residents of the Pale City. They have become so obsessed with watching TV due to the Transmission emitted from the Signal Tower that they\u0027ve begun to lose who they are to it. Their faces are warped and barely existent anymore, and are well on their way to having their entire bodies consumed by the Signal Tower. They would be pretty average as far as residents go if it wasn\u0027t for the fact that they could direct the Transmission towards any unwanted visitors who got near them by just moving their heads to face their target, killing the visitor on the spot."
        },
        {
          "alias": "mainPicture",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": [
            {
              "key": "f61e8ccd-ecdb-490a-9033-71da845b2da5",
