          "segment": null,
          "value": "2,64"
        },
        {
          "alias": "characterSource",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "Destiny 2: Season of the Forge"
        },
        {
          "alias": "characterName",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "Insurrection Prime"
        },
        {
          "alias": "details",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "Insurrection Prime was the Prime Servitor of the criminal syndicate known as Kell\u0027s Scourge. It was put inside a massive machine, which was built out of parts from Walkers, a design that would later be used for Brigs. It was placed in the Last City during a raid the syndicate led on a hidden Black Armory facility. The mech was enhanced with technology stolen from the weapon foundry, and was set to destroy the entirety of the Last City using these weapons once the Kell\u0027s Scourge had finished stealing weapons and data."
        },
        {
          "alias": "energyExponent",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "16"
        },
        {
