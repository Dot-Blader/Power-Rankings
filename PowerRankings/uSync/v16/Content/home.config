        {
          "alias": "characterName",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "Gate Lords"
        },
        {
          "alias": "characterSource",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "Destiny"
        },
        {
          "alias": "details",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "Gate Lords are powerful Minotaurs of the Vex who protect gates that lead into the Vex Network. They maintain the gates\u0027 systems and draw power from them, and can use that power to enhance their defenses or offensive weapons. "
        },
        {
          "alias": "energyExponent",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "28"
        },
        {
