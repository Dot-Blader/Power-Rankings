                    "value": ""
                  },
                  {
                    "alias": "details",
                    "culture": null,
                    "editorAlias": null,
                    "segment": null,
                    "value": "Like all Taken Nixis\u0027s soul was returned to the Ascendant Plane after his defeat, and his ultimate fate remains unknown."
                  }
                ]
              },
              {
                "contentTypeKey": "6f386c25-c5f7-4cc6-8761-a63a480078ba",
