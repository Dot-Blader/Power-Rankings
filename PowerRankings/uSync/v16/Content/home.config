                              ]
                            },
                            {
                              "alias": "characterName",
                              "culture": null,
                              "editorAlias": null,
                              "segment": null,
                              "value": "Ir Halak, Deathsinger"
                            },
                            {
                              "alias": "characterTitle",
                              "culture": null,
                              "editorAlias": null,
                              "segment": null,
                              "value": "The Unraveler"
                            },
                            {
                              "alias": "characterVariant",
                              "culture": null,
                              "editorAlias": null,
                              "segment": null,
                              "value": "Ascendant Plane"
                            },
                            {
                              "alias": "details",
                              "culture": null,
                              "editorAlias": null,
                              "segment": null,
                              "value": "Ir Halak unraveled the very fabric of material space in order to allow the Dreadnaught to travel through a manipulated pocket of interdimensional space. She and her sister would be assaulted and defeated by a fireteam as they were conducting this process."
                            },
                            {
                              "alias": "mainPicture",
                              "culture": null,
                              "editorAlias": null,
                              "segment": null,
                              "value": [
                                {
                                  "key": "6b4a8a48-6854-4d91-9612-8b4b6187fbe1",
                                  "mediaKey": "f8402d20-1c4d-4556-b90a-b3f91d66dc96",
                                  "mediaTypeAlias": "Image",
                                  "crops": [],
                                  "focalPoint": null
                                }
                              ]
                            }
                          ]
                        },
                        {
                          "contentTypeKey": "6f386c25-c5f7-4cc6-8761-a63a480078ba",
                          "key": "5c522d99-da33-4a49-9465-1f58b66352bd",
                          "udi": null,
                          "values": [
                            {
                              "alias": "characterSource",
                              "culture": null,
                              "editorAlias": null,
                              "segment": null,
                              "value": "Destiny: The Taken King"
                            },
                            {
                              "alias": "characterName",
                              "culture": null,
                              "editorAlias": null,
                              "segment": null,
                              "value": "Ir An\u00FBk, Deathsinger"
                            },
                            {
                              "alias": "characterTitle",
                              "culture": null,
                              "editorAlias": null,
                              "segment": null,
                              "value": "The Weaver"
                            },
                            {
                              "alias": "characterVariant",
                              "culture": null,
                              "editorAlias": null,
                              "segment": null,
                              "value": "Ascendant Plane"
                            },
                            {
                              "alias": "details",
                              "culture": null,
                              "editorAlias": null,
                              "segment": null,
                              "value": "After the unraveling of Ir Halak, Ir An\u00FBk would weave the universe\u0027s fabric back behind the Dreadnaught, cementing the titanic warship\u0027s presence in an interdimensional pocket of material space. During the sisters\u0027 performance of this task, they would be attacked, and experienced final deaths at the hands of a fireteam of Guardians."
                            },
                            {
                              "alias": "profilePicture",
                              "culture": null,
                              "editorAlias": null,
                              "segment": null,
                              "value": [
                                {
                                  "key": "dee7368f-2762-43ec-80b9-4c2eb50416a5",
