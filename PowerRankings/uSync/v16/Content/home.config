        },
        {
          "alias": "characterName",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "The Hunter"
        },
        {
          "alias": "characterSource",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "Little Nightmares 2"
        },
        {
          "alias": "details",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "The Hunter lived in the wilderness just outside of the Pale City. He captured both residents and visitors, and stuffed them after killing them. He had a passion for taxidermy, and wielded a typical double-barreled shotgun that he used to hunt down his next target."
        }
      ]
    },
    {
      "contentTypeKey": "6f386c25-c5f7-4cc6-8761-a63a480078ba",
      "key": "58122ac1-efb0-484f-9d43-37f587045153",
      "udi": null,
      "values": [
        {
          "alias": "energyMultiplicator",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "2"
        },
        {
          "alias": "energyExponent",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "0"
        },
        {
          "alias": "details",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "The Mini-Kin was a very small resident. He was usually found attached to the Kin\u0027s arm like a dummy, but was also alive and appears to have been organic and completely sentient. He was about as large as a child, which helped him catch runaway children who may have tried to escape the Carnevale through areas too small for the Kin to fit inside. The Kin fed parts from dead Herd to the Mini-Kin, and their influence on the Nowhere was great enough that paintings of the Mini-Kin can be found all over the place, including the Maw."
        },
        {
          "alias": "profilePicture",
          "culture": null,
          "editorAlias": null,
          "segment": null,
