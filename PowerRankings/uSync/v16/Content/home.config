          "segment": null,
          "value": [
            {
              "key": "fcfff9ed-9489-4287-a3b6-9ed201a1cc3f",
              "mediaKey": "508453ff-e507-46be-b808-17c69e563eba",
              "mediaTypeAlias": "Image",
              "crops": [],
