        },
        {
          "alias": "characterName",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "Thresher"
        },
        {
          "alias": "profilePicture",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": [
            {
              "key": "38d98add-6ad7-4c13-8622-e80d2acf0768",
              "mediaKey": "af29d148-85da-4d89-a231-8a69d1232009",
              "mediaTypeAlias": "Image",
              "crops": [],
              "focalPoint": null
            }
          ]
        },
        {
          "alias": "characterSource",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "Destiny 2"
        },
        {
          "alias": "details",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "Threshers are the standard single-pilot fighters used by the Cabal Empire. They are highly maneuverable and are armed with a strong cannon on their bottom that can fire auto-tracking missiles. They would usually only engage other ships in combat, but the Red Legion started using them to deal with ground-based threats such as tanks and the Guardians of the Last City during the Red War. This tactic was effective, and would continue to be used by most legions of Cabal everywhere."
        },
        {
          "alias": "energyExponent",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "11"
        },
        {
          "alias": "mainPicture",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": [
            {
              "key": "ad4a0fd6-74af-433a-a89d-433185e3ba39",
              "mediaKey": "e2192266-36fb-4867-b808-2dcbf1f2dc6f",
              "mediaTypeAlias": "Image",
              "crops": [],
              "focalPoint": null
            }
          ]
        }
      ]
    },
    {
      "contentTypeKey": "6f386c25-c5f7-4cc6-8761-a63a480078ba",
      "key": "1968b101-1d5f-49c0-a861-aaa05a3890b7",
      "udi": null,
      "values": [
        {
          "alias": "energyMultiplicator",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "1,14"
        },
        {
          "alias": "profilePicture",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": [
            {
              "key": "b7bb2d03-9b5c-47ed-8512-bf51fd91d846",
              "mediaKey": "a26ce34c-1289-4d70-a5b2-1afcdaba170e",
              "mediaTypeAlias": "Image",
              "crops": [],
              "focalPoint": null
            }
          ]
        },
        {
          "alias": "characterName",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "Harvester"
        },
        {
          "alias": "characterSource",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "Destiny"
        },
        {
          "alias": "details",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "Harvesters are the main dropships used by the Cabal for troop-deployment. Their armor can withstand most smaller threats, allowing them to drop troops directly into the middle of an active battlefront without being brought down. To support these Cabal the Harvester has a rotating turret that fires tracking missiles on the front."
        },
        {
          "alias": "mainPicture",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": [
            {
              "key": "afeca855-e58a-48b1-b093-e2b807e5d1d3",
              "mediaKey": "52e1edb2-ba4b-487b-a813-e9da66b54233",
              "mediaTypeAlias": "Image",
              "crops": [],
              "focalPoint": null
            }
          ]
        },
        {
