                "key": "5b60982c-5c39-4bfe-b0e8-0b714ed2cf1d",
                "udi": null,
                "values": [
                  {
                    "alias": "characterName",
                    "culture": null,
                    "editorAlias": null,
                    "segment": null,
                    "value": "Dumuzod"
                  },
                  {
                    "alias": "characterVariant",
                    "culture": null,
                    "editorAlias": null,
                    "segment": null,
                    "value": "Ascendant Plane"
                  },
                  {
                    "alias": "characterSource",
                    "culture": null,
                    "editorAlias": null,
                    "segment": null,
                    "value": "Destiny: The Taken King"
                  },
                  {
                    "alias": "details",
                    "culture": null,
                    "editorAlias": null,
                    "segment": null,
                    "value": "After being defeated by the Young Wolf, Dumuzod\u0027s soul returned to the Ascendant Plane. He would be resummoned to material space by any Guardians who challenged his servants like the Young Wolf. His clashing against Guardians continued until the Red War, but after that his ultimate fate is unknown."
                  },
                  {
                    "alias": "profilePicture",
                    "culture": null,
                    "editorAlias": null,
