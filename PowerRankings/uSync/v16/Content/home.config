        {
          "alias": "characterName",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "The Herd"
        },
        {
          "alias": "characterSource",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "Little Nightmares 3"
        },
        {
          "alias": "details",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "The Herd is the name for the large residents of the Spiral, a location within the Nowhere. They are found both working in the Candy Factory and visiting the Carnevale, and possess great strength. It appears that some of the Herd acquire facemasks and travel to the Maw, being invited there as Guests."
        },
        {
          "alias": "groupMembers",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": {
            "contentData": [
              {
                "contentTypeKey": "6f386c25-c5f7-4cc6-8761-a63a480078ba",
                "key": "bed871e3-9dbd-4238-9d48-21f90fed8a5a",
