                            },
                            {
                              "alias": "details",
                              "culture": null,
                              "editorAlias": null,
                              "segment": null,
                              "value": "It is unknown what happened to the Might of Crota after being defeated in material space by the Young Wolf. Its soul would have returned to its Throne World in the Ascendant Plane, but after that its fate is unknown."
