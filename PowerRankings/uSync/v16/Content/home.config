                "udi": null,
                "values": [
                  {
                    "alias": "characterName",
                    "culture": null,
                    "editorAlias": null,
                    "segment": null,
                    "value": "Kagoor"
                  },
                  {
                    "alias": "characterTitle",
                    "culture": null,
                    "editorAlias": null,
                    "segment": null,
                    "value": "World-Render"
                  },
                  {
                    "alias": "characterVariant",
                    "culture": null,
                    "editorAlias": null,
                    "segment": null,
                    "value": "Material Space"
                  },
                  {
                    "alias": "details",
                    "culture": null,
                    "editorAlias": null,
                    "segment": null,
                    "value": "Kagoor was a Taken Wizard created onto the Court of Oryx representing the shape of joy. She had the ability to tame and control any Hive Ogre, and her death was hidden in the Ogres she commanded. "
                  },
                  {
                    "alias": "characterSource",
                    "culture": null,
                    "editorAlias": null,
                    "segment": null,
                    "value": "Destiny: The Taken King"
