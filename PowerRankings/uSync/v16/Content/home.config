                  {
                    "alias": "characterName",
                    "culture": null,
                    "editorAlias": null,
                    "segment": null,
                    "value": "Ungoloth, Wayward Beast"
                  },
                  {
                    "alias": "characterSource",
                    "culture": null,
                    "editorAlias": null,
                    "segment": null,
                    "value": "Destiny 2: Season of the Wish"
                  },
                  {
                    "alias": "details",
                    "culture": null,
                    "editorAlias": null,
                    "segment": null,
                    "value": "Ungoloth was an incredibly strong Taken Ogre. Mara Sov sensed that the energy within this Ogre would destabilize the Ley Lines, which bind the Ascendant Plane and Material Space together. This level of power is exactly what Ascendant beings have, breaching the material world with just their strength alone."
                  },
                  {
                    "alias": "characterVariant",
                    "culture": null,
                    "editorAlias": null,
                    "segment": null,
                    "value": "Material Space"
                  }
                ]
              },
