          "alias": "characterName",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "Colossus"
        },
        {
          "alias": "characterSource",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "Destiny"
        },
        {
          "alias": "mainPicture",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": [
            {
              "key": "956c1806-1701-4f13-9dc1-706723b414ac",
              "mediaKey": "f46704a3-a37f-4084-a18b-0c185cb4c217",
              "mediaTypeAlias": "Image",
              "crops": [],
              "focalPoint": null
            }
          ]
        },
        {
          "alias": "details",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "The Colossus is the toughest of the Cabal military\u0027s basic units. Their armor is heavier than other units, which is why it\u0027s only worn by Cabal who have grown older and larger than the average Legionary. When a Colossus walks, its steps can be felt throughout the area as the very ground trembles before them like a small earthquake. "
        }
      ]
    },
    {
      "contentTypeKey": "6f386c25-c5f7-4cc6-8761-a63a480078ba",
      "key": "5de6ced3-3a08-45da-9454-f49dd1a5d475",
