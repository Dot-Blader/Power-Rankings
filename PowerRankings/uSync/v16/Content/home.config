                  },
                  {
                    "alias": "characterName",
                    "culture": null,
                    "editorAlias": null,
                    "segment": null,
                    "value": "Bracus Payne, the Called Hand"
                  },
                  {
                    "alias": "characterVariant",
                    "culture": null,
                    "editorAlias": null,
                    "segment": null,
                    "value": "Material Space"
                  },
                  {
                    "alias": "characterSource",
                    "culture": null,
                    "editorAlias": null,
                    "segment": null,
                    "value": "Destiny 2: Forsaken"
                  },
                  {
                    "alias": "details",
                    "culture": null,
                    "editorAlias": null,
                    "segment": null,
                    "value": "Bracus Payne was a Taken Centurion who was summoned to various places around the Dreaming City in order to spread the Blight of the Taken. He controlled an Ascendant Blight which he used to force Taken troops into the city to lead the charge, but would be defeated multiple times and forced to return to the Ascendant Plane."
                  }
                ]
              },
              {
                "contentTypeKey": "6f386c25-c5f7-4cc6-8761-a63a480078ba",
                "key": "c17910ab-d1e3-4ee9-8f9b-046d02a34485",
                "udi": null,
                "values": [
                  {
                    "alias": "characterName",
                    "culture": null,
                    "editorAlias": null,
                    "segment": null,
                    "value": "Vakarsik, Grasp of Quria"
                  },
                  {
                    "alias": "characterVariant",
                    "culture": null,
                    "editorAlias": null,
                    "segment": null,
                    "value": "Material Space"
                  },
                  {
                    "alias": "characterSource",
                    "culture": null,
                    "editorAlias": null,
                    "segment": null,
                    "value": "Destiny 2: Forsaken"
                  },
                  {
                    "alias": "details",
                    "culture": null,
                    "editorAlias": null,
                    "segment": null,
                    "value": "Vakarsik was a servant of Quria who was at some point defeated in material space and forced back into the Ascendant Plane. Its Taken servants would attempt to resurrect and return Vakarsik to material space by using the Ascendant energies of the Awoken\u0027s Rift Generator. Once restored, Vakarisk would have used their own Ascendant power to assault the Dreaming City."
                  }
                ]
              },
              {
                "contentTypeKey": "6f386c25-c5f7-4cc6-8761-a63a480078ba",
                "key": "0d63f872-21c2-4510-a136-b77f1c9fafc6",
                "udi": null,
                "values": [
