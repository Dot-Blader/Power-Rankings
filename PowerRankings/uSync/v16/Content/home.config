                  {
                    "alias": "characterName",
                    "culture": null,
                    "editorAlias": null,
                    "segment": null,
                    "value": "Eschaton Mind"
                  },
                  {
                    "alias": "characterSource",
                    "culture": null,
                    "editorAlias": null,
                    "segment": null,
                    "value": "Destiny"
                  },
                  {
                    "alias": "details",
                    "culture": null,
                    "editorAlias": null,
                    "segment": null,
                    "value": "The Eschaton Mind was a Minotaur of a present design, created to represent the present in the Sol Progeny. If it hadn\u0027t been destroyed by a Guardian before it was fully charged, it would have allowed the Vex to alter the present of the entire infinite universe."
                  }
                ]
              },
              {
                "contentTypeKey": "6f386c25-c5f7-4cc6-8761-a63a480078ba",
                "key": "fc65dc1e-6261-4f06-b710-a107cc4224f0",
