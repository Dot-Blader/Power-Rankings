                  },
                  {
                    "alias": "characterSource",
                    "culture": null,
                    "editorAlias": null,
                    "segment": null,
                    "value": "Destiny 2: Season of Opulence"
                  },
                  {
                    "alias": "characterName",
                    "culture": null,
                    "editorAlias": null,
                    "segment": null,
                    "value": "Gahlran, the Sorrow-Bearer"
                  },
                  {
                    "alias": "details",
                    "culture": null,
                    "editorAlias": null,
                    "segment": null,
                    "value": "Gahlran was a Barant created by Exiled Emperor Calus for the specific purpose of bearing the Crown of Sorrow. Calus hoped that he would be able to use Gahlran to control the Hive, but moments after putting the Crown on Gahlran\u0027s mind was overtaken by Savath\u00FBn. He became a vassal to her power, and would take over leadership of the Hive found within Calus\u0027s Leviathan, but would use them for Savath\u00FBn\u0027s purposes. Calus would send for his favourite Guardian to come and destroy this failed Cabal before he could cause too many issues. "
                  },
                  {
                    "alias": "characterVariant",
                    "culture": null,
                    "editorAlias": null,
                    "segment": null,
                    "value": "Material Space"
                  },
                  {
                    "alias": "characterTitle",
                    "culture": null,
                    "editorAlias": null,
                    "segment": null,
                    "value": "Hive Commander"
                  }
                ]
              },
              {
                "contentTypeKey": "6f386c25-c5f7-4cc6-8761-a63a480078ba",
                "key": "87de1a25-8564-4b89-9667-9c6b19bcaefd",
