        {
          "alias": "characterName",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "Malok, Pride of Oryx"
        },
        {
          "alias": "characterSource",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "Destiny: The Taken King"
        },
        {
          "alias": "details",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "Malok was a son of Savath\u00FBn, the Witch Queen, who was placed in servitude of Oryx. His mother had intended for Malok to secretly steal tithes from Oryx and send them to her, but he proved himself to be a true son of the God of trickery by instead using them to grow stronger himself. Oryx would discover this, and would Take Malok and name him his Pride, to spite Savath\u00FBn. After the fall of Oryx, Malok would seek to take the vacant Osmium Throne, and experimented with controlling Taken Blights. "
        },
        {
          "alias": "energyExponent",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "28"
        },
