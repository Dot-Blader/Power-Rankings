                        "mediaKey": "65f7c36f-0415-49e5-b1af-e2aa8abea75e",
                        "mediaTypeAlias": "Image",
                        "crops": [],
                        "focalPoint": null
                      }
                    ]
                  },
                  {
                    "alias": "characterName",
                    "culture": null,
                    "editorAlias": null,
                    "segment": null,
                    "value": "Valus Pra\u0027um"
                  },
                  {
                    "alias": "characterSource",
                    "culture": null,
                    "editorAlias": null,
                    "segment": null,
                    "value": "Destiny 2: Lightfall"
                  },
                  {
                    "alias": "details",
                    "culture": null,
                    "editorAlias": null,
                    "segment": null,
                    "value": "Valus Pra\u0027um was a Gladiator of the Shadow Legion who was stationed inside the Typhon Imperator. He was overseeing the crucial task of coordinating the troops stationed just outside the main entrance of the Typhon Imperator at Ahimsa Park. Due  to his importance to the Cabal, he got a price on his head set by the citizens of Neomuna, and the price would be collected by a Guardian who entered the Typhon Imperator and faced Pra\u0027um one-on-one."
                  }
                ]
              },
              {
                "contentTypeKey": "6f386c25-c5f7-4cc6-8761-a63a480078ba",
                "key": "64275090-e68a-40f9-9983-2b37ee5c51f1",
