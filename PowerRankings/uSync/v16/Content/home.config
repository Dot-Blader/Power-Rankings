          "value": "Hiraks, the Mindbender"
        },
        {
          "alias": "characterTitle",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "Scorned Baron"
        },
        {
          "alias": "characterVariant",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "Ascendant Plane"
        },
        {
          "alias": "characterSource",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "Destiny 2: Forsaken"
        },
        {
          "alias": "details",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "Hiraks would become the first Eliksni and Scorn to create a Throne World through attaining sufficient power with the Darkness. Within this Throne World his power was absolute, and in the vastness of the Ascendant Plane\u0027s Sea of Screams his power was beyond anything any Eliksni or Scorn had ever imagined possible."
        },
        {
          "alias": "energyMultiplicator",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "5-Dimensional"
        }
      ]
    },
