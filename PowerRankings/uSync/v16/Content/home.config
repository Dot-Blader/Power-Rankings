        {
          "alias": "characterName",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "Silver Sonic"
        },
        {
          "alias": "characterSource",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "Sonic the Hedgehog 2"
        },
        {
          "alias": "details",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "Silver Sonic was an early attempt by Eggman to counter Sonic with a robot that could mimic his abilities. It was able to spin and use its sharp spikes in the same way Sonic could, and could almost match his speed. Its hull was built to the same level of resilience as the Egg Mobile, giving the robot a better chance at tackling Sonic."
        },
        {
          "alias": "mainPicture",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": [
            {
              "key": "5805c030-aede-4a26-9193-7c44149e4636",
              "mediaKey": "6389766c-11b7-4d4a-aef1-b2d33170d1e2",
              "mediaTypeAlias": "Image",
              "crops": [],
              "focalPoint": null
            }
          ]
        }
      ]
    },
