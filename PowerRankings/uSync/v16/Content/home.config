        {
          "alias": "characterName",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "Bracus Tho\u0027ourg"
        },
        {
          "alias": "characterSource",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "Destiny"
        },
        {
          "alias": "mainPicture",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": [
            {
              "key": "74c406db-3517-4d34-b034-b39395d6f657",
              "mediaKey": "d9332047-31b6-4082-9c5a-0b64a056f524",
              "mediaTypeAlias": "Image",
              "crops": [],
              "focalPoint": null
            }
          ]
        },
        {
          "alias": "details",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "A Bracus serves beneath a Val, which often leads to them being seen as lesser of status. This was not the case for Tho\u0027ourg however, as he had helped the Cabal Empire secure the lost city of Freehold on Mars with greater efficiency than any other commanders at the time."
        }
      ]
    },
    {
      "contentTypeKey": "6f386c25-c5f7-4cc6-8761-a63a480078ba",
      "key": "e74b85e3-de3d-46d0-82a2-9c4851780840",
      "udi": null,
      "values": [
        {
          "alias": "energyMultiplicator",
