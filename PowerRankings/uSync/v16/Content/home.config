          "value": [
            {
              "key": "7e6bd427-698f-48b7-b60d-a432fdb1e271",
              "mediaKey": "6e585b64-2573-4d78-a1b7-1fa59c411191",
              "mediaTypeAlias": "Image",
              "crops": [],
              "focalPoint": null
            }
          ]
        },
        {
          "alias": "characterName",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "Three Super States"
        },
        {
          "alias": "characterSource",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "SONIC HEROES"
        },
        {
          "alias": "mainPicture",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": [
            {
              "key": "84d9ff35-ed57-4e6f-81c5-0b3bdf64456e",
              "mediaKey": "31890664-4c9f-4990-aa46-3bffa2a3cf24",
              "mediaTypeAlias": "Image",
              "crops": [],
              "focalPoint": null
            }
          ]
        },
        {
          "alias": "details",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "To defeat Metal Overlord, Team Sonic had to charge the Chaos Emeralds to allow Super Sonic to share his power with Tails and Knuckles. With the three Super-powered beings fighting together, they were able to rival Metal Overlord\u0027s power, though only when using their strongest attacks. They would eventually succeed in defeating the mad robot, saving the world from his conquest in doing so."
        }
      ]
    },
    {
      "contentTypeKey": "6f386c25-c5f7-4cc6-8761-a63a480078ba",
      "key": "73eb12dc-3d46-42ad-be15-7ff598206f21",
      "udi": null,
