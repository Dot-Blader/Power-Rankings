                              "culture": null,
                              "editorAlias": null,
                              "segment": null,
                              "value": "Sardon, Fist of Crota"
                            },
                            {
                              "alias": "characterVariant",
                              "culture": null,
                              "editorAlias": null,
                              "segment": null,
                              "value": "Ascendant Plane"
                            },
                            {
                              "alias": "characterSource",
                              "culture": null,
                              "editorAlias": null,
                              "segment": null,
                              "value": "Destiny: The Dark Below"
                            },
                            {
                              "alias": "details",
                              "culture": null,
                              "editorAlias": null,
                              "segment": null,
                              "value": "Sardon was killed by the Young Wolf, and would have his soul returned to his Throne World in waiting to be brought back to material space by his followers. The Swarm Princes would have brought Sardon back, but they left him and the broods of Oryx to instead join Savath\u00FBn, leaving Sardon\u0027s fate unknown."
                            }
                          ]
                        },
                        {
