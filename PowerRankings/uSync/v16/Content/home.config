        },
        {
          "alias": "characterName",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "Guardian Armor"
        },
        {
          "alias": "characterSource",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "Destiny"
        },
        {
          "alias": "details",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "The armor worn by Guardians varies in strength, but the standard-issue armor most Titans wear is made of materials such as Relic Iron. With its ultra-dense strength this armor provides an incredible natural protection, only strengthened by the shielding of the inner Light of the Guardian. The shear weight of these armor pieces is so heavy that normal human beings are unable to wear them, lest they break their limbs."
        },
        {
          "alias": "energyExponent",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "10"
        },
        {
          "alias": "mainPicture",
          "culture": null,
