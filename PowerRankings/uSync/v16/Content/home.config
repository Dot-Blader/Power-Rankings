        },
        {
          "alias": "characterName",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "Zulmak, Instrument of Torment"
        },
        {
          "alias": "characterSource",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "Destiny 2: Shadowkeep"
        },
        {
          "alias": "details",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "Zulmak was originally a fighter in the Pit on Luna, striving to fill the void left by Crota and Oryx. After being slain, he was resurrected by Savath\u00FBn and gifted to the daughters of Crota in a soulless state. This emptyness would allow the daughters to fill Zulmak with the essences harnessed from the Nightmares summoned from Nezarec\u0027s Pyramid Ship. With the Guardian who slew Crota having arrived, a Nightmare of Crota was generated, and along with other Nightmares its essence was imbued into Zulmak."
        },
        {
          "alias": "energyExponent",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "60"
        }
      ]
    },
