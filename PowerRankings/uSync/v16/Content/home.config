                    "segment": null,
                    "value": "Destiny 2: Beyond Light"
                  },
                  {
                    "alias": "characterName",
                    "culture": null,
                    "editorAlias": null,
                    "segment": null,
                    "value": "Ak-Baral, Rival of Nav\u00F4ta"
                  },
                  {
                    "alias": "characterTitle",
                    "culture": null,
                    "editorAlias": null,
                    "segment": null,
                    "value": ""
                  },
                  {
                    "alias": "details",
                    "culture": null,
                    "editorAlias": null,
                    "segment": null,
                    "value": "After being defeated in material space, Ak-Baral would be returned to his Throne World like all Ascendant Hive do. He would regularly be summoned back into material space by his brood to continue to attempt to take over the Cosmodrome."
                  }
                ]
              },
              {
                "contentTypeKey": "6f386c25-c5f7-4cc6-8761-a63a480078ba",
                "key": "281011ec-57ff-466c-90fd-4917b202b955",
