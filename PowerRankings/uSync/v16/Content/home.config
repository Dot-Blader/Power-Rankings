        },
        {
          "alias": "characterName",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "Psion Triunes"
        },
        {
          "alias": "details",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "Three flayer siblings can unify themselves by merging their minds and bodies psionically, which will combine their power and allow them to accomplish greater feats than any one Psion could."
        },
        {
          "alias": "groupMembers",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": {
            "contentData": [
              {
                "contentTypeKey": "6f386c25-c5f7-4cc6-8761-a63a480078ba",
                "key": "a937cee9-c169-4ee1-975a-f7406da001fa",
                "udi": null,
                "values": [
                  {
                    "alias": "profilePicture",
