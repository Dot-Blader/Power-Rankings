                  },
                  {
                    "alias": "details",
                    "culture": null,
                    "editorAlias": null,
                    "segment": null,
                    "value": "This group of sibling witches were older than Oryx\u0027s daughters, and were the first of Oryx\u0027s witches to experiment with separating their deaths from themselves. They did so by hiding their deaths in each other, which meant they would all have to be defeated for any one of them to ever truly be."
                  },
                  {
                    "alias": "profilePicture",
                    "culture": null,
                    "editorAlias": null,
                    "segment": null,
                    "value": [
