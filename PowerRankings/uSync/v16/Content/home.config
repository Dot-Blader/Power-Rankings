                  {
                    "alias": "characterSource",
                    "culture": null,
                    "editorAlias": null,
                    "segment": null,
                    "value": "Little Nightmares"
                  },
                  {
                    "alias": "details",
                    "culture": null,
                    "editorAlias": null,
                    "segment": null,
                    "value": "This Chef was the second to encounter Six during her journey through the kitchen. He had been sleeping peacefully when the small disturbance woke him, but after not finding her he instead started his day of cooking and doing dishes alongside his brother. Six would evade him and his twin multiple times, angering the two Chefs more and more."
                  }
                ]
              }
            ],
