                  },
                  {
                    "alias": "characterName",
                    "culture": null,
                    "editorAlias": null,
                    "segment": null,
                    "value": "Ak-Baral, Rival of Nav\u00F4ta"
                  },
                  {
                    "alias": "characterSource",
                    "culture": null,
                    "editorAlias": null,
                    "segment": null,
                    "value": "Destiny 2: Beyond Light"
                  },
                  {
                    "alias": "details",
                    "culture": null,
                    "editorAlias": null,
                    "segment": null,
                    "value": "Ak-Baral was an Ascendant Knight who ruled over the brood that resided in the Cosmodrome after the Red War. This brood was made up from remnants of both Oryx and Crota\u0027s broods. A member of the brood, Nav\u00F4ta, was seeking to become Ascendant herself, hoping to take Ak-Baral\u0027s position from him."
                  },
                  {
                    "alias": "characterTitle",
                    "culture": null,
                    "editorAlias": null,
                    "segment": null,
                    "value": ""
                  },
                  {
                    "alias": "characterVariant",
                    "culture": null,
                    "editorAlias": null,
                    "segment": null,
                    "value": "Material Space"
                  }
                ]
              },
