        },
        {
          "alias": "characterName",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "The Supervisor"
        },
        {
          "alias": "characterSource",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "Little Nightmares 3"
        },
        {
          "alias": "details",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "The Supervisor managed the massive candy factory that sold candy to various places around the Nowhere. She would often be stressed due to the factory\u0027s shortcomings, and was easily provoked. Typically she had her lower body attached to a cart that looked like a skirt, but when angered by a couple of visiting children she tore herself off of it in order to pursue them more effectively. She had six arms, and crawled on them like an insect, and she had enough strength to be able to withstand the immense pressure of an industrial grade hydraulic press for a short moment, before getting crushed to death by it."
        }
      ]
    },
    {
      "contentTypeKey": "6f386c25-c5f7-4cc6-8761-a63a480078ba",
      "key": "28ff8f53-ec0e-4732-baa1-175888afed50",
