        {
          "alias": "characterName",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "Moto Bug"
        },
        {
          "alias": "characterSource",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "Sonic the Hedgehog"
        },
        {
          "alias": "details",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "Moto Bugs were the first Badniks encountered by Sonic. They are simple robots made by Eggman to help him control the territories he captures on his quest to conquer the world. Being robots, they have metallic hulls of standard Eggman Empire materials, which gives them decent natural protection, but not enough to withstand strikes from Sonic."
        },
        {
          "alias": "characterTitle",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "Badnik"
        }
      ]
    },
    {
