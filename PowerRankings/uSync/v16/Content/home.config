              "mediaKey": "ec5cd506-8990-4e7c-9861-751b6a67e080",
              "mediaTypeAlias": "Image",
              "crops": [],
              "focalPoint": null
            }
          ]
        },
        {
          "alias": "characterName",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "Atheon, Time\u0027s Conflux"
        },
        {
          "alias": "characterSource",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "Destiny"
        },
        {
          "alias": "details",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "Atheon was the centerpiece of the Vault of Glass. All timelines converged in the Vault through Atheon, who allowed the Vex of all these timelines to connect. It would be destroyed by a fireteam of Guardians, who were thrown into alternate timelines during their fight against this Minotaur, showing its control over time within the Vault."
        }
      ]
    },
    {
      "contentTypeKey": "6f386c25-c5f7-4cc6-8761-a63a480078ba",
      "key": "b5a3bbd6-b4ef-4435-9c97-8f886b676d16",
      "udi": null,
      "values": [
