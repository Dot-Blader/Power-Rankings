                  },
                  {
                    "alias": "mainPicture",
                    "culture": null,
                    "editorAlias": null,
                    "segment": null,
                    "value": [
                      {
                        "key": "01cad6cf-4926-4ac6-8ebf-71fd5f40aba9",
                        "mediaKey": "15e64ea7-67e4-4d6a-95ed-0985f11fc1e5",
                        "mediaTypeAlias": "Image",
                        "crops": [],
                        "focalPoint": null
                      }
                    ]
                  },
                  {
                    "alias": "characterVariant",
                    "culture": null,
                    "editorAlias": null,
                    "segment": null,
                    "value": "Carnevale Goer"
                  },
                  {
                    "alias": "characterSource",
                    "culture": null,
                    "editorAlias": null,
                    "segment": null,
                    "value": "Little Nightmares 3"
                  },
                  {
                    "alias": "details",
                    "culture": null,
                    "editorAlias": null,
                    "segment": null,
                    "value": "The Herd can be found as visitors to the Carnevale, and these gluttonous beasts feast on candy from the factory as they consume all the entertainment. They are often very docile and distracted by the performances of the Puppets, but if interrupted can lash out violently, breaking apart wooden stands easily with their brute strength."
                  }
                ]
              }
            ],
            "settingsData": [
