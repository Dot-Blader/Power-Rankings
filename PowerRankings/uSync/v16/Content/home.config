        {
          "alias": "characterName",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "Egg Hawk"
        },
        {
          "alias": "characterSource",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "Sonic Heroes"
        },
        {
          "alias": "details",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "The Egg Hawk was a large robotic bird used by Metal Sonic when he was disguised as Doctor Eggman. He used the machine to fight against Sonic and his friends, and due to being made for taking on multiple threats at once the Egg Hawk was incredibly strong. Its hull was so strong that it would take Sonic one hundred attacks to bring it down on his own."
        }
      ]
    },
