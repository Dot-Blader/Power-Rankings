        },
        {
          "alias": "details",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "CATERPILLARs were guardians stationed on Ouranos Island. They were built with protective shields, allowing them greater survivability in battles against most combatants. Even with their shields disabled the CATERPILLARs could withstand incredible power with its hull."
        }
      ]
    },
