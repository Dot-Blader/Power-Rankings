                    "segment": null,
                    "value": "Ecthar, Sword of Oryx"
                  },
                  {
                    "alias": "characterSource",
                    "culture": null,
                    "editorAlias": null,
                    "segment": null,
                    "value": "Destiny: The Taken King"
                  },
                  {
