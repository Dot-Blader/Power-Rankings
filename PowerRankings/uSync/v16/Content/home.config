                        "mediaKey": "46d69f02-2bff-40af-8100-0b33be15d8d0",
                        "mediaTypeAlias": "Image",
                        "crops": [],
                        "focalPoint": null
                      }
                    ]
                  },
                  {
                    "alias": "mainPicture",
                    "culture": null,
                    "editorAlias": null,
                    "segment": null,
                    "value": [
                      {
                        "key": "a6855554-50e2-44a9-8166-2876c13121b0",
                        "mediaKey": "93bd903b-b17f-46dd-a35a-110e40d08fc5",
                        "mediaTypeAlias": "Image",
